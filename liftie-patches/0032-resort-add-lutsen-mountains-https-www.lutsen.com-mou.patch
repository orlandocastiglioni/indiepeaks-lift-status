 lib/resorts/lutsen-mountains/resort.json   |   16 +
 lib/resorts/lutsen-mountains/trails.js     |   19 +
 test/resorts/example/lutsen-mountains.html | 4189 ++++++++++++++++++++
 test/resorts/lutsen-mountains-trails.js    |  439 ++
 test/resorts/lutsen-mountains.js           |   13 +
 6 files changed, 4691 insertions(+)
 create mode 100644 lib/resorts/lutsen-mountains/index.js
 create mode 100644 lib/resorts/lutsen-mountains/resort.json
 create mode 100644 lib/resorts/lutsen-mountains/trails.js
 create mode 100644 test/resorts/example/lutsen-mountains.html
 create mode 100644 test/resorts/lutsen-mountains-trails.js
 create mode 100644 test/resorts/lutsen-mountains.js

diff --git a/lib/resorts/lutsen-mountains/index.js b/lib/resorts/lutsen-mountains/index.js
new file mode 100644
index 00000000..bb4aa392
--- /dev/null
+++ b/lib/resorts/lutsen-mountains/index.js
@@ -0,0 +1,15 @@
+import select from '../../select.js';
+import { allText } from '../../tools/domutil.js';
+
+// same platform as granite-peak: flat component rows, status icon title attr
+export default {
+  selector: '.lift.component-row',
+  parse: row => {
+    const title = select(row.children, '.cell.title')[0];
+    const status = select(row.children, '.status .f-icon')[0];
+    if (!title || !status) {
+      return;
+    }
+    return { name: allText(title), status: status.attribs.title };
+  }
+};
diff --git a/lib/resorts/lutsen-mountains/resort.json b/lib/resorts/lutsen-mountains/resort.json
new file mode 100644
index 00000000..09273a4b
--- /dev/null
+++ b/lib/resorts/lutsen-mountains/resort.json
@@ -0,0 +1,16 @@
+{
+  "name": "Lutsen Mountains",
+  "url": {
+    "host": "https://www.lutsen.com",
+    "pathname": "/mountain-info/mountain-report"
+  },
+  "trails": true,
+  "tags": [
+    "Minnesota",
+    "Midwest"
+  ],
+  "ll": [
+    -90.7135,
+    47.654
+  ]
+}
diff --git a/lib/resorts/lutsen-mountains/trails.js b/lib/resorts/lutsen-mountains/trails.js
new file mode 100644
index 00000000..f060bf90
--- /dev/null
+++ b/lib/resorts/lutsen-mountains/trails.js
@@ -0,0 +1,19 @@
+import select from '../../select.js';
+import { allText } from '../../tools/domutil.js';
+
+export default {
+  selector: '.trail.component-row',
+  parse: row => {
+    const title = select(row.children, '.cell.title')[0];
+    const status = select(row.children, '.status .f-icon')[0];
+    const level = title && select(title.children, '.f-icon.level')[0];
+    if (!title || !status) {
+      return;
+    }
+    return {
+      name: allText(title),
+      status: status.attribs.title,
+      level: level?.attribs.title
+    };
+  }
+};
