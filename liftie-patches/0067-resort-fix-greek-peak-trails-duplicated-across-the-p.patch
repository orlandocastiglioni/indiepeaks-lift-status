From a6c0fd42b0f863ac36b0c5af4c062e8ddb1c883a Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Fri, 17 Jul 2026 13:02:28 +0000
Subject: [PATCH 67/77] resort: fix greek-peak - trails duplicated across the
 page's two tables

The conditions page renders two #gp-trail-table tables (a featured subset
plus the full list); the selector matched both, publishing 7 trails twice
(79 rows for 72 unique). Merge rows by name - open status wins, level kept
from whichever table carries it. Live output verified at 72 unique.
---
 lib/resorts/greek-peak/trails.js | 31 +++++++++++++++++++++++--------
 1 file changed, 23 insertions(+), 8 deletions(-)

diff --git a/lib/resorts/greek-peak/trails.js b/lib/resorts/greek-peak/trails.js
index 1859cd1b..0cd99175 100644
--- a/lib/resorts/greek-peak/trails.js
+++ b/lib/resorts/greek-peak/trails.js
@@ -1,3 +1,4 @@
+import select from '../../select.js';
 import { allText } from '../../tools/domutil.js';
 
 const emojiLevels = {
@@ -9,27 +10,41 @@ const emojiLevels = {
   '⛰': 'terrainPark'
 };
 
+const rank = { open: 0, closed: 1 };
+
 // #gp-trail-table rows: name cell starts with a difficulty emoji,
-// day column class carries trail-open/trail-closed (cell text is a time in season)
-export default {
-  selector: '#gp-trail-table tr',
-  parse: row => {
+// day column class carries trail-open/trail-closed (cell text is a time in
+// season). The page renders TWO #gp-trail-table tables (a featured subset +
+// the full list) with some trails in both - merge by name, open wins.
+export default function parse(dom) {
+  const byName = new Map();
+  for (const row of select(dom, '#gp-trail-table tr')) {
     const tds = row.children.filter(c => c.name === 'td');
     const nameCell = tds.find(c => c.attribs?.class?.includes('trail-col-name'));
     const day = tds.find(c => c.attribs?.class?.includes('trail-col-day'));
     const m = day?.attribs.class.match(/trail-(open|closed)/);
     if (!nameCell || !m) {
-      return;
+      continue;
     }
     const text = allText(nameCell).replace(/\s+/g, ' ').trim();
     const parts = text.match(/^(\S*?)\s*([A-Za-z0-9(].*)$/);
     if (!parts) {
-      return;
+      continue;
     }
-    return {
+    const trail = {
       name: parts[2].trim(),
       status: m[1],
       level: emojiLevels[parts[1]]
     };
+    const prev = byName.get(trail.name);
+    if (!prev) {
+      byName.set(trail.name, trail);
+    } else {
+      if (rank[trail.status] < rank[prev.status]) {
+        prev.status = trail.status;
+      }
+      prev.level ??= trail.level;
+    }
   }
-};
+  return [...byName.values()];
+}
-- 
