From da04374d8cc84d26e23f5fa2dcbae6d4a8c0e452 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Fri, 17 Jul 2026 12:59:21 +0000
Subject: [PATCH 62/77] resort: fix red-lodge-mountain - row layout changed,
 all lifts collapsed into one phantom

The site moved the lift name into .chair-header-right h2 and put a
'Chair Status' label first in each row, so every row parsed to the same
name and the app showed a single phantom lift 'Chair Status' (scheduled,
via the unknown-status fallback). Read the name from the h2 and the
status from the status icon alt; fixture refreshed to the current page.
---
 lib/resorts/red-lodge-mountain/index.js       |  15 +-
 .../example/red-lodge-mountain-2026.html      | 680 ++++++++++++++++++
 test/resorts/red-lodge-mountain.js            |  10 +-
 3 files changed, 695 insertions(+), 10 deletions(-)
 create mode 100644 test/resorts/example/red-lodge-mountain-2026.html

diff --git a/lib/resorts/red-lodge-mountain/index.js b/lib/resorts/red-lodge-mountain/index.js
index bfbb8808..b1d01eed 100644
--- a/lib/resorts/red-lodge-mountain/index.js
+++ b/lib/resorts/red-lodge-mountain/index.js
@@ -1,10 +1,15 @@
+import select from '../../select.js';
+import { findText } from '../../tools/domutil.js';
+
+// each .chair-header.row starts with a "Chair Status" label block; the lift
+// name lives in .chair-header-right h2 and the state in the status icon alt
 export default {
   selector: '.chair-header.row',
-  parse: {
-    name: '0/0',
-    status: {
-      child: '1/0/1/0',
-      attribute: 'alt'
+  parse: row => {
+    const name = findText(select(row.children, '.chair-header-right h2')[0]);
+    const status = select(row.children, '.chair-status img')[0]?.attribs.alt;
+    if (name && status) {
+      return { name, status };
     }
   }
 };
