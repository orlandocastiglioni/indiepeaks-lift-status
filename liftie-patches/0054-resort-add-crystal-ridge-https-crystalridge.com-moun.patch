diff --git a/lib/resorts/crystal-ridge/index.js b/lib/resorts/crystal-ridge/index.js
new file mode 100644
index 00000000..a4d8d6b8
--- /dev/null
+++ b/lib/resorts/crystal-ridge/index.js
@@ -0,0 +1,14 @@
+import select from '../../select.js';
+import { allText } from '../../tools/domutil.js';
+
+export default {
+  selector: '.Lift.component-row',
+  parse: row => {
+    const title = select(row.children, '.cell.title')[0];
+    const status = select(row.children, '.cell.status')[0];
+    if (!title || !status) {
+      return;
+    }
+    return { name: allText(title), status: status.attribs.title ?? allText(status) };
+  }
+};
diff --git a/lib/resorts/crystal-ridge/resort.json b/lib/resorts/crystal-ridge/resort.json
new file mode 100644
index 00000000..25b0ccf1
--- /dev/null
+++ b/lib/resorts/crystal-ridge/resort.json
@@ -0,0 +1,16 @@
+{
+  "name": "Crystal Ridge",
+  "url": {
+    "host": "https://crystalridge.com",
+    "pathname": "/mountain-info/snow-report/"
+  },
+  "trails": true,
+  "tags": [
+    "Wisconsin",
+    "Midwest"
+  ],
+  "ll": [
+    -88.0384,
+    42.8886
+  ]
+}
diff --git a/lib/resorts/crystal-ridge/trails.js b/lib/resorts/crystal-ridge/trails.js
new file mode 100644
index 00000000..db5d2683
--- /dev/null
+++ b/lib/resorts/crystal-ridge/trails.js
@@ -0,0 +1,19 @@
+import select from '../../select.js';
+import { allText } from '../../tools/domutil.js';
+
+export default {
+  selector: '.Trail.component-row',
+  parse: row => {
+    const title = select(row.children, '.cell.title')[0];
+    const status = select(row.children, '.cell.status')[0];
+    const level = title && select(title.children, '.f-icon.level')[0];
+    if (!title || !status) {
+      return;
+    }
+    return {
+      name: allText(title),
+      status: status.attribs.title ?? allText(status),
+      level: level?.attribs.title
+    };
+  }
+};
