 3 files changed, 382 insertions(+), 1 deletion(-)
 create mode 100644 lib/resorts/granite-peak/trails.js
 create mode 100644 test/resorts/granite-peak-trails.js

diff --git a/lib/resorts/granite-peak/resort.json b/lib/resorts/granite-peak/resort.json
index baa7fd02..6800b764 100644
--- a/lib/resorts/granite-peak/resort.json
+++ b/lib/resorts/granite-peak/resort.json
@@ -12,5 +12,6 @@
     -89.6832,
     44.9328
   ],
-  "twitter": "SkiGranitePeak"
+  "twitter": "SkiGranitePeak",
+  "trails": true
 }
diff --git a/lib/resorts/granite-peak/trails.js b/lib/resorts/granite-peak/trails.js
new file mode 100644
index 00000000..6855064c
--- /dev/null
+++ b/lib/resorts/granite-peak/trails.js
@@ -0,0 +1,21 @@
+import select from '../../select.js';
+import { allText } from '../../tools/domutil.js';
+
+// trail rows are nested under each lift's <details>; the difficulty and
+// status icons carry title attributes (occasionally a raw term id, coerced away)
+export default {
+  selector: '.trail.component-row',
+  parse: row => {
+    const title = select(row.children, '.cell.title')[0];
+    const status = select(row.children, '.status .f-icon')[0];
+    const level = title && select(title.children, '.f-icon.level')[0];
+    if (!title || !status) {
+      return;
+    }
+    return {
+      name: allText(title),
+      status: status.attribs.title,
+      level: level?.attribs.title
+    };
+  }
+};
