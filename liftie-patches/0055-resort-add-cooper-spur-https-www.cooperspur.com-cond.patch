 lib/resorts/cooper-spur/resort.json   |   15 +
 test/resorts/cooper-spur.js           |    6 +
 test/resorts/example/cooper-spur.html | 1466 +++++++++++++++++++++++++
 4 files changed, 1502 insertions(+)
 create mode 100644 lib/resorts/cooper-spur/index.js
 create mode 100644 lib/resorts/cooper-spur/resort.json
 create mode 100644 test/resorts/cooper-spur.js
