diff --git a/lib/resorts/cooper-spur/index.js b/lib/resorts/cooper-spur/index.js
new file mode 100644
index 00000000..37d6e353
--- /dev/null
+++ b/lib/resorts/cooper-spur/index.js
@@ -0,0 +1,15 @@
+import select from '../../select.js';
+import { findText } from '../../tools/domutil.js';
+
+// conditions page is one feature list mixing weather, parking and the two
+// lifts - keep only the lift-shaped entries
+export default {
+  selector: '.eael-feature-list-content-box',
+  parse: box => {
+    const name = findText(select(box.children, '.eael-feature-list-title')[0])?.trim();
+    const status = findText(select(box.children, '.eael-feature-list-content')[0])?.trim();
+    if (name && status && /lift|tow|chair|carpet/i.test(name)) {
+      return { name, status };
+    }
+  }
+};
diff --git a/lib/resorts/cooper-spur/resort.json b/lib/resorts/cooper-spur/resort.json
new file mode 100644
index 00000000..0dea772f
--- /dev/null
+++ b/lib/resorts/cooper-spur/resort.json
@@ -0,0 +1,15 @@
+{
+  "name": "Cooper Spur",
+  "url": {
+    "host": "https://www.cooperspur.com",
+    "pathname": "/conditions-report/"
+  },
+  "tags": [
+    "Oregon",
+    "Mt Hood"
+  ],
+  "ll": [
+    -121.6273,
+    45.4479
+  ]
+}
diff --git a/test/resorts/cooper-spur.js b/test/resorts/cooper-spur.js
new file mode 100644
index 00000000..cc5097ed
--- /dev/null
+++ b/test/resorts/cooper-spur.js
@@ -0,0 +1,6 @@
+import lifts from '../lifts/index.js';
+
+lifts('cooper-spur', 'html', {
+  'Homestead Lift': 'closed',
+  'Rope Tow': 'closed'
+});
