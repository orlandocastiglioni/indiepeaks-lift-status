+document.addEventListener("DOMContentLoaded", function () {
+
+  // -------------------------------------------------------
+  // 1. Fix Elementor Accordion Tabs (remove nested <a>)
+  // -------------------------------------------------------
+  document.querySelectorAll(".elementor-tab-title a.elementor-accordion-title").forEach(link => {
+    const span = document.createElement('span');
+    span.className = link.className;
+    span.textContent = link.textContent;
+    link.replaceWith(span);
+  });
+
+  // -------------------------------------------------------
+  // 2. Strip interactive role from listbox buttons
+  // -------------------------------------------------------
+  document.querySelectorAll('ul[role="listbox"] li button').forEach(button => {
+    const span = document.createElement('span');
+    span.className = button.className;
+    span.textContent = button.textContent;
+    span.style.cursor = 'pointer';
+    span.setAttribute('aria-hidden', 'true');
+    span.addEventListener('click', () => button.click());
+    button.replaceWith(span);
+  });
+
+  // -------------------------------------------------------
+  // 3. Fix Date and Time Pickers ARIA Attributes
+  // -------------------------------------------------------
+  ["rtb-date", "rtb-time"].forEach(id => {
+    const el = document.getElementById(id);
+    if (!el) return;
+    el.setAttribute("role", "combobox");
+    el.setAttribute("aria-haspopup", "dialog");
+    el.setAttribute("aria-expanded", "false");
+    const owns = el.getAttribute("aria-owns");
+    if (owns) {
+      el.setAttribute('aria-controls', owns);
+      el.removeAttribute('aria-owns');
+    }
+    if (el.hasAttribute('readonly')) {
+      el.setAttribute('aria-readonly', 'true');
+    }
+  });
+
+  // -------------------------------------------------------
+  // 4. FAQ link aria-label
+  // -------------------------------------------------------
+  document.querySelectorAll('a[href*="/faq"]').forEach(link => {
+    if (link.textContent.trim() === 'FAQ') {
+      link.setAttribute('aria-label', 'Frequently Asked Questions');
+    }
+  });
+
+  // -------------------------------------------------------
+  // 5. Logo link aria-label
+  // -------------------------------------------------------
+  const homeUrl = window.location.origin + "/";
+  document.querySelectorAll(`a.logo-link[href^="${homeUrl}"]`).forEach((link, index) => {
+    if (!link.hasAttribute("aria-label")) {
+      link.setAttribute("aria-label",
+        index === 0
+          ? "Cooper Spur Mountain Resort Home"
+          : `Cooper Spur Mountain Resort Home (Logo ${index + 1})`
+      );
+    }
+  });
+
+  // -------------------------------------------------------
+  // 6. Gallery lightbox links
+  // -------------------------------------------------------
+  document.querySelectorAll('a[data-elementor-open-lightbox="yes"]').forEach(el => {
+    el.setAttribute('role', 'button');
+    el.setAttribute('aria-haspopup', 'dialog');
+    if (!el.getAttribute('aria-label')) {
+      el.setAttribute('aria-label', 'Open image in lightbox');
+    }
+  });
+
+  // -------------------------------------------------------
+  // 7. Lightbox keyboard navigation
+  // -------------------------------------------------------
+  (function () {
+    var FOCUSABLE = [
+      '.dialog-close-button',
+      '.elementor-slideshow__header [tabindex="0"]',
+      '.elementor-swiper-button-next',
+      '.elementor-swiper-button-prev'
+    ].join(', ');
+
+    var CLICKABLE = [
+      '.eicon-zoom-in-bold',
+      '.eicon-frame-expand',
+      '.eicon-share-arrow',
+      '.elementor-swiper-button-next',
+      '.elementor-swiper-button-prev',
+      '.dialog-close-button'
+    ].join(', ');
+
+    function patchButtons() {
+      document.querySelectorAll(CLICKABLE).forEach(function (btn) {
+        if (btn.dataset.kbPatched) return;
+        btn.dataset.kbPatched = 'true';
+        btn.addEventListener('keydown', function (e) {
+          if (e.key === 'Enter' || e.key === ' ') {
+            e.preventDefault();
+            e.stopImmediatePropagation();
+            btn.click();
+          }
+        }, true);
+      });
+    }
+
+    document.addEventListener('keydown', function (e) {
+      if (e.key !== 'Tab') return;
+      var lightbox = document.querySelector('.dialog-lightbox-widget');
+      if (!lightbox || window.getComputedStyle(lightbox).display === 'none') return;
+      var focusable = Array.from(lightbox.querySelectorAll(FOCUSABLE))
+        .filter(el => el.offsetWidth > 0 || el.closest('.elementor-lightbox'));
+      var currentIndex = focusable.indexOf(document.activeElement);
+      if (currentIndex === -1) return;
+      e.preventDefault();
+      e.stopImmediatePropagation();
+      var nextIndex = e.shiftKey
+        ? (currentIndex - 1 + focusable.length) % focusable.length
+        : (currentIndex + 1) % focusable.length;
+      focusable[nextIndex].focus();
+    }, true);
+
+    document.addEventListener('focusin', function (e) {
+      var lightbox = document.querySelector('.dialog-lightbox-widget');
+      if (!lightbox || !lightbox.contains(e.target)) return;
+      var swiper = document.querySelector('.elementor-lightbox .swiper');
+      if (swiper) swiper.classList.remove('elementor-slideshow--ui-hidden');
+    }, true);
+
+    patchButtons();
+    new MutationObserver(patchButtons).observe(document.body, { childList: true, subtree: true });
+  })();
+
+  // -------------------------------------------------------
+  // 8. Desktop nav: submenu keyboard support + ARIA
+  // -------------------------------------------------------
+  document.querySelectorAll(
+    '#site-navigation-bottom-desktop .menu-item-has-children > a'
+  ).forEach(link => {
+    const li = link.closest('.menu-item-has-children');
+    link.setAttribute('aria-haspopup', 'true');
+    link.setAttribute('aria-expanded', 'false');
+
+    link.addEventListener('keydown', function (e) {
+      if (e.key === 'Enter' || e.key === ' ') {
+        e.preventDefault();
+        const isOpen = li.classList.contains('focus');
+        li.classList.toggle('focus', !isOpen);
+        link.setAttribute('aria-expanded', String(!isOpen));
+      }
+      if (e.key === 'Escape') {
+        li.classList.remove('focus');
+        link.setAttribute('aria-expanded', 'false');
+        link.focus();
+      }
+    });
+
+    li.addEventListener('focusout', function () {
+      setTimeout(() => {
+        if (!li.contains(document.activeElement)) {
+          li.classList.remove('focus');
+          link.setAttribute('aria-expanded', 'false');
+        }
+      }, 100);
+    });
+  });
+
+  // -------------------------------------------------------
