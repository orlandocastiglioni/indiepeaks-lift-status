+  if (mobileToggle) {
+    mobileToggle.setAttribute('aria-label', 'Open navigation menu');
+    mobileToggle.setAttribute('aria-expanded', 'false');
+    mobileToggle.setAttribute('aria-controls', 'site-navigation-sidebar-mobile');
+    mobileToggle.addEventListener('click', function () {
+      const isOpen = this.getAttribute('aria-expanded') === 'true';
+      this.setAttribute('aria-expanded', String(!isOpen));
+      this.setAttribute('aria-label', isOpen ? 'Open navigation menu' : 'Close navigation menu');
+    });
+  }
+
+  // -------------------------------------------------------
+  // 10. Nav landmark labels
+  // -------------------------------------------------------
+  const desktopNav = document.querySelector('#site-navigation-bottom-desktop');
+  const mobileNav  = document.querySelector('#site-navigation-sidebar-mobile');
+  if (desktopNav) desktopNav.setAttribute('aria-label', 'Main');
+  if (mobileNav)  mobileNav.setAttribute('aria-label', 'Main mobile');
+
+});
