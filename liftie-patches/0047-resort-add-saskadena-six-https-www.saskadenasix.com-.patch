diff --git a/lib/resorts/saskadena-six/index.js b/lib/resorts/saskadena-six/index.js
new file mode 100644
index 00000000..62a061d0
--- /dev/null
+++ b/lib/resorts/saskadena-six/index.js
@@ -0,0 +1,6 @@
+import coerce from '../../tools/coerce.js';
+import sections from './sections.js';
+
+export default function parse(dom) {
+  return Object.fromEntries(sections(dom, 'Lifts').map(({ name, status }) => [name, coerce(status)]));
+}
