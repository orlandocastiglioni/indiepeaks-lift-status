/p>\n\u003C/div>\n\u003C/div>\n\u003C/div>"},"region":"Alberta","country":"Canada","regions":["CalgaryArea"],"groups":[{"groupId":"ShaganappiNordic","groupName":"Shaganappi Nordic Ski Trails","groupBounds":[[-114.13595321620532,51.04097289633012],[-114.11669182561675,51.049934378343465]]},{"groupId":"ShaganappiFatbike","groupOrder":1,"groupName":"Snowshoe and Fatbike Trails","groupBounds":[[-114.13670282641665,51.04110223033089],[-114.11691656987618,51.04994056058471]]},{"groupId":"MultiUse","groupOrder":2,"groupName":"Multi-Use Trails","groupBounds":[[-114.13402229701671,51.04095237648908],[-114.12242282945687,51.049440121026095]]}],"logo":"AB-CalgaryShaganappi.jpg","banner":"AB-CalgaryShaganappi-banner.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-03-14T20:59:18.596Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-03-14T20:59:18.596Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-03-14T20:59:18.596Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-03-14T20:59:18.596Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-03-14T20:59:18.596Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-03-14T20:59:18.596Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":17350.81,"percent":100}],"7d":[{"id":"twoWeeksAgo","distance":17350.81,"percent":100}],"4d":[{"id":"twoWeeksAgo","distance":17350.81,"percent":100}],"36h":[{"id":"twoWeeksAgo","distance":17350.81,"percent":100}],"24h":[{"id":"twoWeeksAgo","distance":17350.81,"percent":100}],"12h":[{"id":"twoWeeksAgo","distance":17350.81,"percent":100}]},"lastGroomedGroups":[{"id":"twoWeeksAgo","distance":17350.81,"percent":100}],"active":true,"timezone":"America/Denver","liveTrack":true,"coordinates":[51.0447147,-114.1238232],"distance":17350.80884297875,"distanceGroups":[{"id":"easy","distance":10.67,"percent":61.49869444279119},{"id":"intermediate","distance":3.31,"percent":19.100391759555826},{"id":"advanced","distance":0.75,"percent":4.312700696294212}],"links":{"website":{"en":"https://www.shaganappinordic.ca"}},"snowDepth":6,"snowDepthUnpacke