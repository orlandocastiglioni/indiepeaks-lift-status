[-117.95264752652794,49.2498075970515],[-117.95264752652794,49.25338209702566],[-117.96765292406533,49.25338209702566],[-117.96765292406533,49.253026297028235],[-117.9740923004836,49.253026297028235],[-117.9740923004836,49.248665397059746],[-117.97652236284787,49.248665397059746],[-117.97652236284787,49.25025539704826],[-117.99740016086574,49.25025539704826],[-117.99740016086574,49.24891739705793],[-118.0065027871357,49.24891739705793],[-118.0065027871357,49.24806839706407],[-118.02137976227876,49.24806839706407],[-118.02137976227876,49.241503197111506],[-118.03423108281649,49.241503197111506],[-118.03423108281649,49.23447539716227],[-118.0392284460537,49.23447539716227],[-118.0392284460537,49.22982139719589],[-118.0394105344003,49.22982139719589],[-118.0394105344003,49.225243497228924],[-118.04012392695809,49.225243497228924],[-118.04012392695809,49.21000389368325]]]],"lastGroomed":"2026-03-21T16:02:32.000Z","weatherSources":["6920fa80e9bd1b159a5e9fe5","680907e5e3004a71b66ca196"],"name":{"en":"Castlegar Nordic"},"city":{"en":"Castlegar"},"sponsorText":{"en":"\u003Cp>The service fee for Castlegar Nordic Ski Trails has been graciously covered by Gerick Cycle and Ski.\u003C/p>"},"description":{"en":"\u003Cp>The Castlegar Nordic Ski Club has been providing well maintained cross country ski trails in the Paulson area for the last 50 years.&nbsp; The club operates and maintains the&nbsp;\u003Cem>Paulson Cross Country Ski Trails\u003C/em>, located 32 km west of Castlegar.\u003C/p>\n\u003Cp>With over 60 km of packed and tracked&nbsp;\u003Ca href=\"https://www.castlegarnordic.ca/trails-and-maps\">ski trails\u003C/a>&nbsp;ranging from beginner to advanced levels, the club hosts thousands of user-days every season.&nbsp; There are trails for everyone, from a popular 7.5 km circular route from Mud Lake to the Ben Shaw cabin that is ideal for young families and beginners, to numerous longer, more challenging loop trails for intermediate and expert skiers.&nbsp; Several kilometres of untracked trails are available for more advanced backcountry skiers. The Viking Centre and four modern warming huts offer opportunities for a variety of adventures from a short hour-long ski to a full day outing.&nbsp; Our trails are groomed and tracked primarily for classic style skiing but some opportunities exist on the wider packed trails for skate skiing as well.\u003C/p>\n\u003Cp>Since becoming a registered non-profit Society in 1990, club membership has grown greatly, varying year-to-year from 600 to over 1200 members.&nbsp; Members and day-users include individuals and families from Castlegar, Trail, Rossland, Nelson, Grand Forks, Christina Lake, the Slocan Valley, Washington State and many other communities.\u003C/p>\n\u003Cp>Our trails are located 32 km west of Castlegar on Highway #3, or 33 km north of Rossland, just west of the junction of Highway #3 and Highway #3B near Nancy Greene Provincial Park.\u003C/p>"},"region":"British Columbia","country":"Canada","regions":["WestKootenays","Kootenays"],"groups":[{"groupId":"alltrails","groupName":"All Trails","groupBounds":[[-118.0346173199355,49.203342271458574],[-117.94362709562573,49.24942921217285]]}],"logo":"BC-CastlegarNordic.png","banner":"2022-11-23T14-04-24-890-08:00_BC-CastlegarNordic_Julien.jpg","lastGroomedClass":"oneDayAgo","active":true,"timezone":"America/Vancouver","liveTrack":true,"coordinates":[49.242685,-117.999879],"distance":62248.43277330046,"distanceGroups":[{"id":"easy","distance":12.08,"percent":19.411287551725962},{"id":"intermediate","distance":40.46,"percent":64.99668339454473},{"id":"advanced","distance":9.71,"percent":15.592029053729298}],"links":{"website":{"en":"http://www.castlegarnordic.ca/"},"weather":{"en":"https://www.castlegarnordic.ca/weather/"},"tickets":{"en":"https://www.castlegarnordic.ca/membership-fees/"},"email":{"en":"castlegarnordicski@gmail.com"},"fb":{"en":"https://www.facebook.com/CastlegarNordicSkiClub#"},"ig":{"en":"https://www.instagram.com/castlegarnordicskiclub/"}},"sponsor":true,"sponsorLogo":"2025-12-09T21-16-10-902+01:00_BC-CastlegarNordic_logo_0.png","sponsorLink":"https://www.gericks.com/","currentTemp":4.9,"elevation":1302,"lastTrailsUpdate":"2025-12-01T01:33:43.700Z","tempUnits":"C","timezoneUTC":"-7","reportLatest":{"updatedAt":"2026-03-30T23:43:18.911Z","clubId":"BC-CastlegarNordic","type":"grooming-report","content":{"en":"\u003Cp>Hello Skiers,\u003C/p>\n\u003Cp>A bit of a spring surprise. You will find a decent single track around Booty's/Benshaw!&nbsp;\u003C/p>\n\u003Cp>From the bit of snow last night and you could actually have some pretty decent skiing all around the club. A nice bit of powder covering the hard pack. Must be lovely up top. Probably make some nice turns if you bring out the wider boards.&nbsp;\u003C/p>\n\u003Cp>Enjoy the off season !\u003C/p>\n\n"},"account":"692f34dfdd42915ab023bf2c","author":"Rolf ","timestamp":"2026-03-30T23:40:02.000Z","deviceId":"49a7f149ca7b1259"}},{"clubId":"BC-BulkleyValley","season":"winter","activities":["nordic"],"countryId":"CA","regionId":"BC","permalink":"Bulkley-Valley-Nordic","bounds":[[-127.2782104279543,54.717846269661365],[-127.18107085960176,54.75827051037404]],"offlineMapsBounds":[[[[-127.28443897343801,54.720979171772406],[-127.26610839450612,54.720979171772406],[-127.26610839450612,54.720266205778984],[-127.24065557721003,54.720266205778984],[-127.24065557721003,54.71496844882791],[-127.24046003903608,54.71496844882791],[-127.24046003903608,54.71424874883453],[-127.20975946680764,54.71424874883453],[-127.20975946680764,54.71483374882914],[-127.18762072333686,54.71483374882914],[-127.18762072333686,54.72902255235384],[-127.2028993397335,54.72902255235384],[-127.2028993397335,54.72903314869804],[-127.20203465094383,54.72903314869804],[-127.20203465094383,54.731330588090785],[-127.19757228448435,54.731330588090785],[-127.19757228448435,54.73700937700369],[-127.17975971113074,54.73700937700369],[-127.17975971113074,54.74731304852912],[-127.17483