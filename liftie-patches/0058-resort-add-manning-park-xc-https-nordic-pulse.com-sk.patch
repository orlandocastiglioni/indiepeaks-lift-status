6.14079327103192,44.87151996616962],[-116.14079327103192,44.85225935263198]]]],"lastGroomed":"2026-02-26T14:16:42.000Z","weatherSources":["69282c70dfe3cf247f56f57a"],"name":{"en":"Valley County Pathways"},"city":{"en":"McCall"},"description":{"en":"\u003Cp>The winter North Valley Rail Trail system is a free community resource in McCall, ID. It covers over 10 km of mostly gentle terrain with a few hills. We welcome all non-motorized users like xc skiers, snowshoers, fat bikers and walkers. Dogs are welcome too! The trail system is established and managed by Valley County Pathways, a community nonprofit. It is groomed on a regular basis thanks to private donations and financial support from the City of McCall's local option tax funds.&nbsp;\u003C/p>\n\u003Cp>For more information and to donate go to&nbsp;\u003Ca href=\"https://www.valleycountypathways.org/winter-trails/\" target=\"_blank\" rel=\"noopener\">valleycountypathways.org\u003C/a>\u003C/p>"},"region":"Idaho","country":"USA","regions":["US-ID-McCall"],"logo":"2025-11-27T11-48-37-753+01:00_US-ID-ValleyCountyPathways_0.jpg","banner":"2025-11-27T11-59-50-367+01:00_US-ID-ValleyCountyPathways_0.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-02-26T14:16:42.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-02-26T14:16:42.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-02-26T14:16:42.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-02-26T14:16:42.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-02-26T14:16:42.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-02-26T14:16:42.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":8897.09,"percent":86.81}],"7d":[{"id":"twoWeeksAgo","distance":8897.09,"percent":86.81}],"4d":[{"id":"twoWeeksAgo","distance":8897.09,"percent":86.81}],"36h":[{"id":"twoWeeksAgo","distance":8897.09,"percent":86.81}],"24h":[{"id":"twoWeeksAgo","distance":8897.09,"percent":86.81}],"12h":[{"id":"twoWeeksAgo","distance":8897.09,"percent":86.81}]},"active":true,"timezone":"America/Boise","liveTrack":true,"coordinates":[44.87182624176236,-116.11547057732314],"distance":10248.506915610536,"distanceGroups":[{"id":"easy","distance":8.9,"percent":86.81353914768987},{"id":"intermediate","distance":1.35,"percent":13.18646085231013}],"links":{"website":{"en":"https://www.valleycountypathways.org/winter-trails/"},"weather":{"en":"https://www.yr.no/en/forecast/daily-table/2-5600363/United%20States/Idaho/Valley/McCall"}},"elevation":1519,"lastTrailsUpdate":"2026-01-05T20:06:06.713Z","tempUnits":"F","timezoneUTC":"-6","reportLatest":{"updatedAt":"2026-03-07T21:41:15.100Z","clubId":"US-ID-ValleyCountyPathways","type":"grooming-report","content":{"en":"\u003Cp>Well, after a winter that never really got going on the Valley County Pathways winter trail system it appears that spring is arriving early. &nbsp;We've suspended grooming for the season but on the bright side with as little snow that's on the Rail Trail hopefully it will melt off quickly and we can transition into summer mode. &nbsp;On another positive note we had enough snow to get fealing for the new trails and some of the work that needs done for next year, mostly ditch crossings. &nbsp;After this season I think it's apparent that if we get the ditches flattened out we can start grooming trails there with not much snow. &nbsp;Hopefully we'll also have some actual names for the trails. &nbsp;Looking forward to next season.\u003C/p>"},"account":"6937462b87842d7dcf10b6a7","author":"Toddc","timestamp":"2026-03-07T21:24:09.000Z","deviceId":"528D683E-1445-4217-9A19-F66FCF1CA3DE"},"reportNotices":[{"updatedAt":"2026-07-11T15:49:57.013Z","clubId":"US-ID-ValleyCountyPathways","type":"grooming-report-notice","content":{"en":"\u003Cp>We are only grooming the Rail Trail at this time due to the lack of snow. &nbsp;We really need at least a foot of snow to build the other trails due to all the irregularities in the fields.\u003C/p>"},"account":"6937462b87842d7dcf10b6a7","author":"Toddc","timestamp":"2026-01-29T14:18:33.000Z","deviceId":"528D683E-1445-4217-9A19-F66FCF1CA3DE"},{"updatedAt":"2026-07-11T15:49:57.013Z","clubId":"US-ID-ValleyCountyPathways","type":"grooming-report-notice","content":{"en":"\u003Cp>We have opened the Meadow trail and are currently working on the new trails.\u003C/p>"},"account":"6937462b87842d7dcf10b6a7","author":"Toddc","timestamp":"2026-02-02T15:40:05.000Z","deviceId":"528D683E-1445-4217-9A19-F66FCF1CA3DE"},{"updatedAt":"2026-07-11T15:49:57.013Z","clubId":"US-ID-ValleyCountyPathways","type":"grooming-report-notice","content":{"en":"\u003Cp>Over the summer Valley County Pathways was able to obtain permission to groom several kilometers of trails on privately owned land. This opportunity has significantly extended our trail network. This will be a work in progress as we experiment with trail placement to try and find what works. These trails, like the the other Valley County winter trails, will be open to Nordic skiing, walking, snowshoeing, and fat tire biking. The trails are closed to all motorized travel. &nbsp;We ask users to respect this private property by staying on the designated trails and &nbsp;picking up after your dogs please!&nbsp;\u003C/p>"},"account":"6937462b87842d7dcf10b6a7","author":"Toddc","timestamp":"2026-02-04T15:18:17.000Z","deviceId":"528D683E-1445-4217-9A19-F66FCF1CA3DE"}]},{"clubId":"US-WY-GrandTarghee","activities":["fatbike","nordic"],"countryId":"US","regionId":"WY","permalink":"GrandTarghee","bounds":[[-110.9720359400287,43.782257872872094],[-110.95163422799193,43.80777341359366]],"lastGroomed":"2026-02-26T14:15:00.000Z","weatherSources":["680907e6e3004a71b66ca3ae"],"name":{"en":"Grand Targhee Resort"},"city":{"en":"Alta"},"region":"Wyoming","country":"USA","regions":["US-WY-JHNordic","US-CCSAA","US-WY-JHNordic-TetonValleyArea"],"groups":[{"groupId":"GrandTarghee","groupName":"Nordic Trails","groupBounds":[[-110.96857783151103,43.786648072871074],[-110.95163422799193,43.80777341359366]]},{"groupId":"GrandTargheeFB","groupOrder":1,