003C/p>"},"account":"692f34ebdd42915ab023c05e","author":"janet K","timestamp":"2026-03-23T00:36:57.802Z"}},{"clubId":"BC-CypressMountain","activities":["nordic"],"countryId":"CA","regionId":"BC","permalink":"Cypress-Mountain","bounds":[[-123.1925055,49.3737292],[-123.1689876,49.3947454]],"lastGroomed":"2026-04-12T15:10:52.000Z","weatherSources":["680907e6e3004a71b66ca472"],"name":{"en":"Cypress Mountain"},"city":{"en":"West Vancouver"},"region":"British Columbia","country":"Canada","regions":["US-CCSAA"],"groups":[{"groupId":"CypressNordicLower","groupName":"Nordic Lower Trails"},{"groupId":"CypressNordicUpper","groupName":"Nordic Upper Trails"},{"groupId":"CypressNordicRidge","groupName":"Nordic Ridge Trails"},{"groupId":"CypressNordicEast","groupName":"Nordic Far East Trails"}],"logo":"2023-06-08T15-28-21-507-06:00_BC-CypressMountain_logo.png","banner":"2023-03-05T09-18-04-500-07:00_BC-CypressMountain_Rob.jpg","lastGroomedClass":"sevenDaysAgo","active":true,"timezone":"America/Vancouver","liveTrack":true,"coordinates":[49.37890527833566,-123.19250675796249],"distance":"22531.657681407232","distanceGroups":[{"id":"easy","distance":8.16,"percent":36.21941872530226},{"id":"intermediate","distance":7.81,"percent":34.67638419060427},{"id":"advanced","distance":6.56,"percent":29.10419708409347}],"links":{"website":{"en":"https://cypressmountain.com/cross-country-skiing"},"weather":{"en":"https://www.yr.no/en/map/weather/49.396,-123.202"},"webcam":{"en":"https://youtu.be/YWyUuLjnVS8"}},"snowDepth":75,"currentTemp":11,"currentCond":"Good","waxKick":"Swix Universal Klister ","waxGlide":"Swix Universal Klister","elevation":906,"lastTrailsUpdate":"2024-03-04T23:17:12.039Z","tempUnits":"C","timezoneUTC":"-7","reportLatest":{"updatedAt":"2026-04-12T15:15:03.181Z","clubId":"BC-CypressMountain","type":"grooming-report","content":{"en":"\u003Ch3>April 12th\u003C/h3>\n\u003Cdiv>\n\u003Cdiv>Morning update:\u003Cbr>\u003Cbr>It is the last day of operations here at Cypress Mountain for our guests to come and have their final cross country ski or snowshoe. It's a mild morning and the temperature is currently 6 degrees with high cloud. There is some light precipitation forecasted later in the day.\u003Cbr>\u003Cbr>The overnight groom has been complete and trails are track-set. Trails will soften through the day with any precipitation that falls and with rise in temperature.\u003Cbr>\u003Cbr>There is variable snow cover across the trails. Guests are asked to keep alert of unmarked hazards.\u003Cbr>\u003Cbr>For the most up-to-date trail information, please check the Nordic Pulse app or refer to the list of open trails below.\u003Cbr>\u003Cbr>Waxing tip: Swix Universal Klister\u003Cbr>\u003Cbr>We hope you have a wonderful time snowshoeing or cross-country skiing, and thank you for joining us out on the trails!\u003Cbr>___________________________________________________________________\u003Cbr>\u003Cbr>\u003Cstrong>HOURS OF OPERATION\u003Cbr>for Sunday, April 12th\u003C/strong>\u003Cbr>\u003Cbr>\u003Cstrong>Please note that our opening hours will be&nbsp;\u003Cu>9:00 AM - 4:00 PM\u003C/u>&nbsp;from March 30th to April 12th (our anticipated close date).\u003C/strong>\u003Cbr>\u003Cbr>\u003Cstrong>\u003Cem>Activities\u003C/em>\u003C/strong>\u003Cbr>- Cross-Country Trails | 9:00am - 4:00am\u003Cbr>- Tube Park | 10:00am - 4:00pm* |&nbsp;\u003Cstrong>\u003Cem>CLOSED FOR THE SEASON\u003C/em>\u003C/strong>\u003Cbr>- Sliding | 10:00am - 4:00pm* |&nbsp;\u003Cstrong>\u003Cem>CLOSED FOR THE SEASON\u003C/em>\u003C/strong>\u003Cbr>- Snowshoe Trails | 9:00am - 4:00pm* |&nbsp;\u003Cstrong>\u003Cem>*Last tickets &amp; rentals sold at 2:30pm\u003C/em>\u003C/strong>\u003Cbr>\u003Cbr>\u003Cstrong>\u003Cem>Dining\u003C/em>\u003C/strong>\u003Cbr>- Nordic Cafe |&nbsp;\u003Cstrong>\u003Cem>9:00 - 3.30pm\u003C/em>\u003C/strong>\u003Cbr>- Hollyburn Lodge | 10:00am - 4:00pm |&nbsp;\u003Cstrong>\u003Cem>*Last call at 3:00pm\u003C/em>\u003C/strong>\u003Cbr>___________________________________________________________________\u003Cbr>\u003Cbr>\u003Cstrong>SNOWSHOE TRAILS OPEN\u003C/strong>\u003Cbr>\u003Cbr>Please watch out for thin snow cover and unmarked hazards, such as sinkholes, open creeks and narrow snow bridges.&nbsp;\u003Cstrong>We urge guests to follow the poles, rather than footprints, on the trails.\u003C/strong>\u003Cbr>\u003Cbr>\u003Cstrong>\u003Cem>Green (Easiest)\u003C/em>\u003C/strong>\u003Cbr>\u003Cbr>- Hollyburn Meadows\u003Cbr>- Burfield Forest\u003Cbr>- Short Cut\u003Cbr>- Cabin Island\u003Cbr>- Tree Island\u003Cbr>\u003Cbr>\u003Cstrong>\u003Cem>Blue (Intermediate)\u003C/em>\u003C/strong>\u003Cbr>\u003Cbr>- Strait Express\u003Cbr>- Ancient Giants&nbsp;\u003Cem>(access via Marr Creek)\u003C/em>\u003Cbr>- Marr Creek\u003Cbr>- Marr Giant Connector\u003Cbr>- Sitzmark Glade\u003Cbr>- Snow Gully\u003Cbr>\u003Cbr>\u003Cstrong>\u003Cem>Black (Intermediate to Hard)\u003C/em>\u003C/strong>\u003Cbr>\u003Cbr>- Ridge Fall Line\u003Cbr>- Ridge Traverse\u003Cbr>- Table Top Loop\u003Cbr>- Lake District\u003Cbr>- Upper Glades\u003Cbr>- Upper Limits\u003Cbr>- Seventh Lake\u003Cbr>- Far East\u003Cbr>\u003Cbr>More runs will open as conditions allow. We kindly ask that guests respect all \"Closed\" signage. Updates will be shared regularly through our social media channels and this mountain report.\u003Cbr>___________________________________________________________________\u003Cbr>\u003Cbr>Come on up and enjoy the mountain!\u003Cbr>\u003Cbr>\u003Ca href=\"https://www.cypressmountain.com/nordic-season-passes\">Buy your 26/27 Nordic Season Passes today!\u003C/a>\u003C/div>\n\u003C/div>"},"account":"670e8d0c2ed2217c80aa12f8","author":"Trudie","timestamp":"2026-04-12T15:14:56.292Z","snowDepth":75,"currentTemp":11,"currentCond":"Good","waxKick":"Swix Universal Klister ","waxGlide":"Swix Universal Klister"}},{"clubId":"US-MT-LoneMountain","season":"winter","activities":["nordic"],"countryId":"US","regionId":"MT","permalink":"Lone-Mountain-Ranch","bounds":[[-111.37863370524266,45.25836887251436],[-111.286533209791,45.31096031322886]],"lastGroomed":"2026-03-17T08:00:48.000Z","weatherSources":["680907e6e3004a71b66ca476"],"name":{"en":"Lone Mountain Ranch Nordic"},"city":{"en":"Big Sky"},"region":"Montana","country":"USA","regions":["US-CCSAA"],"logo":"2025-09-03T08-17-59-711-07:00_US-MT-LoneMountain_logo_0.png","banner":"2023-03-28T13-30-12-361-06:00_US-MT-LoneMountain_Rob.jpg","lastGroomedClass":"oneDayAgo","active":true,"timezone":"America/Edmonton","liveTrack":true,"coordinates":[45.27741225960945,-111.32225109606016],"distance":73314.78747010962,"distanceGroups":[{"id":"easy","distance":27.16,"percent":37.046175142543646},{"id":"intermediate","distance":39.17,"percent":53.42212914583552},{"id":"advanced","distance":6.99,"percent":9.531695711620735}],"links":{"website":{"en":"https://lonemountainranch.com/nordic-ski-trail-passes/"},"weather":{"en":"https://www.yr.no/en/forecast/daily-table/45.278,-111.321"}},"snowDepth":5,"snowDepthUnpacked":20,"snow12h":5,"snow24h":10,"currentTemp":-12.6,"currentCond":"Cold and thin","elevation":2048,"lastTrailsUpdate":"2025-01-15T20:59:46.748Z","tempUnits":"F","timezoneUTC":"-6","reportLatest":{"updatedAt":"2026-03-18T20:23:29.912Z","clubId":"US-MT-LoneMountain","type":"grooming-report","content":{"en":"\u003Cp>After our last grooming on Monday evening we are unable to continue grooming through the rest of the season. Several roads we cross our not safe to walk, drive or take the snow cat over. We hope next winter brings better snow for our trails and fellow skiers.&nbsp;\u003C/p>"},"account":"640365631491498c2aa9479a","author":"Patrick","timestamp":"2026-03-18T20:20:12.000Z","deviceId":"FF741B1E-06B2-4512-AAA8-AC6DF5B83AA2"}},{"clubId":"US-NH-Jackson","activities":["nordic"],"countryId":"US","regionId":"NH","permalink":"Jackson-Ski-Touring-Foundation","bounds":[[-71.2683679312288,44.138495672787414],[-71.1370994995065,44.24980901348833]],"offlineMapsBounds":[[[[-71.2733826