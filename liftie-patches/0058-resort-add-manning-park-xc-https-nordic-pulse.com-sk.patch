f9758e56059e","683984d256aa6c38d9b12b20","683984d2d369ef468f3f87db"],"name":{"en":"Perisher Cross Country"},"city":{"en":"Perisher"},"description":{"en":"\u003Cp>Perisher X-Country (PXC) is an&nbsp;organized community of volunteers who love their sport and want to see others using skis to enjoy the wonders of the subalpine and alpine landscape under a blanket of snow. This enjoyment varies from taking time with friends and family to go \"bushwalking\" on skis to participating in the world's best fitness activity.\u003C/p>\n\u003Cp>All levels of skiers are supported by PXC, from those who simply want to get out there and enjoy the peace and quiet and the beautiful alpine environment, to those who want to learn to ski with increasing efficiency and grace, through to those who would like to master the sport on the world stage.\u003C/p>"},"region":"Oregon","country":"Australia","groups":[{"groupId":"InnerTrails","groupName":"Inner Trails","groupBounds":[[148.39775726537346,-36.429126932059724],[148.43522082360738,-36.400138903573556]]},{"groupId":"OuterTrails","groupOrder":1,"groupName":"Outer Trails","groupBounds":[[148.3320164071457,-36.44223631515223],[148.41129546678945,-36.405624380708964]]}],"logo":"2026-07-05T11-37-27-833-07:00_AU-NSW-MtPerisher_0.jpg","banner":"2025-07-19T09-21-29-201+10:00_AU-NSW-MtPerisher_Nordic-Andy%20.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2025-09-19T20:59:17.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2025-09-19T20:59:17.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2025-09-19T20:59:17.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2025-09-19T20:59:17.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2025-09-19T20:59:17.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2025-09-19T20:59:17.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":6394.95,"percent":16.73}],"7d":[{"id":"twoWeeksAgo","distance":6394.95,"percent":16.73}],"4d":[{"id":"twoWeeksAgo","distance":6394.95,"percent":16.73}],"36h":[{"id":"twoWeeksAgo","distance":6394.95,"percent":