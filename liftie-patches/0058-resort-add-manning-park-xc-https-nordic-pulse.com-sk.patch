85149],[-107.89872912599256,37.818592564869185],[-107.91141023182672,37.818592564869185],[-107.91141023182672,37.81615426488121],[-107.91382977190449,37.81615426488121],[-107.91382977190449,37.81563236488379],[-107.91454737458795,37.81563236488379],[-107.91454737458795,37.806361561273825]]]],"lastGroomed":"2026-03-17T15:01:27.000Z","weatherSources":["680907e6e3004a71b66ca4ce"],"name":{"en":"Trout Lake"},"city":{"en":"Telluride"},"groomedBy":{"en":"Telluride Nordic Association"},"sponsorText":{"en":"\u003Cp>Telluride&rsquo;s ONLY locally owned outdoor gear shop, your source for everything Nordic: Classic, Skate, and Backcountry.\u003C/p>"},"description":{"en":"\u003Cp>\u003Cspan>The Trout Lake Railroad Grade is distinguished by consistently receiving significantly more snow than any other Nordic trail in the region. It is always the first and last trail skiable for the season. \u003C/span>\u003C/p>\n\u003Cp>\u003Cstrong>Dogs\u003C/strong>: Dogs are welcome on the Trout Lake RR Grade provided the dog has a responsible owner! Please clean up after your pet and shorten your leash when other skiers are present.\u003C/p>\n\u003Cp>\u003Cstrong>Parking:\u003C/strong> Skiers are encouraged to access the trail from the top of Lizard Head Pass. Doing so reduces the impacts of traffic and maintenance on Trout Lake Road for Trout Lake residents. Limited parking is available at the USFS rest station at the top of the Pass. . When using the lower trailhead, please remember to observe the 10 mph speed limit on Trout Lake Road.\u003C/p>"},"region":"Colorado","country":"USA","regions":["US-CO-Telluride-Regional-Trails"],"logo":"2023-11-15T20-27-47-547-05:00_US-CO-PriestLake_logo.png","banner":"2023-11-21T10-31-44-880-08:00_US-CO-TroutLake_Rob.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-03-17T15:01:27.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-03-17T15:01:27.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-03-17T15:01:27.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-03-17T15:01:27.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-03-17T15:01:27.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-03-17T15:01:27.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":5254.86,"percent":100}],"7d":[{"id":"twoWeeksAgo","distance":5254.86,"percent":100}],"4d":[{"id":"twoWeeksAgo","distance":5254.86,"percent":100}],"36h":[{"id":"twoWeeksAgo","distance":5254.86,"percent":100}],"24h":[{"id":"twoWeeksAgo","distance":5254.86,"percent":100}],"12h":[{"id":"twoWeeksAgo","distance":5254.86,"percent":100}]},"active":true,"timezone":"America/Denver","liveTrack":true,"coordinates":[37.8164097,-107.886968],"distance":5254.857044046189,"distanceGroups":[{"id":"easy","distance":5.25,"percent":100}],"links":{"website":{"en":"https://www.telluridenordic.com/nordic-trails/#trout-lake"},"weather":{"en":"https://www.accuweather.com/en/us/ames/81426/daily-weather-forecast/2201554"}},"sponsor":true,"sponsorLogo":"2023-11-15T20-34-29-869-05:00_US-CO-PriestLake_logo.png","sponsorLink":"https://www.jagged-edge-telluride.com/","currentCond":"snowing","elevation":3088,"lastTrailsUpdate":"2025-11-27T00:18:02.547Z","tempUnits":"F","timezoneUTC":"-6","reportLatest":{"updatedAt":"2026-03-20T00:20:22.362Z","clubId":"US-CO-TroutLake","type":"grooming-report","content":{"en":"\u003Cp>\u003Cstrong>Thursday, March 19:\u003C/strong> Sadly, grooming for the season has ended. The grooming crew was hoping it would be possible to eke out one or two more days but unfortunately, the grooming cat needs a new hydraulic hose and the base will be gone in too many areas for grooming to resume once the cat is repaired (62 degrees at Lizard Head Pass 5pm today). There is still some crust sking to be found in the meadows below the RR Grade. Diehards should plan their crust ski so they are done by 11am.\u003C/p>\n\u003Cp>It may be a few weeks before the Trout cat is transported to its summer storage home. In the unlikely (according to the long range forecast) event there is significant new accumulation before the cat is moved there could be a surprise groom or two. If that happens it will be posted here and on Instagram.\u003C/p>"},"account":"654d47073adc0402f0e91c56","author":"Bill","timestamp":"2026-03-20T00:08:07.707Z"}},{"clubId":"US-WY-JacksonTetonCounty","activities":["nordic"],"countryId":"US","regionId":"WY","permalink":"Cache-Creek-Road","bounds":[[-110.7299129,43.4370684],[-110.6549278,43.4650591]],"lastGroomed":"2026-03-17T14:55:08.000Z","weatherSources":["680907e6e3004a71b66ca38a"],"name":{"en":"Cache Creek Road"},"city":{"en":"Jackson"},"groomedBy":{"en":"Teton County Parks & Recreation"},"region":"Wyoming","country":"USA","regions":["US-WY-JHNordic","US-WY-JHNordic-Jackson-Snake","US-CCSAA"],"logo":"2023-10-16T15-15-27-340-07:00_US-WY-JacksonTown_logo.png","banner":"2024-02-07T16-06-06-769-05:00_US-WY-CacheCreekSkiTrail_Finn.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-03-17T14:55:08.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-03-17T14:55:08.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-03-17T14:55:08.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-03-17T14:55:08.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-03-17T14:55:08.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-03-17T14:55:08.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":7316.73,"percent":100}],"7d":[{"id":"twoWeeksAgo","distance":7316.73,"percent":100}],"4d":[{"id":"twoWeeksAgo","distance":7316.73,"percent":100}],"36h":[{"id":"twoWeeksAgo","distance":7316.73,"percent":100}],"24h":[{"id":"twoWeeksAgo","distance":7316.73,"percent":100}],"12h":[{"id":"twoWeeksAgo","distance":7316.73,"percent":100}]},"active":true,"timezone":"America/Edmonton","liveTrack":true,"coordinates":[43.46646438818599,-110.7326580103204],"distance":"7316.73244551173","distanceGroups":[{"id":"intermediate","distance":7.32,"percent":100}],"links":{"website":{"en":"https://jhnordic.com/"},"weather":{"en":"https://www.yr.no/en/forecast/daily-table/43.465,-110.729"}},"sponsor":true