 experience one final weekend with the best coverage of the season.\u003C/p>"},"account":"655b84b755f47f4a3659a712","author":"Laurie","timestamp":"2026-03-20T23:00:00.000Z"}},{"clubId":"BC-IllecillewaetGreenbelt","season":"winter","activities":["nordic","snowshoe","hiking","fatbike"],"countryId":"CA","regionId":"BC","permalink":"Illecillewaet-Greenbelt","bounds":[[-118.21284480311108,50.96649087093081],[-118.18180468026316,50.99303541165016]],"offlineMapsBounds":[[[[-118.21855892972832,50.98024018043086],[-118.21817302991582,50.98024018043086],[-118.21817302991582,50.97894118044094],[-118.21450218047192,50.97894118044094],[-118.21450218047192,50.9766691804586],[-118.21450217665779,50.9766691804586],[-118.21450217665779,50.97664438045879],[-118.21066198525743,50.97664438045879],[-118.21066198525743,50.97661138411477],[-118.21076153771878,50.97661138411477],[-118.21076153771878,50.963381780561775],[-118.21076146266367,50.963381780561775],[-118.21076146266367,50.96289338056557],[-118.19434053160627,50.96289338056557],[-118.19434053160627,50.96369568055934],[-118.19408741055649,50.96369568055934],[-118.19408741055649,50.96383258055829],[-118.18908919980821,50.96383258055829],[-118.18908919980821,50.97412974149208],[-118.18434103418998,50.97412974149208],[-118.18434103418998,50.97447826097473],[-118.18194841683352,50.97447826097473],[-118.18194841683352,50.978202580446684],[-118.1785374090177,50.978202580446684],[-118.1785374090177,50.97944428043704],[-118.17608995714673,50.97944428043704],[-118.17608995714673,50.989424284015186],[-118.17617060579047,50.989424284015186],[-118.17617060579047,50.99040768400754],[-118.17863563769737,50.99040768400754],[-118.17863563769737,50.99085008400411],[-118.18255832085855,50.99085008400411],[-118.18255832085855,50.99095948400326],[-118.19942674752657,50.99095948400326],[-118.19942674752657,50.996632483959154],[-118.21415776182484,50.996632483959154],[-118.21415776182484,50.99662188395924],[-118.21794881569312,50.99662188395924],[-118.21794881569312,50.99239228399211],[-118.21855892972832,50.99239228399211],[-118.21855892972832,50.98024018043086]]]],"lastGroomed":"2026-03-16T21:32:35.000Z","weatherSources":["680907e5e3004a71b66ca2c6"],"name":{"en":"Illecillewaet Greenbelt Society"},"city":{"en":"Revelstoke"},"description":{"en":"\u003Cp>Since its formation in 1988 the IGS has been responsible for the protection and conservation of a 21.6 hectare parcel of land, near downtown Revelstoke, along the north shore of the Illecillewaet River extending to the west from the Fourth Street bridge.\u003C/p>\n\u003Cp>Revelstoke and surrounding areas are located on the unceded territory of the Sinixt, Ktunaxa, Secwepemc and Sylix Nations. We would like to acknowledge and honour the four nations on whose traditional land we live and play on.\u003C/p>\n\u003Cp>As a registered charity the IGS depends on membership fees, donations and sponsors to support its work, including environmental conservation, summer trail maintenance and winter track setting in the Greenbelt Area and on the Columbia River Flats.\u003C/p>"},"region":"British Columbia","country":"Canada","regions":["CA-BC-IGS"],"groups":[{"groupId":"GreenbeltTrails","groupName":"Illecillewaet Greenbelt and Columbia River Flats","groupBounds":[[-118.20878860311109,50.96649087093081],[-118.18180485489358,50.98736241165194]]},{"groupId":"Hiking / Cycling Trails","groupOrder":1,"groupName":"Hiking / Cycling Trails","groupBounds":[[-118.21284529260154,50.98240667092587],[-118.18435058026314,50.99303541165016]]}],"logo":"BC-IllecillewaetGreenbelt.png","banner":"BC-IllecillewaetGreenbelt-banner.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-03-16T21:32:35.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-03-16T21:32:35.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-03-16T21:32:35.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-03-16T21:32:35.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-03-16T21:32:35.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-03-16T21:32:35.000Z"