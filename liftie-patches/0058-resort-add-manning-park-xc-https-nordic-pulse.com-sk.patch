 and wonderful skiing make Bear Basin a great place for everyone.&nbsp;\u003C/div>\n\u003Cdiv>&nbsp;\u003C/div>\n\u003Cdiv>Cross-country ski lessons are available for every level of skier. Go to our website for trail passes and lesson bookings. Rental skies are not available at Bear Basin. Check out one of the great gear stores in McCall for rentals before you head to the trails.\u003C/div>"},"region":"Idaho","country":"USA","regions":["US-ID-McCall"],"groups":[{"groupId":"BearBasinNordic","groupName":"Nordic Trails","groupBounds":[[-116.1599013594843,44.93359067259463],[-116.13577032039336,44.95411431331717]]},{"groupId":"BearBasinBackcountry","groupOrder":1,"groupName":"Snowshoe Trails","groupBounds":[[-116.15825555469519,44.93337417259468],[-116.15041409976665,44.93995241332067]]}],"logo":"2025-01-08T10-41-55-913-07:00_US-ID-BearBasin_logo_0.png","banner":"2024-10-16T12-19-09-448-06:00_US-ID-BearBasin_Rob.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-03-18T04:30:23.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-03-18T04:30:23.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-03-18T04:30:23.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-03-18T04:30:23.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-03-18T04:30:23.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-03-18T04:30:23.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":21992.41,"percent":91.55}],"7d":[{"id":"twoWeeksAgo","distance":21992.41,"percent":91.55}],"4d":[{"id":"twoWeeksAgo","distance":21992.41,"percent":91.55}],"36h":[{"id":"twoWeeksAgo","distance":21992.41,"percent":91.55}],"24h":[{"id":"twoWeeksAgo","distance":21992.41,"percent":91.55}],"12h":[{"id":"twoWeeksAgo","distance":21992.41,"percent":91.55}]},"lastGroomedGroups":[{"id":"twoWeeksAgo","distance":2840.52,"percent":11.82}],"active":true,"timezone":"America/Edmonton","liveTrack":true,"coordinates":[44.93400208973505,-116.15326251022675],"distance":24023.336276869202,"distanceGroups":[{"id":"easy","distance":7.77,"percent":32.3