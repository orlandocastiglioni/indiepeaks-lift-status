93,41.29029504321191],[-122.20654130833759,41.29029504321191],[-122.20654130833759,41.29774624317126],[-122.20653819577358,41.29774624317126],[-122.20653819577358,41.29997854315909],[-122.20653809550772,41.29997854315909],[-122.20653809550772,41.30301284314253],[-122.20611806954037,41.30301284314253],[-122.20611806954037,41.30389214313773],[-122.20474972255556,41.30389214313773],[-122.20474972255556,41.31275234308935],[-122.20297564368344,41.31275234308935],[-122.20297564368344,41.32478064667942],[-122.20301131237795,41.32478064667942],[-122.20301131237795,41.326209546671606],[-122.21879922033797,41.326209546671606],[-122.21879922033797,41.32514324667743],[-122.23010607085178,41.32514324667743],[-122.23010607085178,41.32133100106783],[-122.23374671527696,41.32133100106783],[-122.23374671527696,41.31185927893955]]]],"lastGroomed":"2026-02-28T04:02:51.000Z","weatherSources":["680907e5e3004a71b66ca2d2"],"name":{"en":"Mt. Shasta Nordic Center"},"city":{"en":"Mount Shasta"},"region":"California","country":"United States","regions":["US-CCSAA"],"logo":"US-CA-MtShasta.png","banner":"2024-12-13T09-24-52-903-07:00_US-CA-MtShasta_Rob_0.jpg","lastGroomedClass":"tenDaysAgo","active":true,"timezone":"America/Los_Angeles","liveTrack":true,"coordinates":[41.308271,-122.211565],"distance":25101.236097420722,"distanceGroups":[{"id":"easy","distance":7.23,"percent":28.799885986792837},{"id":"intermediate","distance":9.87,"percent":39.31900458987296},{"id":"advanced","distance":8,"percent":31.8811094233342}],"links":{"website":{"en":"https://www.mtshastanordic.org/"},"weather":{"en":"https://forecast7.com/en/41d31n122d31/mount-shasta/?unit=us"}},"currentTemp":9.9,"elevation":1591,"lastTrailsUpdate":"2025-12-31T04:38:15.152Z","tempUnits":"F","timezoneUTC":"-7","reportLatest":{"updatedAt":"2026-03-12T02:30:36.919Z","clubId":"US-CA-MtShasta","type":"grooming-report","content":{"en":"\u003Cp>As the team that turns snow into trails, Dan &amp; I tend to be perpetually optimistic when it comes to our winter forecasts; simultaneously, we have no choice but to remain brutally realistic. The whacky winter that almost was is best put to rest, as spring has a warm grip that just won't let go. Time to accept what we've resisted for weeks: we're not coming back this spring... Thanks for your support &amp; we're looking forward to seeing everyone on the snow next season!\u003C/p>"},"account":"63927137fcfcc4146c64f154","author":"Sean","timestamp":"2026-03-12T02:13:47.000Z","images":["2026-03-12T10-14-08-150+08:00_US-CA-MtShasta_Sean.jpg"],"deviceId":"093DB65E-1EE6-4C91-B5D2-F29254823C1C","imagesMeta":[{"createdAt":"2026-03-12T02:30:42.316Z","updatedAt":"2026-03-12T02:30:42.316Z","name":"2026-03-12T10-14-08-150+08:00_US-CA-MtShasta_Sean.jpg","description":"Mt. Shasta Nordic Center Daily Grooming Report","alt":"Mt. Shasta Nordic Center Daily Grooming Report","clubId":"US-CA-MtShasta","caption":{"en":"","fr":"","de":""}}]}},{"clubId":"SK-HudsonBay","activities":["nordic"],"countryId":"CA","regionId":"SK","permalink":"Hudson-Bay-Ski-Club","bounds":[[-102.3642674,52.7996317],[-102.3310268,52.8168748]],"lastGroomed":"2021-01-01T00:00:00.000Z","weatherSources":["680907e5e3004a71b66ca312"],"name":{"en":"Hudson Bay Ski Club"},"city":{"en":"Hudson Bay"},"region":"Saskatchewan","country":"Canada","lastGroomedClass":"twoWeeksAgo","active":true,"timezone":"America/Regina","coordinates":[52.799891,-102.344426],"distance":"8353.992624121021","distanceGroups":[{"id":"easy","distance":8.35,"percent":100}],"links":{"website":{"en":"https://www.facebook.com/HudsonBaySkiClub/"},"weather":{"en":"https://www.theweathernetwork.com/ca/weather/saskatchewan/hudson-bay"}},"elevation":371,"tempUnits":"C","timezoneUTC":"-6","reportLatest":{"type":"grooming-report"}},{"clubId":"SK-Rocanville","activities":["nordic"],"countryId":"CA","regionId":"SK","permalink":"Rocanville","bounds":[[-101.7297721,50.3398638],[-101.7083882,50.355115]],"lastGroomed":"2021-01-01T00:00:00.000Z","weatherSources":["680907e6e3004a71b66ca332"],"name":{"en":"Rocanville X Country Ski Club"},"city":{"en":"Rocanville"},"region":"Saskatchewan","country":"Canada","lastGroomedClass":"twoWeeksAgo","active":true,"timezone":"America/Regina","coordinates":[50.352959,-101.708005],"distance":"6213.610834725153","distanceGroups":[{"id":"easy","distance":6.21,"percent":100}],"links":{"website":{"en":"https://rocanvillecrosscountrytrails.ca/"},"weather":{"en":"https://www.theweathernetwork.com/ca/weather/saskatchewan/rocanville"}},"elevation":525,"tempUnits":"C","timezoneUTC":"-6","reportLatest":{"type":"grooming-report"}},{"clubId":"US-AK-Matsu","season":"winter","activities":["nordic","snowshoe"],"countryId":"US","regionId":"AK","permalink":"Matsu","bounds":[[-149.3005085,61.6969387],[-149.2656827,61.7124296]],"lastGroomed":"2026-04-14T14:04:20.000Z","weatherSources":["680907e6e3004a71b66ca34a"],"name":{"en":"Mat-Su: GPRA"},"city":{"en":"Palmer"},"sponsorText":{"en":"\u003Cp>Eric Christensen\u003C/p>\n\u003Cp>(907 746-4950)\u003C/p>\n\u003Cp>\u003Cspan>\u003Cspan>541 S Cobb Street Ste 100\u003Cbr>Palmer, AK 99645-6319\u003C/span>\u003C/span>\u003C/p>"},"description":{"en":"\u003Cdiv data-block-id=\"block-c81aeade-c35e-4a41-bfa6-67a5d4cd2fff\">The Mat-Su Ski Club promotes Nordic skiing opportunities in the southern Mat-Su Valley for fun, community, and health.\u003C/div>\n\u003Cdiv data-block-id=\"block-ffedcccf-07f3-401b-ab86-ea4a5ec4f9d8\">\u003Cbr>The Mat-Su Ski Club is dedicated to providing exceptional Nordic skiing opportunities for residents and visitors of all ages and skill levels. We meticulously groom Nordic ski trails at the Government Peak Recreation Area (GPRA), Independence Mine, Archangel Road at Hatcher Pass, and the Matanuska Moose Range. We maintain and are responsible for expanding the world-class Nordic trail system and facilities at GPRA.\u003C/div>\n\u003Cdiv data-block-id=\"block-f43a1b22-de33-409d-a3a6-cf77f2af8465\">\u003Cbr>Our club offers a range of programs for all ages and skill levels, including educational clinics, adult ski lessons, and our cornerstone Junior Nordics program, where hundreds of kids learn to ski each winter. We organize community ski events, run a series of Nordic races, and partner with local high schools to host their competitions at the venues we maintain. We&rsquo;re proud to host high-level, FIS-sanctioned races at GPRA as well.\u003C/div>\n\u003Cdiv data-block-id=\"block-c12ca31f-a08d-4c8a-93b0-5eac69f53616\">\u003Cbr>We also offer Mat-Su Nordic&mdash;a year-round, community-focused athletic training program led by professional coaches. This program supports everyone from recreational seniors to kids aiming for elite competition. Beyond skiing, we host a variety of seasonal, family-friendly community gatherings on the trails&mdash;no skis required!\u003Cbr>\u003Cbr>\u003C/div>\n\u003Cdiv data-block-id=\"block-b1f38652-130f-457a-a3f6-9525b7d17e88\">We offer year-round healthy activities and programs to the whole community. We organize volunteers, raise funds, pursue grants, manage projects, and work closely with public and private agencies to build and maintain ski trails and facilities. \u003Cbr>We ski!\u003C/div>"},"region":"Alaska","country":"USA","regions":["US-AK-Matsu","US-CCSAA"],"logo":"2025-11-10T18-54-11-288-08:00_US-AK-Matsu_logo_0.png","banner":"US-AK-Matsu-GPRA-banner.jpg","lastGroomedClass":"twoWeeksAgo","active":true,"timezone":"America/Anchorage","liveTrack":true,"coordinates":[61.704743,-149.27814],"distance":"17126.399312932543","distanceGroups":[{"id":"easy","distance":3.68,"percent":21.46320612105284},{"id":"intermediate","distance":7.53,"percent":43.96391001554271},{"id":"advanced","distance":5.92,"percent":34.57288386340446}],"links":{"website":{"en":"https://matsuski.org/"},"weather":{"en":"https://www.wunderground.com/dashboard/pws/KAKPALME74"}},"sponsor":true,"sponsorLogo":"2022-11-27T17-51-55-714+13:00_US-AK-Matsu_logo.png","sponsorLink":"https://www.valleysf.com/?cmpid=mmkj_blm_0001","currentCond":"powder 12\" new powder","waxKick":"blue extra","waxGlide":"blue extra","elevation":310,"tempUnits":"F","timezoneUTC":"-8","reportLatest":{"updatedAt":"2026-04-14T15:54:50.298Z","clubId":"US-AK-Matsu","type":"grooming-report","content":{"en":"\u003Cp>Mat-Su Ski Club \"scarified the skate lane on all wide ski trails. Bare spots getting a bit larger, but the cold nights are helping to maintain the snow pack. Skiers need to use caution on the Lazy and below the Susitna Short Cut as the bare spots stretch completely across the ski trail. We may try to groom again early Saturday AM. Last grooming session?? (Check out the Nordic Pulse map to locate these trail segments)\u003C/p>"},"account":"632a852ccd50923a7b206401","author":"Marla","timestamp":"2026-04-14T13:53:00.000Z"}},{"clubId":"US-AK-Matsu-Moose","season":"winter","activities":["nordic"],"countryId":"US","regionId":"AK","permalink":"Matsu-Moose","bounds":[[-149.2278434,61.6717279],[-149.1008422,61.7418667]],"lastGroomed":"2026-04-07T05:26:45.000Z","weatherSources":["680907e6e3004a71b66ca34e"],"name":{"en":"Mat-Su: Moose Range"},"city":{"en":"Palmer"},"sponsorText":{"en":"\u003Cp>Eric Christensen\u003C/p>\n\u003Cp>(907 746-4950)\u003C/p>\n\u003Cp>\u003Cspan>\u003Cspan>541 S Cobb Street Ste 100\u003Cbr>Palmer, AK 99645-6319\u003C/span>\u003C/span>\u003C/p>"},"region":"Alaska","country":"USA","regions":["US-AK-Matsu","US-CCSAA"],"logo":"2025-11-10T18-54-11-288-08:00_US-AK-Matsu_logo_0.png","banner":"US-AK-Matsu-MooseRange-banner.jpg","lastGroomedClass":"twoWeeksAgo","active":true,"timezone":"America/Anchorage","liveTrack":true,"coordinates":[61.686209,-149.208903],"distance":"78875.0582370072","distanceGroups":[{"id":"easy","distance":14.68,"percent":18.608449366947767},{"id":"intermediate","distance":64.2,"percent":81.39155063305223}],"links":{"website":{"en":"https://matsuski.org/"}},"sponsor":true,"sponsorLogo":"2022-11-27T17-51-55-714+13:00_US-AK-Matsu_logo.png","sponsorLink":"https://www.valleysf.com/?cmpid=mmkj_blm_0001","snowDepth":12,"snow24h":12,"currentTemp":-3.2,"currentCond":"overcast ","elevation":236,"lastTrailsUpdate":"2023-02-01T23:55:59.195Z","tempUnits":"F","timezoneUTC":"-8","reportLatest":{"updatedAt":"2026-03-20T17:33:39.002Z","clubId":"US-AK-Matsu-Moose","type":"grooming-report","content":{"en":"\u003Cdiv>\n\u003Cdiv dir=\"auto\">We did Treestand all the way back to the swamp. We groomed Sunnyside trail even though it didn&rsquo;t really need it. We hit another quarter of the powder loops as well.\u003C/div>\n\u003C/div>\n\u003Cdiv>\n\u003Cdiv dir=\"auto\">Treestand should be fantastic tomorrow! It was a little soft and drifted in some spots so hopefully the groom will help. Some sections of ice to be careful on, but no big deal.\u003C/div>\n\u003C/div>\n\u003Cdiv>\n\u003Cdiv dir=\"auto\">Moose Range is riding awesome! I road 10 miles myself today. The swamp is blown completely off to a very hard packed trail. Loads of ice on Sunnyside too, but again, just a place to be careful.\u003Cbr>-The Rowlands\u003Cbr>\u003Cbr>Nordic Pulse did not record, but edited after the fact. Treestand is groomed back to the swamp even if not shown. Segments of trails cannot be edited.\u003Cbr>\u003Cbr>\u003C/div>\n\u003C/div>"},"account":"632a852ccd50923a7b206401","author":"Marla","timestamp":"2026-03-20T05:29:00.000Z","images":["2026-03-20T09-31-30-875-08:00_US-AK-Matsu-Moose_0.jpg"],"imagesMeta":[{"createdAt":"2026-03-20T17:33:40.896Z","updatedAt":"2026-03-20T17:33:40.896Z","name":"2026-03-20T09-31-30-875-08:00_US-AK-Matsu-Moose_0.jpg","description":"Cross Country Skiing at Mat-Su: Moose Range","alt":"Mat-Su: Moose Range","clubId":"US-AK-Matsu-Moose","caption":{"en":"","fr":"","de":""}}]}},{"clubId":"US-AK-Matsu-Archangel","season":"winter","activities":["nordic"],"countryId":"US","regionId":"AK","permalink":"Matsu-Archangel","bounds":[[-149.2403324,61.7742963],[-149.1967002,61.818878]],"lastGroomed":"2026-04-18T14:13:06.139Z","weatherSources":["68