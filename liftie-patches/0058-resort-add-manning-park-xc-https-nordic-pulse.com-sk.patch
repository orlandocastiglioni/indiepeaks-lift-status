.campaign-archive1.com/?u=38439f1838e9c88104faf8604&amp;id=3b0def19b2\" target=\"_blank\" rel=\"noopener\">.&nbsp;\u003C/a> Dogs are welcome on designated dog-friendly trails with direct and constant owner supervision and control. Look for new trail signage at the Priest Lake trailhead and along the designated route.\u003C/p>\n\u003Cp id=\"yui_3_17_2_1_1701039732626_689\">\u003Cstrong>Parking:\u003C/strong> Public Parking is available at the Priest Lake parking lot at the trailhead.\u003C/p>"},"region":"Colorado","country":"USA","regions":["US-CO-Telluride-Regional-Trails"],"logo":"2023-11-15T20-27-47-547-05:00_US-CO-PriestLake_logo.png","banner":"2024-12-31T10-42-00-576-07:00_US-CO-PriestLake_Rob_0.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-03-07T13:54:48.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-03-07T13:54:48.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-03-07T13:54:48.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-03-07T13:54:48.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-03-07T13:54:48.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-03-07T13:54:48.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":10321.16,"percent":100}],"7d":[{"id":"twoWeeksAgo","distance":10321.16,"percent":100}],"4d":[{"id":"twoWeeksAgo","distance":10321.16,"percent":100}],"36h":[{"id":"twoWeeksAgo","distance":10321.16,"percent":100}],"24h":[{"id":"twoWeeksAgo","distance":10321.16,"percent":100}],"12h":[{"id":"twoWeeksAgo","distance":10321.16,"percent":100}]},"active":true,"timezone":"America/Denver","liveTrack":true,"coordinates":[37.8395001,-107.882008],"distance":10321.159214926633,"distanceGroups":[{"id":"easy","distance":5.17,"percent":50.075803543429764},{"id":"intermediate","distance":2.65,"percent":25.647388490768},{"id":"advanced","distance":2.51,"percent":24.276807965802192}],"links":{"website":{"en":"https://www.telluridenordic.com/nordic-trails/#priest-lake"},"weather":{"en":"https://www.accuweather.com/en/us/ames/81426/daily-weather-forecast/2201554"}},"sponsor":true,"sponsorLogo":"2023-11-15T20-34-29-869-05:00_US-CO-PriestLake_logo.png","sponsorLink":"https://www.jagged-edge-telluride.com/","elevation":2903,"lastTrailsUpdate":"2025-12-17T00:13:50.512Z","tempUnits":"F","timezoneUTC":"-6","reportLatest":{"updatedAt":"2026-03-07T13:57:36.284Z","clubId":"US-CO-PriestLake","type":"grooming-report","content":{"en":"\u003Cp>Early morning snowcat grooming completed on Priest Nordic trails where possible for skate and classic. Spring melt down conditions vary from poor to very good. Beware of thin and dirt sections as hazards exist.\u003C/p>"},"account":"658c598e222c6d38f5522c8f","author":"Rollo","timestamp":"2026-03-07T13:55:53.000Z","deviceId":"56671293-C675-446E-9589-7252CCACFAE7"},"reportNotices":[{"updatedAt":"2026-07-11T15:49:56.687Z","clubId":"US-CO-PriestLake","type":"grooming-report-notice","content":{"en":"\u003Cp>\u003Cstrong>January 27: \u003C/strong>New accumulation allowed flat grooming of all Priest trails last weekend. Unfortunately, the additional snow was not enough to allow resumtion of daily grooming. The grooming crew will be shovelling snow this week to maintain and improve the base so that it might last until the next storm. Today (Tuesday) or tomorrow will likely be the last grooming activity until arrival of new snow.\u003C/p>"},"account":"654d47073adc0402f0e91c56","author":"Bill","timestamp":"2026-01-27T17:11:09.135Z"}]},{"clubId":"NS-Brunello","activities":["snowshoe","nordic"],"countryId":"CA","regionId":"CA-NS","permalink":"Brunello-XC","bounds":[[-63.73255292388585,44.6342932429766],[-63.70519581723774,44.65091984271983]],"lastGroomed":"2026-03-07T12:58:55.000Z","weatherSources":["680907e6e3004a71b66ca68e"],"name":{"en":"Brunello XC"},"city":{"en":"Timberlea"},"groomedBy":{"en":"Scotia XC Ski Club"},"description":{"en":"\u003Cp>SCOTIA XC is delighted to partner with&nbsp;\u003Ca href=\"https://www.thelinksatbrunello.com/\" target=\"_blank\" rel=\"noreferrer noopener\">The Links at Brunello\u003C/a>&nbsp;to groom their golf course trails, whenever snow conditions permit. SCOTIA XC club members are welcome to ski on the cart paths as part of their membership. Non-members can purchase a trail pass directly from&nbsp;\u003Ca href=\"https://www.thelinksatbrunello.com/activities/winter-activities\" target=\"_blank\" rel=\"noreferrer noopener\">Brunello\u003C/a>. The club-house and facilities (washrooms, food and bar service) are available when the Pro Shop is open &ndash;you must check in and introduce yourselves as Club members. If the Pro Shop is closed, you are welcome to ski with a headlamp at your own risk.\u003C/p>"},"region":"Nova Scotia","country":"Canada","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-03-07T12:58:55.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-03-07T12:58:55.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-03-07T12:58:55.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-03-07T12:58:55.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-03-07T12:58:55.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-03-07T12:58:55.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":6055.31,"percent":53.01}],"7d":[{"id":"twoWeeksAgo","distance":6055.31,"percent":53.01}],"4d":[{"id":"twoWeeksAgo","distance":6055.31,"percent":53.01}],"36h":[{"id":"twoWeeksAgo","distance":6055.31,"percent":53.01}],"24h":[{"id":"twoWeeksAgo","distance":6055.31,"percent":53.01}],"12h":[{"id":"twoWeeksAgo","distance":6055.31,"percent":53.01}]},"lastGroomedGroups":[{"id":"twoWeeksAgo","distance":1324.27,"percent":11.59}],"active":true,"timezone":"Canada/Atlantic","liveTrack":true,"coordinates":[44.6437771893736,-63.72177913356145],"distance":11423.034337067786,"distanceGroups":[{"id":"easy","distance":10.74,"percent":94.00532585566548},{"id":"expert","distance":0.68,"percent":5.994674144334546}],"links":{"website":{"en":"https://scotiaxc.ca/brunello-xc/"}},"elevation":106,"lastTrailsUpdate":"2025-02-13T01:48:59.088Z","tempUnits":"C","timezoneUTC":"-3","reportLatest":{"updatedAt":"2026-03-07T13:36:36.031Z","clubId":"NS-Brunello","type":"grooming-report","content":{"en":"\u003Cp>The Brunello range and cart paths out to holes 7 &amp; 8 were groomed on Saturday morning for skate. With the milder temperatures, the surface is a little softer and not as granular as the last couple of days. Should be very nice, especially this morning before it gets milder.\u003C/p>\n\u003Cp>Watch out for a few patches of ice on the cart paths and the steep hills are fast and firm.\u003C/p>"},"account":"692f34f9dd42915ab023c1c3","author":"Brooker","timestamp":"2026-03-07T13:02:51.000Z","images":["2026-03-07T09-03-04-192-04:00_NS-Brunello_Brooker.jpg","2026-03-07T09-03-08-485-04:00_NS-Brunello_Brooker.jpg","2026-03-07T09-34-35-922-04:00_NS-Brunello_Brooker.jpg","2026-03-07T09-34-39-851-04:00_NS-Brunello_Brooker.jpg","2026-03-07T09-36-28-317-04:00_NS-Brunello_Brooker.jpg","2026-03-07T09-36-31-927-04:00_NS-Brunello_Brooker.jpg"],"deviceId":"5D06D0B6-6636-454F-8F26-FAB858CBCBFE","imagesMeta":[{"createdAt":"2026-03-07T13:36:46.863Z","updatedAt":"2026-03-07T13:36:46.863Z","name":"2026-03-07T09-36-28-317-04:00_NS-Brunello_Brooker.jpg","description":"Brunello XC Daily Grooming Report","alt":"Brunello XC Daily Grooming Report","clubId":"NS-Brunello","caption":{"en":"","fr":"","de":""}},{"createdAt":"2026-03-07T13:36:46.013Z","updatedAt":"2026-03-07T13:36:46.013Z","name":"2026-03-07T09-36-31-927-04:00_NS-Brunello_Brooker.jpg","description":"Brunello XC Daily Grooming Report","alt":"Brunello XC Daily Grooming Report","clubId":"NS-Brunello","caption":{"en":"","fr":"","de":""}}]}},{"clubId":"AB-CookingLake","activities":["nordic"],"countryId":"CA","regionId":"AB","permalink":"Cooking-Lake-Blackfoot","bounds":[[-112.95253572429733,53.4536480701141],[-112.72879698114673,53.54217041081088]],"offlineMapsBounds":[[[[-112.95858211174912,53.48364015985897],[-112.94632584942408,53.48364015985897],[-112.94632584942408,53.479145859898075],[-112.91084122668303,53.4791458598