r":"Val-d'Or"},"description":{"en":"\u003Cp>Situ&eacute;e &agrave; quelques minutes seulement du centre-ville de Val-d&rsquo;Or, la For&ecirc;t r&eacute;cr&eacute;ative offre 50 km2 de plaisir, de d&eacute;tente et de sensations fortes! Des milliers d&rsquo;utilisateurs sillonnent ses sentiers et la fr&eacute;quent tout au long de l&rsquo;ann&eacute;e. Que ce soit pour le v&eacute;lo de montagne ou de route, la marche, le patin &agrave; roues align&eacute;es, la cueillette de petits fruits ou encore le ski de fond, le patin &agrave; glace, la raquette ou le VPS (fat bike), ce territoire est un vrai terrain de jeu pour les amateurs de plein air! Le site est muni de deux b&acirc;timents d&rsquo;accueil o&ugrave; on offre plusieurs services dont la location d&rsquo;&eacute;quipement et des collations sant&eacute;.\u003C/p>"},"region":"Quebec","country":"Canada","groups":[{"groupId":"ValDorSki","groupName":"Sentiers Ski de Fond","groupBounds":[[-77.85005337830658,48.02167877179163],[-77.7890433764777,48.06935738135499]]},{"groupId":"ValDorFatbike","groupOrder":1,"groupName":"Sentiers VPS (Fat bike)","groupBounds":[[-77.80826899957873,48.04165307178613],[-77.79447396136821,48.058460012509094]]}],"lastGroomedClass":"sevenDaysAgo","active":true,"timezone":"America/Toronto","liveTrack":true,"coordinates":[48.058029360340846,-77.79345158095865],"distance":57801.49676605082,"distanceGroups":[{"id":"easy","distance":38.04,"percent":65.81834058028888},{"id":"intermediate","distance":12.03,"percent":20.816194255629835},{"id":"advanced","distance":7.73,"percent":13.365465164081247}],"links":{"website":{"fr":"https://foretrecreative.com/"}},"elevation":340,"lastTrailsUpdate":"2025-11-13T00:44:05.788Z","tempUnits":"C","timezoneUTC":"-4","reportLatest":{"updatedAt":"2026-04-22T18:49:32.150Z","clubId":"QC-ValDor","type":"grooming-report","content":{"fr":"\u003Cp>Merci et &agrave; la saison prochaine\u003C/p>"},"account":"6757808d1a20e034dd354b15","author":"Nathalie","timestamp":"2026-04-22T18:49:16.065Z"}},{"clubId":"US-VT-U32School","activities":["nordic"],"countryId":"US","regionId":"VT","permalink":"U-32-School-Trails","bounds":[[-72.52835934040095,44.24118307276281],[-72.51804868879158,44.24759480900876]],"lastGroomed":"2026-03-05T14:31:06.000Z","weatherSources":["680907e6e3004a71b66ca626"],"name":{"en":"U32 School Trails"},"city":{"en":"Montpelier"},"description":{"en":"\u003Cp>These trails are maintained by the U-32 Nordic Team coaches for use by the school's Nordic Ski team. The school generously allows the public to use the trails when not in use for a practice or a race.\u003C/p>\n\u003Cp>\u003Cstrong>Where to Park:\u003C/strong>\u003C/p>\n\u003Cp>Please park in the U-32 parking lot away from the school, near the football field.\u003C/p>\n\u003Cp>\u003Cstrong>Guidelines for Use:\u003C/strong>\u003C/p>\n\u003Cp>Please no walkers as these trails are maintained for the ski team.\u003C/p>\n\u003Cp>Please avoid these trails if there is a ski practice or race happening.\u003C/p>\n\u003Cp>No dogs or fat bikes.\u003C/p>"},"region":"Vermont","country":"USA","regions":["US-VT-Central-Vermont"],"logo":"2024-12-12T20-04-03-148-07:00_US-VT-U32School_logo_0.png","banner":"2024-10-18T12-46-19-368-06:00_US-VT-Montpelier_Rob.jpg","lastGroomedClass":"fourDaysAgo","active":true,"timezone":"America/New_York","liveTrack":true,"coordinates":[44.2455306696951,-72.52561386596298],"distance":4121.310323505078,"distanceGroups":[{"id":"easy","distance":4.12,"percent":100}],"links":{"website":{"en":"https://onionrivernordic.org/places-to-ski/"}},"elevation":269,"lastTrailsUpdate":"2025-02-04T21:56:04.393Z","tempUnits":"F","timezoneUTC":"-4","reportLatest":{"updatedAt":"2026-03-13T12:43:36.510Z","clubId":"US-VT-U32School","type":"grooming-report","content":{"en":"\u003Cp>You are invited to a celebration of our amazing local Nordic Ski Trail Network and all the volunteers and landowners who make it possible. See the attached poster or the info below for details:\u0