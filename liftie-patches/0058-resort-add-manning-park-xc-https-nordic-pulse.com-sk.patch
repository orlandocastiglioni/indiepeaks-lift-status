55074],[-112.40049931545184,42.72772548847671],[-112.40414332277011,42.72772548847671],[-112.40414332277011,42.726877950865564],[-112.40511231994283,42.726877950865564],[-112.40511231994283,42.716675573558994]]]],"lastGroomed":"2026-02-23T02:52:17.000Z","weatherSources":["68d5f254db930019f9b60044"],"name":{"en":"East Mink Creek Nordic Center"},"city":{"en":"Pocatello"},"groomedBy":{"en":"City of Pocatello Staff & Pocatello Cross-Country Ski Foundation Volunteers"},"description":{"en":"\u003Cp>Located just 7 miles outside of Pocatello, East Mink Creek Nordic Center is a quality ski and snowshoe area. It hosts approximately 20K of groomed classic and skate trails. The nordic center is operated by the City of Pocatello through a special use permit with the United States Forest Service and through volunteer services of the&nbsp;\u003Ca href=\"https://pokyxc.org/\">\u003Cstrong>Pocatello Cross-Country Ski Foundation\u003C/strong>\u003C/a> (PXCSF).\u003C/p>"},"descriptionDirections":{"en":"\u003Ch2>Please note, Google Maps sometimes inaccurately shows that there is a closed gate restricting access to the nordic center. This gate is open in the winter.\u003C/h2>\n\u003Ch2>From Pocatello\u003C/h2>\n\u003Col>\n\u003Cli>Drive south on N Arthur Ave (one-way street), which will turn into a two-way highway (Bannock Highway)\u003C/li>\n\u003Cli>Continue 4.5 miles on Bannock Highway and turn/veer right on Mink Creek Rd\u003C/li>\n\u003Cli>After 4.8 miles, turn left on E Fork Mink Creek Rd\u003C/li>\n\u003Cli>Drive 1.6 miles and turn right on the dirt road at the East Fork Mink Creek Nordic Center sign\u003C/li>\n\u003Cli>Follow the dirt road to the parking lot\u003C/li>\n\u003C/ol>\n\u003Ch2>From I-15\u003C/h2>\n\u003Col>\n\u003Cli>Take Exit 63 (Portneuf Area)\u003C/li>\n\u003Cli>From the off-ramp, turn right\u003C/li>\n\u003Cli>Take N Fort Hall Mine Rd marked by a Landfill sign\u003C/li>\n\u003Cli>Cross the railroad tracks and turn right at the Mink Creek Recreation Area sign&nbsp;on W Portneuf Rd (going north)\u003C/li>\n\u003Cli>Drive 1.2 miles and veer left at the Mink Creek Recreation Area sign\u003C/li>\n\u003Cli>At the stop sign, turn left on Mink Creek Rd\u003C/li>\n\u003Cli>After 4.6 miles, turn left on E Fork Mink Creek Rd\u003C/li>\n\u003Cli>Drive 1.6 miles and turn right on the dirt road at the East Fork Mink Creek Nordic Center sign\u003C/li>\n\u003Cli>Follow the dirt road to the parking lot\u003C/li>\n\u003C/ol>"},"region":"Idaho","country":"USA","groups":[{"groupId":"NordicTrails","groupName":"Nordic Trails","groupBounds":[[-112.40021582602915,42.69894828591339],[-112.3696415581006,42.72822896865178]]},{"groupId":"NordicandFatbikeTrails","groupOrder":1,"groupName":"Nordic and Fatbike Trails","groupBounds":[[-112.38275070164788,42.715890358634056],[-112.37476365411581,42.73237431384356]]},{"groupId":"SnowshoeandFatbikeTrails","groupOrder":2,"groupName":"Snowshoe and Fatbike Trails","groupBounds":[[-112.38659697758847,42.706923421149746],[-112.3717967578369,42.718838333977956]]},{"groupId":"Roads","groupOrder":3,"groupName":"Roads","groupBounds":[[-112.38302491786771,42.710680673120905],[-112.36824760560911,42.734831313843]]}],"logo":"2025-09-26T14-15-25-646-07:00_US-ID-EastMinkCreek_logo_0.png","banner":"2025-09-26T14-17-19-139-07:00_US-ID-EastMinkCreek_0.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-02-23T02:52:17.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-02-23T02:52:17.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-02-23T02:52:17.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-02-23T02:52:17.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-02-23T02:52:17.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-02-23T02:52:17.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":19660.65,"percent":76.36}],"7d":[{"id":"twoWeeksAgo","distance":19660.65,"percent":76.36}],"4d":[{"id":"twoWeeksAgo","distance":19660.65,"percent":76.36}],"36h":[{"id":"twoWeeksAgo","distance":19660.65,"percent":76.36}],"24h":[{"id":"twoWeeks