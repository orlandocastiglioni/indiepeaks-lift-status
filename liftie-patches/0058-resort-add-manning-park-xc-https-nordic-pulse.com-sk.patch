90858844},{"id":"intermediate","distance":21.95,"percent":45.310029691041485},{"id":"advanced","distance":5.15,"percent":10.635035308759877},{"id":"unknown","distance":12.96,"percent":26.75936709161021}],"links":{"website":{"en":"https://rangeleylakestrailscenter.org/"},"weather":{"en":"https://www.yr.no/en/forecast/daily-table/44.957,-70.565"}},"currentCond":"Packed powder","elevation":563,"lastTrailsUpdate":"2024-01-16T19:47:41.601Z","tempUnits":"F","timezoneUTC":"-4","reportLatest":{"updatedAt":"2026-04-04T02:51:11.688Z","clubId":"US-ME-Rangeley","type":"grooming-report","content":{"en":"\u003Cp>Last day of the season will be Saturday April 4th! We received about 1/2\" of sleet on Friday, which coated the bare spots and will make for some classic Spring skiing conditions on Saturday. Wet granular surfaces are expected. \u003C/p>\n\u003Cp>The weather has been too warm to groom all week, but the base is still hanging in there. The stadium and around the yurt parking is looking quite bare, but once in the woods the trails have better coverage.&nbsp;\u003Cbr />Tote, Moose and the FIS trails will be best for skiing on Saturday. Watch for the typical spring hazards such as thin or bare spots, rocks, and ice.&nbsp;\u003Cbr />\u003Cbr />$10 day passes today!! Happy Trails!\u003C/p>\n\u003Cp>Thanks for a wonderful snow season, and hope to see you this summer hiking, biking and bird watching on our four season trail system!!\u003C/p>"},"account":"692f34e6dd42915ab023bfeb","author":"Beth","timestamp":"2026-04-04T02:34:23.000Z","deviceId":"3D91F6F5-8326-4208-A306-E7BD0F5F484F"}},{"clubId":"US-CA-AuburnSki","season":"winter","activities":["nordic"],"countryId":"US","regionId":"CA","permalink":"Auburn-Ski","bounds":[[-120.37187008812877,39.32261079300783],[-120.33197227013648,39.33474482457982]],"offlineMapsBounds":[[[[-120.3765200955747,39.32134644364149],[-120.37261755813499,39.32134644364149],[-120.37261755813499,39.321256913641946],[-120.36896028647901,39.321256913641946],