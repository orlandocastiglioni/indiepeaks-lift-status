995,43.85792743227773],[-114.63779629733995,43.86083413226051],[-114.64126661763335,43.86083413226051],[-114.64126661763335,43.86541963223335],[-114.64622012286875,43.86541963223335],[-114.64622012286875,43.87014793220534],[-114.66110474166062,43.87014793220534],[-114.66110474166062,43.85642642863091]]]],"lastGroomed":"2026-04-06T02:03:30.000Z","weatherSources":["680907e6e3004a71b66ca566"],"name":{"en":"BCRD Harriman - Prairie Creek - Durrance"},"nameS":{"en":"Harriman Prairie Creek Durance"},"city":{"en":"Blaine County"},"groomedBy":{"en":"Blaine County Recreation District"},"region":"Idaho","country":"USA","regions":["US-ID-BCRD","US-CCSAA"],"logo":"2023-02-26T11-04-00-079-05:00_US-ID-BCRDGalena_logo.png","banner":"2023-03-28T22-05-45-292-04:00_US-ID-BCRDHarriman_Finn.jpg","lastGroomedClass":"fourDaysAgo","active":true,"timezone":"America/Denver","liveTrack":true,"coordinates":[43.781089,-114.535717],"distance":65981.55257947909,"distanceGroups":[{"id":"easy","distance":52.08,"percent":78.93313748304081},{"id":"intermediate","distance":12.98,"percent":19.665624160232994},{"id":"advanced","distance":0.92,"percent":1.4012383567262148}],"links":{"website":{"en":"https://bcrd.org/wintertrailink/"},"weather":{"en":"https://forecast.weather.gov/MapClick.php?lat=43.78856938155093&lon=-114.4222640991211&site=pih&unit=0&lg=en&FcstType=text"}},"elevation":2015,"lastTrailsUpdate":"2026-02-10T16:42:25.264Z","tempUnits":"F","timezoneUTC":"-6","reportLatest":{"updatedAt":"2026-04-08T03:41:52.950Z","clubId":"US-ID-BCRDHarrimanPrairieDurrance","type":"grooming-report","content":{"en":"\u003Cp>Gladiator loops as well as senate meadow and horse creek connector, horse creek. North fork and cabin loop has all been groomed for classic and skate. If you go in the evening be careful of creek running under the run and lots of dirt and rocks showing. Enjoy!\u003C/p>"},"author":"Sidepipe","timestamp":"2026-04-08T03:39:44.000Z","deviceId":"44AEE067-1376-400A-80F6-0013B1542B9A"},"reportNotices":[{"updatedAt":"2026-07-11T15:49:56.763Z","clubId":"US-ID-BCRDHarrimanPrairieDurrance","type":"grooming-report-notice","content":{"en":"\u003Cp>\u003CspanArial',sans-serif; mso-fareast-font-family: Arial; color: black; mso-themecolor: text1;\">There is water flowing through the Harriman Trail just north of the Frostbite Trailhead, crossing the water to access the trail from the parking lot requires jumping across the steam. It is advised to park above Frostbite at Cathedral Pines or north. Grooming will continue to just above the Frostbite Trailhead as long as conditions allow. Grooming on North Fork Loop, Durrance, and the Harriman from SNRA to Frostbites Flats are done for the season. Access to North Fork Loop from the trailhead will require waders!&nbsp;\u003C/span>\u003C/p>\n\u003Cp>\u003CspanArial',sans-serif; mso-fareast-font-family: Arial; color: black; mso-themecolor: text1;\">The Billy's Bridge, Billy's/Prairie Creek access, and North Fork snowshoe trails are closed for the season. Snowshoeing in the Billy's area is possible depending on conditions, however there is no signed loop.&nbsp;\u003C/span>\u003C/p>"},"account":"65556e472cde45640d8a8ce6","author":"Ashley","timestamp":"2026-03-20T16:54:28.765Z"}]},{"clubId":"US-WY-SouthernValleySki","activities":["nordic"],"countryId":"US","regionId":"ID","permalink":"Southern-Valley-Nordic","bounds":[[-111.09187954502623,43.550743572926606],[-111.06120219024439,43.56359771365118]],"offlineMapsBounds":[[[[-111.09684305342476,43.551989830424894],[-111.07628554901638,43.551989830424894],[-111.07628554901638,43.54714613045329],[-111.05628183511223,43.54714613045329],[-111.05628183511223,43.54715403045324],[-111.05623831337194,43.54715403045324],[-111.05623831337194,43.558139634044544],[-111.05628183511223,43.558139634044544],[-111.05628183511223,43.560841534028704],[-111.06120159735741,43.560841534028704],[-111.06120159735741,43.56314983401515],[-111.067354587201,43.56314983401515],[-111.067354587201,43.563248434014575],[-111.06774943744817,43.563248434014575],[-111.06774943744817,43.563731434011736],[-111.07026133512655,43.563731434011736],[-111.07026133512655,43.56472473400591],[-111.07279798065434,43.56472473400591],[-111.07279798065434,43.56719483399143],[-111.09683983950369,43.56719483399143],[-111.09683983950369,43.56472473400591],[-111.09684305342476,43.56472473400591],[-111.09684305342476,43.551989830424894]]]],"lastGroomed":"2026-03-15T03:54:33.513Z","weatherSources":["680907e6e3004a71b66ca56a"],"name":{"en":"Southern Valley Nordic Trails"},"nameS":{"en":"Southern Valley"},"city":{"en":"Victor"},"groomedBy":{"en":"TVTAP"},"description":{"en":"\u003Cp>This trail system was recently developed to provide winter recreation opportunities for Nordic skiing, snowshoeing, and Fat biking. Per USFS policy, dogs are not allowed on the groomed trails Dec. 1 &ndash; April 15.\u003C/p>\n\u003Cp>Yeti's Loop trail is a relatively narrow forested 5 kilometer trail that is groomed wide enough for a classic and skate track. This trail starts by heading south from the parking area, along the flat in front of the pit toilet. At first fork, bear right, slightly uphill through the USFS brown gate. At next fork, stay left to ski the loop clockwise, which is a steeper climb and more gentle downhill, or counterclockwise for a more gradual climb and steeper descent. There is a cutoff in the middle of the loop that provides additional loop opportunities. Most of this trail meanders through a lovely lodgepole pine forest.\u003C/p>\n\u003Cp>Campground Loop trail starts at the bottom of the parking area and travels up the Mike Harris Campground road. About &frac14; mile in, the trail splits and you can ski the 1.5-mile loop either clockwise or counterclockwise. The lower leg of this loop is shared with the Happy Hour groomed singletrack fat bike trail.\u003C/p>\n\u003Cp>Singletrack Trails are groomed to accommodate fat bike use. You can enjoy these trails without a fat bike, but please be courteous to our grooming efforts and avoid damaging the trail surface.\u003C/p>"},"region":"Idaho","country":"USA","regions":["US-WY-JHNordic","US-CCSAA","US-WY-JHNordic-TetonValleyTrails"],"logo":"2023-04-04T21-53-25-289-07:00_US-WY-Driggs_logo.png","banner":"2024-01-23T13-27-01-870-05:00_US-WY-SouthernValleySki_Finn.jpg","lastGroomedClass":"oneDayAgo","active":true,"timezone":"America/Edmonton","liveTrack":true,"trackset":true,"tracksetType":"tracksetChecked","coordinates":[43.558384,-111.0691],"distance":6971.3633636956165,"distanceGroups":[{"id":"easy","distance":2.26,"percent":32.448025851277734},{"id":"intermediate","distance":4.71,"percent":67.55197414872227}],"links":{"website":{"en":"https://tvtap.org/grooming#southern-valley-nordic"},"weather":{"en":"https://www.yr.no/en/forecast/daily-table/43.558,-111.069"}},"sponsorLogo":"2023-04-04T21-53-25-289-07:00_US-WY-Driggs_logo.png","sponsorLink":"https://tvtap.org/trail-stickers","elevation":1984,"lastTrailsUpdate":"2026-01-14T17:17:17.303Z","tempUnits":"F","timezoneUTC":"-6","reportLatest":{"updatedAt":"2026-03-25T20:31:21.930Z","clubId":"US-WY-SouthernValleySki","type":"grooming-report","content":{"en":"\u003Cp>We hope to see you in the winter 26/27.&nbsp;\u003C/p>"},"account":"6543cbe9ec5650f1762f16b7","author":"Kevin E","timestamp":"2026-03-25T20:31:00.000Z","deviceId":"644ECA70-6191-4321-8A71-687502221959"},"reportNotices":[{"updatedAt":"2026-07-11T15:49:56.765Z","clubId":"US-WY-SouthernValleySki","type":"grooming-report-notice","content":{"en":"\u003Cp>The standard approach to Yeti's is ungroomed due to a lack of snow. An alternate approach has been established up BPA/Poweline road. Follow the track up BPA for about 300 meters, continue past the singletrack trails and trend left/South onto Yeti's.&nbsp;\u003C/p>"},"account":"6543cbe9ec5650f1762f16b7","author":"Kevin E","timestamp":"2026-03-02T18:09:09.000Z","images":["2026-03-02T11-14-12-219-07:00_US-WY-SouthernValleySki_Kevin-E.jpg","2026-03-02T11-14-21-057-07:00_US-WY-SouthernValleySki_Kevin-E.jpg"]},{"updatedAt":"2026-07-11T15:49:56.765Z","clubId":"US-WY-SouthernValleySki","type":"grooming-report-notice","content":{"en":"\u003Cp>Saturday and Sunday March 14th &amp; 15th is race day. Western Club Championships will take place on Southern Valley Nordic Trail (Yeti's). Please consider any of the other groomed trails. Mike Harris's Campground loop, Teton Canyon and Horseshoe Nordic trails. Singletrack trails are still open to fat tire bikes, snowshoe and shuffle skiing. Please be considerate if walking on trails without snowshoes and walk on the edges of any trails while supporting and spectating the event. Thank you in advance for your considerations.&nbsp;\u003C/p>"},"account":"6543cbe9ec5650f1762f16b7","author":"Kevin E","timestamp":"2026-03-11T19:43:41.791Z"}]},{"clubId":"US-AK-ChilkatPark","activities":["nordic"],"countryId":"US","regionId":"AK","permalink":"Chilkat-State-Park","bounds":[[-135.3781545,59.1373129],[-135.3607786,59.1439544]],"lastGroomed":"2024-02-07T17:54:31.000Z","weatherSources":["680907e6e3004a71b66ca572"],"name":{"en":"Chilkat State Park Road"},"city":{"en":"Haines"},"groomedBy":{"en":"Alaska State Parks and Haines Huts and Trails"},"sponsorText":{"en":"\u003Cp>\u003Cspan>\u003Cspan>The Haines Visitor Center is your gateway to exploring the beauty of Haines, Alaska! We provide comprehensive information to visitors and locals, supporting and promoting our vibrant local businesses. As the official tourism department of the Haines Borough, we are dedicated to enhancing your experience. In collaboration with Haines Huts and Trails, we support winter sports and outdoor adventures for the community and visitors alike. Discover Haines with us and make the most of your Alaskan journey!\u003C/span>\u003C/span>\u003C/p>"},"description":{"en":"\u003Cp>Skiing along the Chilkat State Park Road and Campground.&nbsp; A big downhill leads to a campground loop and coastal access.\u003C/p>"},"descriptionDirections":{"en":"\u003Cp>Drive Mud Bay Road to Chilkat State Park Road.&nbsp; Chilkat State Park Road is not currently maintained by the State or Borough but is often plowed by local volunteers.&nbsp; Depending on plowing situation, please park in a considerate spot.\u003C/p>"},"region":"Alaska","country":"USA","regions":["US-AK-Chilkat-Valley-Winter-Trails"],"logo":"2024-02-21T10-18-38-853+01:00_US-AK-Haines_logo.png","banner":"2024-02-21T10-18-52-169+01:00_US-AK-Haines_Rob.jpg","lastGroomedClass":"twoWeeksAgo","active":true,"timezone":"America/Anchorage","liveTrack":true,"trackset":true,"tracksetType":"tracksetChecked","coordinates":[59.143160722805135,-135.35830676804974],"distance":"2432.4949853755206","distanceGroups":[{"id":"advanced","distance":2.43,"percent":100}],"links":{"website":{"en":"https://haineshuts.org/"}},"sponsor":true,"sponsorLogo":"2024-06-19T10-37-47-586-06:00_US-AK-Haines_logo.png","sponsorLink":"https://www.visithaines.com/?gad_source=1&gclid=CjwKCAjwg8qzBhAoEiwAWagLrBI_WJRSigB8Z6Xu3Uxx66o24NfgOxcXY1dAGIAb8_O-KbVDXkdK8hoCUqQQAvD_BwE","elevation":114,"lastTrailsUpdate":"2024-01-26T19:36:04.144Z","tempUnits":"F","timezoneUTC":"-8"},{"clubId":"US-WA-LoupLoup","season":"winter","activities":["nordic"],"countryId":"US","regionId":"WA","permalink":"Loup-Loup-Nordic","bounds":[[-119.933411,48.3416036],[-119.8650562,48.422214]],"lastGroomed":"2021-01-01T00:00:00.000Z","weatherSources":["680907e6e3004a71b66ca586"],"name":{"en":"Loup Loup Nordic Trails"},"nameS":{"en":"Loup Loup"},"city":{"en":"Twisp"},"region":"Washington","country":"USA","regions":["US-WA-SnoParks"],"groups":[{"groupId":"LoupLoupSouth","groupName":"South Summit"},{"groupId":"LoupLoupRec","groupName":"North Summit"}],"lastGroomedClass":"twoWeeksAgo","active":true,"timezone":"America/Vancouver","liveTrack":true,"coordinates":[48.3897821,-119.8830745],"distance":"81794.57168727707","distanceGroups":[{"id":"easy","distance":14.66,"percent":17.921497258236528},{"id":"intermediate","distance":42.58,"