ilsUpdate":"2026-03-24T22:39:55.947Z","tempUnits":"C","timezoneUTC":"-4","reportLatest":{"updatedAt":"2026-05-02T01:24:53.215Z","clubId":"US-MI-STSki","type":"grooming-report","content":{"en":"\u003Cp>Hello All; It has been a great season. I just got done grooming for the evening, and tonight will be the last grooming session of the season. I dragged the skate deck once more on Valley, Cedar, Eds, Greenstone, and Mama Bear. I did do one pass on Birch, but many more bare spots have broken through on that trail so I did not do a second pass. Use caution if you ski it. As usual for this time of year; Expect Late season spring conditions and keep an eye out for bare and thin spots.&nbsp; The start of Valley and start of Mama Bear both look MUCH worse than the rest of the trails - if you walk past the bare spots, the rest of the trail is in good shape. I hope you Enjoy your ski tomorrow, and enjoy your summer. See you next winter!&nbsp;\u003C/p>"},"account":"692f3509dd42915ab023c370","author":"WoodlandSnowGroomer","timestamp":"2026-05-02T01:20:00.072Z"}},{"clubId":"US-AK-Kincaid","activities":["nordic"],"countryId":"US","regionId":"AK","permalink":"Kincaid","bounds":[[-150.07154970417014,61.14488666682711],[-150.000968813987,61.17334990753964]],"lastGroomed":"2026-05-01T14:52:02.000Z","weatherSources":["680907e5e3004a71b66ca322"],"name":{"en":"Kincaid Park"},"city":{"en":"Anchorage"},"region":"Alaska","country":"United States","regions":["US-AK-Anchorage","US-CCSAA"],"logo":"US-AK-Anchorage-logo.png","banner":"US-AK-Anchorage-banner-5.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-05-01T14:52:02.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-05-01T14:52:02.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-05-01T14:52:02.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-05-01T14:52:02.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-05-01T14:52:02.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-05-01T14:52:02.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":6