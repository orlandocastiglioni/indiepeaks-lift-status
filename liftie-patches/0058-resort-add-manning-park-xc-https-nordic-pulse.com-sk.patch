woWeeksAgo","distance":1390.22,"percent":16.75}],"7d":[{"id":"twoWeeksAgo","distance":1390.22,"percent":16.75}],"4d":[{"id":"twoWeeksAgo","distance":1390.22,"percent":16.75}],"36h":[{"id":"twoWeeksAgo","distance":1390.22,"percent":16.75}],"24h":[{"id":"twoWeeksAgo","distance":1390.22,"percent":16.75}],"12h":[{"id":"twoWeeksAgo","distance":1390.22,"percent":16.75}]},"lastGroomedGroups":[{"id":"twoWeeksAgo","distance":4890.51,"percent":58.93}],"lastGroomedGroupsTrackSet":[{"id":"twoWeeksAgo","distance":4890.51,"percent":58.93}],"active":true,"timezone":"America/Vancouver","liveTrack":true,"trackset":true,"tracksetType":"tracksetAuto","coordinates":[51.080623,-114.107383],"distance":8299.064896075804,"distanceGroups":[{"id":"easy","distance":6.29,"percent":75.74800597821336},{"id":"intermediate","distance":1.33,"percent":16.03886083490023},{"id":"advanced","distance":0.68,"percent":8.213133186886413}],"links":{"website":{"en":"https://foothillsnordic.ca/calgary-cross-country-ski-training-locations-grooming-reports/"},"weather":{"en":"https://www.theweathernetwork.com/ca/weather/alberta/calgary"}},"sponsorLogo":"AB-NordiqAlberta.png","sponsorLink":"https://nordiqalberta.ca/","snowDepth":2,"snowDepthUnpacked":4,"currentCond":"-23 C","waxKick":"Blue","elevation":1091,"lastTrailsUpdate":"2026-01-09T18:03:55.182Z","tempUnits":"C","timezoneUTC":"-7","reportLatest":{"updatedAt":"2026-03-15T15:42:58.266Z","clubId":"AB-CalgaryConfederationPark","type":"grooming-report","content":{"en":"\u003Cp>Groomed the skate lanes and set some new track on the low Snow route. Conditions are generally quite good where it was groomed. Monday will be the last day for skiing at Confederation Park with the latest warm weather coming. The snow we have will not last long as the days are longer, and the sun is strong. Thanks for a great Season and we hope you enjoyed skiing at Confederation Park. Foothills Nordic Take great pride providing great skiing in the middle of Calgary. Please don't forget to get your trail pass for the season if you haven't got a chance to do so yet! It will help Foothills ensure that we can continue grooming along into the future and keep improving the trails Year on year!\u003C/p>"},"account":"637453f356848310e76ba175","author":"Jamie","timestamp":"2026-03-15T15:40:59.000Z","deviceId":"D02E00F0-750B-4248-A6D8-9DC3EDFD5890"},"reportNotices":[{"updatedAt":"2026-07-11T15:49:56.275Z","clubId":"AB-CalgaryConfederationPark","type":"grooming-report-notice","content":{"en":"\u003Cp>Trail &amp; Driving Range Closure Notice\u003C/p>\n\u003Cp>The Chinook ❄️🌬️ (aka the snow eater) has been hard at work during the day, followed by overnight sub-zero temperatures doing their best impression of an ice rink. Unfortunately, this freeze-thaw combo has left our trails persistently icy and unsafe.\u003C/p>\n\u003Cp>As a result, the cross-country ski trails and the driving range will be closed starting Friday morning, January 16.\u003C/p>\n\u003Cp>We love enthusiasm, but Olympic-level edge control should not be a requirement to enjoy our trails.\u003C/p>\n\u003Cp>Keep doing your snow dance...we need all the help we can get!\u003C/p>\n\u003Cp>Thanks for your understanding&mdash;and for your continued support of our trails and community. ❄️⛷️\u003C/p>"},"account":"692f34fddd42915ab023c234","author":"Frank the Tank","timestamp":"2026-01-16T02:11:26.000Z","deviceId":"BE2FE0AE-707A-41A6-8060-755FA6B46CB0"},{"updatedAt":"2026-07-11T15:49:56.275Z","clubId":"AB-CalgaryConfederationPark","type":"grooming-report-notice","content":{"en":"\u003Cp>Trail Update: We are Open!\u003C/p>\n\u003Cp>The ski trails at Confederation Park are officially OPEN and skate skiing is&hellip; decent.\u003C/p>\n\u003Cp>A friendly heads-up: the descent into the driving range and the downhill from the clubhouse may inspire creative interpretations of balance and grace. Proceed with caution, confidence, and maybe a bit less speed.\u003C/p>\n\u003Cp>Unfortunately no classic tracks can be set at this time.\u003C/p>"},"account":"692f34fddd42915ab023c234","author":"Frank the Tank","timestamp":"2026-01-20T04:23:00.000Z","images":["2026-01-19T21-23-54-106-07:00_AB-CalgaryConfederationPark_Frank-the Tank.jpg","2026-01-19T21-24-07-826-07:00_AB-CalgaryConfederationPark_Frank-the Tank.jpg"],"deviceId":"BE2FE0AE-707A-41A6-8060-755FA6B46CB0"},{"updatedAt":"2026-07-11T15:49:56.275Z","clubId":"AB-CalgaryConfederationPark","type":"grooming-report-notice","content":{"en":"\u003Cp>With the weather forecasted to be very warm, our last day of skiing will be Monday March 16th.&nbsp;\u003C/p>\n\u003Cp>Thank you all for supporting our trails! &nbsp;We hope to see you all out again next season.\u003C/p>"},"account":"692f34fddd42915ab023c234","author":"Frank the Tank","timestamp":"2026-03-15T14:04:25.000Z","images":["2026-03-15T08-06-44-231-06:00_AB-CalgaryConfederationPark_Frank-the Tank.jpg"],"deviceId":"BE2FE0AE-707A-41A6-8060-755FA6B46CB0"}]},{"clubId":"US-WA-LWStatePark","season":"winter","activities":["nordic","snowshoe"],"countryId":"US","regionId":"WA","permalink":"Lake-Wenatchee-Ski-Trails","bounds":[[-120.76823679006877,47.76140447186294],[-120.65132104755925,47.82409801257343]],"offlineMapsBounds":[[[[-120.7735890210234,47.768256103793874],[-120.76971664870476,47.768256103793874],[-120.76971664870476,47.766521368076695],[-120.75520952061184,47.766521368076695],[-120.75520952061184,47.75780700386507],[-120.71176124863385,47.75780700386507],[-120.71176124863385,47.78396410368675],[-120.7104876241073,47.78396410368675],[-120.7104876241073,47.787266850337694],[-120.70872500016243,47.787266850337694],[-120.70872500016243,47.79719763515189],[-120.70761952833583,47.79719763515189],[-120.70761952833583,47.81188181631419],[-120.70971812812648,47.81188181631419],[-120.70971812812648,47.81642060712094],[-120.71354409504644,47.81642060712094],[-120.71354409504644,47.81667710711918],[-120.71382721274739,47.81667710711918],[-120.71382721274739,47.81722477254526],[-120.71392745979647,47.81722477254526],[-120.71392745979647,47.81927640745934],[-120.72073975382959,47.81927640745934],[-120.72073975382959,47.81959640744423],[-120.72123818636678,47.81959640744423],[-120.72123818636678,47.820595907092425],[-120.74191106847995,47.820595907092425],[-120.74191106847995,47.80910190351521],[-120.7396140638391,47.80910190351521],[-120.7396140638391,47.80581060646076],[-120.77172840969607,47.80581060646076],[-120.77172840969607,47.80500526323079],[-120.7735890210234,47.80500526323079],[-120.7735890210234,47.768256103793874]]],[[[-120.70477910783066,47.81359761146255],[-120.70227038613704,47.81359761146255],[-120.70227038613704,47.813347830133964],[-120.70169987360924,47.813347830133964],[-120.70169987360924,47.803455903553754],[-120.68212509948573,47.803455903553754],[-120.68212509948573,47.80112040356969],[-120.67841749554923,47.80112040356969],[-120.67841749554923,47.79643300360168],[-120.67686218009455,47.79643300360168],[-120.67686218009455,47.79243140362901],[-120.65617664560801,47.79243140362901],[-120.65617664560801,47.79276570362672],[-120.64854368911126,47.79276570362672],[-120.64854368911126,47.79376770361987],[-120.64854299811046,47.79376770361987],[-120.64854299811046,47.8081221071776],[-120.65019049852039,47.8081221071776],[-120.65019049852039,47.809982983663744],[-120.64596342872443,47.809982983663744],[-120.64596342872443,47.8226181070786],[-120.66545584178346,47.8226181070786],[-120.66545584178346,47.82258848699717],[-120.66873373224539,47.82258848699717],[-120.66873373224539,47.82259081505683],[-120.66903134062204,47.82259081505683],[-120.66903134062204,47.8243752029356],[-120.67229277108615,47.8243752029356],[-120.67229277108615,47.8254459070593],[-120.68266927365265,47.8254459070593],[-120.68266927365265,47.82769510704392],[-120.70477910783066,47.82769510704392],[-120.70477910783066,47.81359761146255]]]],"lastGroomed":"2026-03-15T15:17:03.000Z","weatherSources":["680907e6e3004a71b66ca57e"],"name":{"en":"Lake Wenatchee Area Sno Parks"},"city":{"en":"Plain"},"groomedBy":{"en":"Lake Wenatchee State Park"},"description":{"en":"\u003Cp>Click here to see our \u003Cspan>\u003Ca href=\"https://www.youtube.com/watch?v=tbDXpNsWLA4\" target=\"_blank\" rel=\"noopener\">\u003Cstrong>winter recreation video\u003C/strong>\u003C/a>.\u003C/span>\u003C/p>\n\u003Cp>Click here for\u003Cstrong> \u003C/strong>\u003Ca href=\"https://nwac.us/weatherdata/lakewenatchee/now/\" target=\"_blank\" rel=\"noopener\">\u003Cspan>\u003Cstrong>Current\u003C/strong> \u003C/span>\u003Cstrong>\u003Cspan>snow/weather conditions\u003C/span>\u003C/strong>\u003C/a>, \u003Ca href=\"https://forecast.weather.gov/MapClick.php?lon=-120.727&amp;lat=47.808\" target=\"_blank\" rel=\"noopener\">\u003Cstrong>\u003Cspan>Local Forecast\u003C/span>\u003C/strong>\u003C/a>, or buy an \u003Cstrong>\u003Ca href=\"https://epermits.parks.wa.gov/Store/SNO/SnoChoice.aspx\" target=\"_blank\" rel=\"noopener\">\u003Cspan>online parking pass/permit\u003C/span>\u003C/a>\u003C/strong>.\u003C/p>\n\u003Cp>\u003Cspan>\u003Cstrong>------- Permit Information -------\u003C/strong>\u003C/span>\u003C/p>\n\u003Cp>During the Sno-Park season, a Daily Sno-Park Pass ($25) or a Seasonal Sno-Park Pass with the Groomed Trails Sticker ($120) is required to park in all non-motorized Sno-Parks in the Lake Wenatchee Area. This pass is for the vehicle only. No additional passes are required.\u003C/p>\n\u003Cp>Self-pay stations are available in both the North and South State Park areas for day passes. A credit card machine is also located in the South Park for purchasing daily or seasonal passes.\u003C/p>\n\u003Cp>Permits can also be purchased from local vendors including Plain Hardware and KMC Winter Pro-Shop. Online permits are available at \u003Cspan>\u003Cstrong>\u003Cspan tabindex=\"0\" role=\"button\" data-url=\"https://epermits.parks.wa.gov\" aria-label=\"epermits.parks.wa.gov, this will take you to epermits.parks.wa.gov\">\u003Ca href=\"https://epermits.parks.wa.gov/Store/SNO/SnoChoice.aspx\" target=\"_blank\" rel=\"noopener\">epermits.parks.wa.gov\u003C/a>.\u003C/span>\u003C/strong>\u003C/span>\u003C/p>\n\n\n\u003Cp>\u003Cspan>\u003Cstrong>------- XC Trail Descriptions -------\u003C/strong>\u003C/span>\u003C/p>\n\u003Cp>\u003Cem>Most trails are groomed with a full skate lane and a single classic track.\u003C/em>\u003C/p>\n\u003Cp>\u003Cem>\u003Cstrong>Lake Wenatchee South Park and Kahler Glen (9.6 miles / 15.4 km)\u003C/strong>\u003C/em>\u003C/p>\n\u003Cp>The Nason Ridge Sno-Park at Kahler Glen and the South Lake Wenatchee Sno-Park offer about 15.4 km of groomed, interconnected trails. The South State Park has 9.3 km of trails with several short loops and longer routes through forest and along the lakeshore. Kahler Glen Golf Course provides 6.1 km of trails with great views, reliable snow, and access to the Nason Ridge system.\u003C/p>\n\u003Cp>\u003Cem>\u003Cstrong>Nason Ridge, Upper and Lower (12.4 miles / 20 km)\u003C/strong>\u003C/em>\u003C/p>\n\u003Cp>This 20 km groomed system begins at the Nason Ridge Sno-Park at Kahler Glen. It can also be accessed from the South Lake Wenatchee Sno-Park, which adds 2 km. Lower Nason offers 7 km of rolling groomed terrain. At the 5 km point, a challenging 13.7 km loop begins Upper Nason. Upper Nason climbs 1,500 feet to reach 5 km of open ridge-top terrain with wide views of Lake Wenatchee and the Cascade Mountains.\u003C/p>\n\u003Cp>\u003Cem>\u003Cstrong>Lake Wenatchee North Park (3.4 miles / 5.5 km)\u003C/strong> \u003C/em>\u003C/p>\n\u003Cp>The North Park area provides 5.5 km of scenic groomed trails that loop through campgrounds, follow the river and lake shores, and pass through quiet forest.\u003C/p>\n\u003Cp>\u003Cem>\u003Cstrong>Chiwawa Sno-Park (7.0 miles / 11.3 km) (Dog friendly)\u003C/strong>\u003C/em>\u003C/p>\n\u003Cp>This Sno-Park offers 11.1 km of groomed trails: the 7.6 km See and Ski Trail and the 3.5 km Squirrel Run. The two trails connect 3 km from the parking lot by crossing Chiwawa Loop Road, forming a loop. Both trails pass through beautiful forest, and See and Ski offers excellent views of the Wenatchee River. The ungroomed Flying Loop provides a challenging 10 km marked ski route.\u003C/p>\n\u003Cp>Dogs are allowed on the XC ski trails at Chiwawa Sno-Park after 10 a.m.\u003C/p>\n\n\u003Cp>\u003Cspan>\u003Cstrong>------- Local Vendo\u003C/strong>\u003C/span>\u003Cspan>\u003Cstrong>rs/Rentals -------\u003C/strong>\u003C/span>\u003C/p>\n\u003Cp>\u003Cstrong>The Camp Store\u003C/strong> located in the South Park Offering snowshoe rentals, coffee, hot chocolate, snacks, and sleds. Open Fri-Sat 10am-4pm.\u003C/p>\n\u003Cp>\u003Cstrong>Kahler Mountain Club\u003C/strong> located near Nason Ridge Sno-Park Open daily, 10a-5p. Offering Snowshoe rentals, Ski Rentals, and Sno-Park Passes.\u003C/p>\n\n\u003Cp>\u003Cspan>\u003Cstrong>------- Additional Information -------\u003C/strong>\u003C/span>\u003C/p>\n\u003Cp>\u003Cstrong>Warming Hut \u003C/strong>is a Day use only facility. No overnight stays. The hut is located at the intersection of the ski and snowshoe trails on the west saddle of Upper Nason Ridge. It is available for skiers and snowshoers to warm up and enjoy a fire in the wood stove. Firewood and fire-starting materials will be stocked once the sno-cat can reach the hut.\u003C/p>\n\u003Cp>\u003Cstrong>A Special Thank You: \u003C/strong>Our deepest thanks go to the Kahler Glen Community Association and Kahler Mountain Club for their continued partnership and support. We are also sincerely grateful to our landowner partners who make these trails possible: Chelan County&rsquo;s Nason Ridge Community Forest, the Schmitten family, the Chelan Douglas Land Trust, and the United States Forest Service. Your generosity and collaboration allow our community to enjoy this incredible winter recreation area.\u003C/p>"},"region":"Washington","country":"USA","regions":["US-WA-SnoParks"],"groups":[{"groupId":"NasonRidge","groupName":"Nason Ridge Sno-Park ","groupBounds":[[-120.76823679006877,47.76140447186294],[-120.7140802822939,47.80281095747527]]},{"groupId":"NorthSnoPark","groupOrder":1,"groupName":"North Sno-Park","groupBounds":[[-120.73655477572561,47.8079306715421],[-120.71507513071157,47.81699881257537]]},{"groupId":"SouthSnoPark","groupOrder":2,"groupName":"South Sno-Park","groupBounds":[[-120.73310007180565,47.79484083731618],[-120.71297615130959,47.809023663399564]]},{"groupId":"ChiwawaSnoPark","groupOrder":3,"groupName":"Chiwawa Sno-Park","groupBounds":[[-120.69942192869713,47.796028871853494],[-120.65132104755925,47.82409801257343]]}],"logo":"2026-01-12T07-49-55-591-08:00_US-WA-LWStatePark_0.jpg","banner":"2025-08-25T15-33-32-267-07:00_US-WA-LWStatePark_0.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-03-15T15:17:03.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-03-15T15:17:03.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-03-15T15:17:03.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-03-15T15:17:03.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-03-15T15:17:03.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-03-15T15:17:03.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":8812.69,"percent":11.41}],"7d":[{"id":"twoWeeksAgo","distance":8812.69,"percent":11.41}],"4d":[{"id":"twoWeeksAgo","distance":8812.69,"percent":11.41}],"36h":[{"id":"twoWeeksAgo","distance":8812.69,"percent":11.41}],"24h":[{"id":"twoWeeksAgo","distance":8812.69,"percent":11.41}],"12h":[{"id":"twoWeeksAgo","distance":8812.69,"percent":11.41}]},"lastGroomedGroups":[{"id":"twoWeeksAgo","distance":4564.06,"percent":5.91}],"active":true,"timezone":"America/Vancouver","liveTrack":true,"coordinates":[47.813171354848805,-120.7216541260393],"distance":77234.01745568519,"distanceGroups":[{"id":"easy","distance":29.35,"percent":38.005652744257404},{"id":"intermediate","distance":25.16,"percent":32.571984271344434},{"id":"advanced","distance":22.72,"percent":29.422362984398205}],"links":{"website":{"en":"https://parks.wa.gov/find-sno-parks/lake-wenatchee-sno-park"},"weather":{"en":"https://forecast.weather.gov/MapClick.php?lon=-120.726&lat=47.809"},"tickets":{"en":"https://epermits.parks.wa.gov/Store/SNO/SnoChoice.aspx"},"email":{"en":"lake.wenatchee@parks.wa.gov"},"phone":{"en":"509-763-3101"}},"snowDepthUnpacked":35,"snow24h":4,"snowAnnual":119,"currentTemp":1,"currentCond":"wet/soft","elevation":586,"lastTrailsUpdate":"2026-03-15T15:06:44.254Z","tempUnits":"C","timezoneUTC":"-7","reportLatest":{"updatedAt":"2026-03-15T15:00:50.060Z","clubId":"US-WA-LWStatePark","type":"grooming-report","content":{"en":"\u003Cp>Hello Skiers,\u003C/p>\n\u003Cp>Our groomers squeezed in one last fresh grooming in both the North and South Parks before they leave us for the season, and the trails are looking surprisingly sweet after that sneaky little snow dump. Signage is a limited, but the skiing is still a treat.\u003C/p>\n\u003Cp>Get out there and enjoy it while it lasts. With this week&rsquo;s warm-up on the way, the trail is going to start melting faster than a chocolate bar in your pocket.\u003C/p>"},"account":"67b1212dc04872e11a39a6fd","author":"Paul","timestamp":"2026-03-15T14:54:16.282Z"},"reportNotices":[{"updatedAt":"2026-07-11T15:49:56.773Z","clubId":"US-WA-LWStatePark","type":"grooming-report-notice","content":{"en":"\u003Cp>\u003CspanArial Narrow',sans-serif; mso-bidi-font-family: Aparajita;\">During the Sno-Park season a Daily Sno-Park Pass ($25) or a Seasonal Sno-Park Pass with the Groomed Trails Sticker ($120) is required to park in all non-motorized Sno-Parks in the Lake Wenatchee Area.&nbsp;&nbsp;&nbsp;\u003Cu>This pass is for the vehicle &ndash; no other passes are required!\u003C/u> Self-pay stations are available in the North and South State Park areas for day passes. A credit card machine is also located in the South Park, where you may purchase daily or seasonal passes.&nbsp;You may also purchase a permit through local vendors in the area to include: Midway Village, Lake Wenatchee Village, Plain Hardware, KMC Winter Pro-shop, and Der Sportsman. Permits are also available online:&nbsp;\u003Cu>\u003Cspan>epermits.parks.wa.gov\u003C/span>\u003C/u>\u003C/span>\u003C/p>"},"author":"Paul","timestamp":"2026-01-29T17:23:00.000Z"}]},{"clubId":"US-CO-Howelsen","activities":["nordic"],"countryId":"US","regionId":"CO","permalink":"Howelsen-Hill-Nordic-Center","bounds":[[-106.8452236413898,40.463486673615954],[-106.82971677383709,40.485340014338895]],"lastGroomed":"2026-03-15T13:06:36.000Z","weatherSources":["680907e6e3004a71b66ca612"],"name":{"en":"Howelsen Hill Nordic Center"},"city":{"en":"Steamboat Springs"},"description":{"en":"\u003Cp id=\"isPasted\" data-empty=\"true\">Howelsen Hill Ski Area boasts a remarkable heritage. It is Colorado&rsquo;s oldest continuously operated ski area, since 1915, and has the largest and most complete natural ski jumping complex in North America.\u003C/p>"},"region":"Colorado","country":"USA","logo":"2024-10-16T12-45-30-557-06:00_US-CO-Howelsen_logo.png","banner":"2024-10-16T12-46-14-127-06:00_US-CO-Howelsen_Rob.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-03-15T13:06:36.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-03-15T13:06:36.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-03-15T13:06:36.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-03-15T13:06:36.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-03-15T13:06:36.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-03-15T13:06:36.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":15596.4,"percent":100}],"7d":[{"id":"twoWeeksAgo","distance":15596.4,"percent":100}],"4d":[{"id":"twoWeeksAgo","distance":15596.4,"percent":100}],"36h":[{"id":"twoWeeksAgo","distance":15596.4,"percent":100}],"24h":[{"id":"twoWeeksAgo","distance":15596.4,"percent":100}],"12h":[{"id":"twoWeeksAgo","distance":15596.4,"percent":100}]},"lastGroomedGroups":[{"id":"twoWeeksAgo","distance":1920,"percent":12.31}],"active":true,"timezone":"America/Denver","liveTrack":true,"coordinates":[40.483807926966726,-106.8357672690373],"distance":15596.40466691582,"distanceGroups":[{"id":"easy","distance":1.87,"percent":11.989468927723415},{"id":"intermediate","distance":8.65,"percent":55.4811383657326},{"id":"advanced","distance":5.07,"percent":32.52939270654399}],"links":{"website":{"en":"https://steamboatsprings.net/131/Howelsen-Hill-Ski-Area"}},"elevation":2043,"lastTrailsUpdate":"2025-01-02T23:36:47.804Z","tempUnits":"F","timezoneUTC":"-6","reportLatest":{"updatedAt":"2026-03-15T13:31:18.066Z","clubId":"US-CO-Howelsen","type":"grooming-report","content":{"en":"\u003Cp>\u003Cstrong>Howelsen Hill Nordic Report 3/15/26\u003C/strong>\u003C/p>\n\u003Cp>Good morning Nordic skiers,\u003C/p>\n\u003Cp>Today will sadly be the final day of grooming for the season, as the sun has really taken a toll on our trail system. \u003Cbr />The crew came in this morning to some nice cold temps and groomed the Rodeo Loop as best as possible, laying down fresh classic track where they could. \u003Cbr />Please be cautious of icy spots and thin areas. \u003Cbr />Considering how this winter shaped up, it turned out to be a pretty solid season overall and it's been great seeing so many people out enjoying the trails. \u003Cbr />Come out to ski free Sunday while Rodeo Loop is still holding on. \u003Cbr />Bring some friends, have a parking lot cookout, then take a few laps to burn those hot dogs off. \u003Cbr />Happy trails! Thanks for the support and a great season!\u003C/p>\n\u003Cp>-Howelsen Groom Crew ⛷️☀️\u003C/p>"},"account":"66fc16cf3e729f8e6c6fe2ef","author":"Howelsen Groomer","timestamp":"2026-03-15T11:30:00.000Z","images":["2026-03-15T07-30-45-199-06:00_US-CO-Howelsen_Howelsen-Groomer.jpg"],"deviceId":"3CD33956-D9AD-497F-8D0A-68C1C17833C5","imagesMeta":[{"createdAt":"2026-03-15T13:31:20.100Z","updatedAt":"2026-03-15T13:31:20.100Z","name":"2026-03-15T07-30-45-199-06:00_US-CO-Howelsen_Howelsen-Groomer.jpg","description":"Howelsen Hill Nordic Center Daily Grooming Report","alt":"Howelsen Hill Nordic Center Daily Grooming Report","clubId":"US-CO-Howelsen","caption":{"en":"","fr":"","de":""}}]}},{"clubId":"NB-Wostawea-KUW","activities":["nordic"],"countryId":"CA","regionId":"NB","permalink":"Wostawea-Kingswood-UNB","bounds":[[-66.7126549,45.9132022],[-66.6697883,45.9405848]],"lastGroomed":"2026-03-15T11:03:05.000Z","weatherSources":["680907e6e3004a71b66ca33a"],"name":{"en":"Wostawea - Kingswood and UNB Woodlot"},"city":{"en":"Fredericton"},"region":"New Brunswick","country":"Canada","regions":["US-NB-Wostawea"],"logo":"2022-10-24T11-18-21-867+13:00_SK-Wostawea-KLP_logo.png","banner":"2022-10-22T21-28-53-025+13:00_SK-Wostawea-KUW_Seth.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-03-15T11:03:05.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-03-15T11:03:05.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-03-15T11:03:05.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-03-15T11:03:05.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-03-15T11:03:05.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-03-15T11:03:05.000Z","cl":"twoWeeksAgo"}},"lgcTr":{"14d":{"ts":"2026-03-15T11:03:05.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-03-15T11:03:05.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-03-15T11:03:05.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-03-15T11:03:05.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-03-15T11:03:05.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-03-15T11:03:05.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":18502.21,"percent":100}],"7d":[{"id":"twoWeeksAgo","distance":18502.21,"percent":100}],"4d":[{"id":"twoWeeksAgo","distance":18502.21,"percent":100}],"36h":[{"id":"twoWeeksAgo","distance":18502.21,"percent":100}],"24h":[{"id":"twoWeeksAgo","distance":18502.21,"percent":100}],"12h":[{"id":"twoWeeksAgo","distance":18502.21,"percent":100}]},"lggTr":{"14d":[{"id":"twoWeeksAgo","distance":5910.23,"percent":31.94}],"7d":[{"id":"twoWeeksAgo","distance":5910.23,"percent":31.94}],"4d":[{"id":"twoWeeksAgo","distance":5910.23,"percent":31.94}],"36h":[{"id":"twoWeeksAgo","distance":5910.23,"percent":31.94}],"24h":[{"id":"twoWeeksAgo","distance":5910.23,"percent":31.94}],"12h":[{"id":"twoWeeksAgo","distance":5910.23,"percent":31.94}]},"lastGroomedGroups":[{"id":"twoWeeksAgo","distance":18502.21,"percent":100}],"lastGroomedGroupsTrackSet":[{"id":"twoWeeksAgo","distance":18502.21,"percent":100}],"active":true,"timezone":"America/Moncton","liveTrack":true,"trackset":true,"coordinates":[45.929354,-66.711863],"distance":"18502.21229586532","distanceGroups":[{"id":"easy","distance":17.57,"percent":94.98153049473876},{"id":"intermediate","distance":0.93,"percent":5.01846950526122}],"links":{"website":{"en":"https://www.wostawea.ca/home"},"weather":{"en":"https://www.theweathernetwork.com/ca/weather/new-brunswick/fredericton"}},"elevation":110,"tempUnits":"C","timezoneUTC":"-3","reportLatest":{"updatedAt":"2026-03-15T11:32:14.052Z","clubId":"NB-Wostawea-KUW","type":"grooming-report","content":{"en":"\u003Cp>I had a horrible morning trying to roll the trails. First a four wheeler had gone all through the trails and then I kept getting stuck on the ice under the snow. It's under the snow everywhere and could cause you to fall. Then I lost my glasses. After being stuck for the 10th time I quit. Kent Road and the main loop are rolled but not great. Lollipop shows it was groomed but it wasn't.&nbsp;\u003C/p>"},"account":"692f34a1dd42915ab023b8ce","author":"bob","timestamp":"2026-03-15T11:28:17.000Z","deviceId":"C92E000A-C609-4182-B5C7-6A25596E4CCB"}},{"clubId":"US-WA-Icycle","activities":["nordic","snowshoe"],"countryId":"US","regionId":"WA","permalink":"Icicle-River-Trails","bounds":[[-120.68133980495361,47.54793107192089],[-120.66695333582074,47.55887241264553]],"lastGroomed":"2026-03-15T10:41:00.000Z","weatherSources":["680907e6e3004a71b66ca672"],"name":{"en":"Icicle River Trails"},"city":{"en":"Leavenworth"},"groomedBy":{"en":"Leavenworth Winter Sports Club"},"description":{"en":"\u003Cp>The Leavenworth Winter Sports Club maintains 26km of tracks and skating lanes that offer a variety of skiing terrain across three areas around Leavenworth. Each location offers a slightly different experience both in scenery and terrain.\u003C/p>\n\u003Cp>The&nbsp;\u003Ca href=\"https://skileavenworth.com/locations/winter-locations/icicle-river\">\u003Cspan>Icicle River Trails\u003C/span>\u003C/a> are our beginner-friendly location with excellent scenery being tucked away at the mouth of the incredible Icicle Canyon. This is the default Nordic Lesson location.\u003C/p>\n\u003Cp>Our&nbsp;\u003Ca href=\"https://skileavenworth.com/locations/winter-locations/golf-course\">\u003Cspan>Golf Course\u003C/span>\u003C/a> trail network boasts intermediate terrain tucked along the scenic Wenatchee River. Wide sweeping curves lead through open groves of huge pines while surrounded by gorgeous views of the Cascades and home to numerous deer that share the trails.\u003C/p>\n\u003Cp>\u003Cspan>\u003Ca href=\"https://skileavenworth.com/locations/winter-locations/ski-hill\">Ski Hill\u003C/a>\u003C/span> is not only home to our alpine operations but also our more advanced Nordic trail system. These trails loop through beautiful forests and end back at the historic Ski Hill Lodge - the perfect place for apr&egrave;s-ski. This location also offers five kilometers of lighted Nordic skiing until 10pm every night during winter operations.\u003C/p>\n\u003Cp>The&nbsp;\u003Ca href=\"https://skileavenworth.com/locations/winter-locations/peshastin-mill-site\">\u003Cspan>Peshastin Mill Site\u003C/span>\u003C/a> isn't groomed on as rigorous a schedule as the other locations, but we aim to get out there once a week. It offers about a 3/4 mile jaunt that is and dog friendly and not requiring of a ski ticket.\u003C/p>"},"region":"Washington","country":"USA","regions":["US-WA-LWSC"],"groups":[{"groupId":"IcicleRiverNordic","groupName":"Icicle River Trails - Nordic","groupBounds":[[-120.68133980495361,47.5479310719