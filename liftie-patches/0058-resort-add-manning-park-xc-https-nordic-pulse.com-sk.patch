-05T16-03-02-067-08:00_US-MT-LogeGlacier_logo_0.png","banner":"2026-01-05T16-01-40-575-08:00_US-MT-LogeGlacier_0.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-03-01T23:02:19.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-03-01T23:02:19.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-03-01T23:02:19.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-03-01T23:02:19.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-03-01T23:02:19.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-03-01T23:02:19.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":20079.12,"percent":84.44}],"7d":[{"id":"twoWeeksAgo","distance":20079.12,"percent":84.44}],"4d":[{"id":"twoWeeksAgo","distance":20079.12,"percent":84.44}],"36h":[{"id":"twoWeeksAgo","distance":20079.12,"percent":84.44}],"24h":[{"id":"twoWeeksAgo","distance":20079.12,"percent":84.44}],"12h":[{"id":"twoWeeksAgo","distance":20079.12,"percent":84.44}]},"active":true,"timezone":"US/Mountain","liveTrack":true,"coordinates":[48.279010475150855,-113.61185186090799],"distance":23778.65451971861,"distanceGroups":[{"id":"easy","distance":13.98,"percent":58.80379886989694},{"id":"intermediate","distance":8.22,"percent":34.58918742433651},{"id":"advanced","distance":1.57,"percent":6.607013705766585}],"links":{"website":{"en":"https://www.logecamps.com/journal/xc-ski-glacier"},"weather":{"en":"https://www.yr.no/en/forecast/daily-table/48.294,-113.612"}},"elevation":1180,"lastTrailsUpdate":"2026-01-30T17:34:56.450Z","tempUnits":"C","timezoneUTC":"-6","reportLatest":{"updatedAt":"2026-03-01T15:51:06.975Z","clubId":"US-MT-LogeGlacier","type":"grooming-report","content":{"en":"\u003Cp>❄️❄️❄️TRAILS UPDATE❄️❄️❄️\u003C/p>\n\u003Cp>March 1 ~ 8:30am\u003C/p>\n\u003Cp>It&rsquo;s quite chilly out here, 21* and the trails are frozen. We are closing today. We will be removing all signs from the trails. We will do so with the snowmobile and drag so there will be some grooming today. We are no longer selling passes, ski at your own risk.&nbsp;\u003C/p>\n\u003Cp>The staff at LOGE Glacier thank you for your patronage and kindness, your smiles and laughter, for helping make Essex and the Izaak such fantastic place to be.&nbsp;\u003C/p>\n\u003Cp>In my opinion, it&rsquo;s the community of people that play, visit, live and work here that make the Izaak such a special place. It&rsquo;s the adventures had, the magical moments shared, the memories made. Cheers to you all!\u003C/p>"},"account":"696645fbf5923b24deca4219","author":"TW","timestamp":"2026-03-01T15:50:43.000Z","deviceId":"6EA6F208-A93E-4376-A76A-E93D66C642EA"}},{"clubId":"US-VT-Memphremagogtrails","season":"winter","activities":["nordic"],"countryId":"US","regionId":"VT","permalink":"Memphremagog","bounds":[[-72.21909169295131,44.948659672590935],[-72.14630006694858,45.006249313304345]],"offlineMapsBounds":[[[[-72.22417410123084,44.94537522206048],[-72.22060106659103,44.94537522206048],[-72.22060106659103,44.9450622220624],[-72.20481369219596,44.9450622220624],[-72.20481369219596,44.94728122204876],[-72.20475534276757,44.94728122204876],[-72.20475534276757,44.94739422204807],[-72.20368922351588,44.94739422204807],[-72.20368922351588,44.9479092220449],[-72.20247438222755,44.9479092220449],[-72.20247438222755,44.94993522203244],[-72.18295075223622,44.94993522203244],[-72.18295075223622,44.952439222017055],[-72.17786401494645,44.952439222017055],[-72.17786401494645,44.95413522200663],[-72.1768046810372,44.95413522200663],[-72.1768046810372,44.95461722200365],[-72.16877553492607,44.95461722200365],[-72.16877553492607,44.95756422198553],[-72.16877548905644,44.95756422198553],[-72.16877548905644,44.95772922198452],[-72.15935633182907,44.95772922198452],[-72.15935633182907,44.95956222197323],[-72.15544558475641,44.95956222197323],[-72.15544558475641,44.96224622195673],[-72.14393456236566,44.96224622195673],[-72.14393456236566,44.96306226483849],[-72.14067780543674,44.96306226483849],[-72.14067780543674,44.972413357967696],[-72.14121585404253,44.972413357967696],[-7