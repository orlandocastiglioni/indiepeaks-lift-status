nce":21171.55,"percent":85.65}],"24h":[{"id":"twoWeeksAgo","distance":21171.55,"percent":85.65}],"12h":[{"id":"twoWeeksAgo","distance":21171.55,"percent":85.65}]},"lastGroomedGroups":[{"id":"twoWeeksAgo","distance":3512.54,"percent":14.21}],"lastGroomedGroupsTrackSet":[{"id":"twoWeeksAgo","distance":24312.07,"percent":98.36}],"active":true,"timezone":"America/Edmonton","liveTrack":true,"trackset":true,"tracksetType":"tracksetChecked","coordinates":[50.8501362,-115.4009238],"distance":24717.469761209668,"distanceGroups":[{"id":"easy","distance":8.87,"percent":35.879856731541814},{"id":"intermediate","distance":12.69,"percent":51.334687227801524},{"id":"advanced","distance":3.16,"percent":12.785456040656642}],"links":{"website":{"en":"https://www.albertaparks.ca/parks/kananaskis/kananaskis-country/advisories-public-safety/trail-reports/mount-shark/"},"weather":{"en":"https://weather.gc.ca/city/pages/ab-49_metric_e.html"}},"sponsorLogo":"AB-NordiqAlberta.png","sponsorLink":"https://nordic-pulse.com/ski-areas/CA/AB/region/Nordiq-Alberta","currentTemp":-7.1,"elevation":1783,"lastTrailsUpdate":"2026-04-22T17:54:45.443Z","tempUnits":"C","timezoneUTC":"-6","reportLatest":{"updatedAt":"2026-04-20T05:26:53.393Z","clubId":"AB-MtShark","type":"grooming-report","content":{"en":"\u003Cp>\u003Cstrong>April 18th:&nbsp;&nbsp;\u003C/strong>The condition of the Smith Dorien is no longer suitable for snowcat transportation and Mt Shark was not groomed this week;&nbsp;\u003Cstrong>grooming is now finished for the season at Mt Shark.\u003C/strong>\u003C/p>\n\u003Cp>\u003Cstrong>April 10th:&nbsp;\u003C/strong>Grooming took place at Mt.Shark on Thursday morning/evening under clear sky's with the temperature dropping into the negative single digits just after sunset.&nbsp; A double shift was completed with a lengthy break between the two shifts to allow temperatures to drop back down in the evening.&nbsp; Any snow that had fallen since last weeks grooming had melted into the base and leaving the trail surface icy and very firm which in turn made for very slow grooming condition's, because of this some trails(like Hercules) were not re-groomed.&nbsp;\u003C/p>\n\u003Cp>There is generally still a decent base at Mt Shark but sun exposed areas are thinning and there&nbsp;&nbsp;is possible exposed ground or rocks (on the two usual tight corners on Ursa Major and Hercules).\u003C/p>\n\u003Cp>Always come prepared for a variety of conditions, that can change suddenly throughout the day. You may want to consider bringing hiking poles, micro spikes, toques, gloves and multiple layers. Snowshoeing, Winter Walking and fat biking are only permitted on the multi-use Watridge Lake trail. Keep dogs on leash and pick up after your pets.\u003C/p>\n\u003Cp>\u003Cstrong>Click on the computer icon above to access the Alberta Parks report and information on individual trails\u003C/strong>\u003C/p>"},"account":"67619e54d7a3acd277dfc508","author":"Adam","timestamp":"2026-04-19T10:10:18.024Z"}},{"clubId":"AB-Bonnyville","season":"winter","activities":["nordic"],"countryId":"CA","regionId":"AB","permalink":"MDBonnyville","bounds":[[-110.6796327,54.1708146],[-110.6549943,54.1950761]],"lastGroomed":"2026-04-09T20:41:31.000Z","weatherSources":["680907e5e3004a71b66ca26a"],"name":{"en":"Muriel Lake M.D. Park"},"city":{"en":"Bonnyville"},"groomedBy":{"en":"The MD of Bonnyville, Parks and Recreation Department"},"description":{"en":"\u003Cp>Discover winter at Muriel Lake Campground!\u003C/p>\n\u003Cp>The MD of Bonnyville maintains: over 12kms of groomed cross-country ski trails, we offer both skate skiing and also classic track trails on open roads and winding back-woods routes. A public fire pit at the main viewpoint where you can warm up between loops while enjoying the fantastic lake vistas.\u003C/p>\n\u003Cp>Expect wildlife sightings (deer and moose are common). View from a distance. Please keep walking, fat biking, and pets off set tracks to preserve grooming. Pack out what you pack in; fires only in the deswignated pits. Daylight is limited so bring a headlamp and dress for changing conditions.\u003C/p>\n\u003Cp>Keep watching our social media sites and Nordic Pulse for any MD grooming updates.\u003C/p>\n\u003Cp>Now get out and enjoy the trails!!!!\u003C/p>"},"descriptionDirections":{"en":"\u003Cp>From the Town of Bonnyville head 2 miles South on Range Road 460 to Township Road 610, turn east and go 4 miles to Range Road 452, 3 miles South to the Muriel Lake campground gate.\u003C/p>"},"region":"Alberta","country":"Canada","logo":"AB-Bonnyville.png","banner":"AB-Bonnyville.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-04-09T20:41:31.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-04-09T20:41:31.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-04-09T20:41:31.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-04-09T20:41:31.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-04-09T20:41:31.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-04-09T20:41:31.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":10544.89,"percent":95.28}],"7d":[{"id":"twoWeeksAgo","distance":10544.89,"percent":95.28}],"4d":[{"id":"twoWeeksAgo","distance":10544.89,"percent":95.28}],"36h":[{"id":"twoWeeksAgo","distance":10544.89,"percent":95.28}],"24h":[{"id":"twoWeeksAgo","distance":10544.89,"percent":95.28}],"12h":[{"id":"twoWeeksAgo","distance":10544.89,"percent":95.28}]},"active":true,"timezone":"America/Edmonton","liveTrack":true,"coordinates":[54.1921729,-110.6674072],"distance":"11067.73637310905","distanceGroups":[{"id":"easy","distance":4.92,"percent":44.42922222317734},{"id":"intermediate","distance":3.08,"percent":27.832926508568},{"id":"advanced","distance":3.07,"percent":27.737851268254676}],"links":{"website":{"en":"https://www.md.bonnyville.ab.ca/258/Outdoor-Winter-Fun"},"weather":{"en":"https://weather.com/weather/today/l/54.15,-110.69?par=google"},"tickets":{"en":"Open free to the Public."}},"snowDepth":6,"currentTemp":-10.8,"currentCond":"Good","