ription":{"en":"\u003Cp>The UP Nordic Ski Complex is the home of the Ishpeming Ski Club. Our club has 5 ski jumps, including the Olympic-sized K90 \"Suicide Hill\" where our 139th annual Paul Bietila Ski Jumping tournament is hosted this January 16th-18th. UPNSC also has several cross country ski trails which are available for any and all to ski, snowshoe, and fatbike in the winter.&nbsp;\u003C/p>\n\u003Cp>All your support for our trails goes directly to support our youth programs for cross country skiing and ski jumping!&nbsp;\u003C/p>"},"region":"Michigan","country":"USA","logo":"2025-05-30T11-31-11-954-07:00_US-MI-Ishpeming_logo_0.png","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-04-07T00:14:18.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-04-07T00:14:18.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-04-07T00:14:18.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-04-07T00:14:18.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-04-07T00:14:18.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-04-07T00:14:18.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":8050.54,"percent":100}],"7d":[{"id":"twoWeeksAgo","distance":8050.54,"percent":100}],"4d":[{"id":"twoWeeksAgo","distance":8050.54,"percent":100}],"36h":[{"id":"twoWeeksAgo","distance":8050.54,"percent":100}],"24h":[{"id":"twoWeeksAgo","distance":8050.54,"percent":100}],"12h":[{"id":"twoWeeksAgo","distance":8050.54,"percent":100}]},"active":true,"timezone":"America/Chicago","liveTrack":true,"coordinates":[46.483028,-87.62813],"distance":8050.540105153333,"distanceGroups":[{"id":"easy","distance":2.33,"percent":28.96645606692989},{"id":"intermediate","distance":1.59,"percent":19.779124087123286},{"id":"advanced","distance":4.13,"percent":51.25441984594683}],"links":{"tickets":{"en":"https://ishskiclub.com/donations/"},"fb":{"en":"https://www.facebook.com/Ishskiclub/?ref=embed_page#"},"ig":{"en":"https://www.instagram.com/ishskiclub/"}},"sponsor":true,"sponsorLogo":"2025-12-03T14-52-25-671-05:00_US-MI-Ish