8491539518586,37.468494958505836],[-106.8491539518586,37.47893472795186],[-106.84978083966315,37.47893472795186],[-106.84978083966315,37.4791064665369],[-106.85010298956159,37.4791064665369],[-106.85010298956159,37.48133727055684],[-106.86550720158232,37.48133727055684],[-106.86550720158232,37.480276603525596],[-106.8670544499864,37.480276603525596],[-106.8670544499864,37.473083436174974],[-106.86861192104728,37.473083436174974],[-106.86861192104728,37.4696789405283],[-106.87169548950813,37.4696789405283],[-106.87169548950813,37.459095033729646]]]],"weatherSources":["692503e1cc50385b17f1248b"],"name":{"en":"Fall Creek"},"city":{"en":"Pagosa Springs"},"sponsorText":{"en":"\u003Cp>Pagosa Mountain Sports provides bike &amp; outdoor sales, service, guiding and rentals in beautiful downtown Pagosa Springs, Colorado. Whether it's biking, stand up paddling, backpacking, cross country skiing, sledding or just playing in the outdoors that gets you excited, we have the gear, knowledge and experience to help you enjoy it to the fullest!\u003C/p>"},"description":{"en":"\u003Cp>\u003Cem>\u003Cstrong>Fall Creek Experienced major road damage this spring due to flooding that makes it inaccesible this year.\u003C/strong>\u003C/em>\u003C/p>\n\u003Cp>Fall Creek is a forest service road in the San Juan National Forest and is groomed by the Pagosa Nordic Club for skate and classic skiing with the permission of the US Forest Service, Pagosa Ranger District. Starting at an elevation of approximately 9550 ft. about 3.5 miles of road are groomed to a top elevation of 10450 ft. This is advanced intermediate, to difficult terrain due to the high elevation and 1,000 ft of vertical gain.\u003C/p>\n\u003Cp>The Pagosa Nordic Club of Pagosa Springs, Colorado is a 501(c)(3) non profit, 100% volunteer organization with a mission &ldquo;To enhance winter recreational opportunities in Pagosa Springs by maintaining accessible groomed winter trails for skate skiing &amp; classic cross country skiing for all ability levels and to encourage and promote the use of these winter trails through education, marketing and events.\"\u003C/p>\n\u003Cp>Have any questions or suggestions for the&nbsp;Pagosa Nordic Club?&nbsp;\u003Ca href=\"https://pagosanordic.com/contact-pagosa-nordic-club/\">Let us know\u003C/a>!\u003C/p>\n\u003Cp>\u003Cstrong>Looking forward to seeing you all out on the trails!\u003C/strong>\u003C/p>"},"region":"Colorado","country":"USA","regions":["US-CO-PagosaSprings"],"logo":"2025-12-08T15-20-57-198-08:00_US-CO-WestFork_logo_0.png","banner":"2025-12-01T13-15-27-517-07:00_US-CO-FallCreek_0.jpg","lastGroomedClass":"not-groomed","active":true,"timezone":"US/Mountain","liveTrack":true,"coordinates":[37.459292,-106.860189],"distance":5439.79463634342,"distanceGroups":[{"id":"intermediate","distance":5.44,"percent":100}],"links":{"website":{"en":"https://pagosanordic.com/"},"weather":{"en":"https://www.wunderground.com/weather/us/co/pagosa-springs"}},"sponsor":true,"sponsorLogo":"2025-12-05T16-10-32-247-07:00_US-CO-CoyoteHill_logo_0.png","sponsorLink":"http://www.pagosamountainsports.com","elevation":3191,"lastTrailsUpdate":"2025-12-01T17:03:23.130Z","tempUnits":"F","timezoneUTC":"-6"},{"clubId":"US-CO-WestFork","season":"winter","activities":["nordic"],"countryId":"US","regionId":"CO","permalink":"West-Fork","bounds":[[-106.92050769196668,37.43777067423264],[-106.88316600329186,37.45880249719504]],"offlineMapsBounds":[[[[-106.92503934208253,37.452950446405204],[-106.92457622903312,37.452950446405204],[-106.92457622903312,37.444993263047934],[-106.91722330233497,37.444993263047934],[-106.91722330233497,37.440097552164744],[-106.91316562510596,37.440097552164744],[-106.91316562510596,37.43878313590531],[-106.90870115612093,37.43878313590531],[-106.90870115612093,37.438165482942324],[-106.90764475360649,37.438165482942324],[-106.90764475360649,37.437182675110066],[-106.90676370921611,37.437182675110066],[-106.90676370921611,37.43658326308902],[-106.90310278759466,37.43658326308902],[-106.90310278759466,37.4362382630907],[-106.89662300612616,37.4362382630907],[-106.89662300612616,37.43618326309096],[-106.8931143068475,37.43618326309096],[-106.8931143068475,37.43417326310078],[-106.88073516492308,37.43417326310078],[-106.88073516492308,37.43930767744214],[-106.87863481202844,37.43930767744214],[-106.87863481202844,37.44095496274154],[-106.8786348065434,37.44095496274154],[-106.8786348065434,37.45116907222639],[-106.88210068290586,37.45116907222639],[-106.88210068290586,37.45350146666206],[-106.89697211564594,37.45350146666206],[-106.89697211564594,37.45454146665699],[-106.9058950434346,37.45454146665699],[-106.9058950434346,37.461943650016956],[-106.91324756502702,37.461943650016956],[-106.91324756502702,37.462399648857485],[-106.92503934208253,37.462399648857485],[-106.92503934208253,37.452950446405204]]]],"weatherSources":["6925079dcc50385b17f128a9"],"name":{"en":"West Fork"},"city":{"en":"Pagosa Springs"},"sponsorText":{"en":"\u003Cp>Pagosa Mountain Sports provides bike &amp; outdoor sales, service, guiding and rentals in beautiful downtown Pagosa Springs, Colorado. Whether it's biking, stand up paddling, backpacking, cross country skiing, sledding or just playing in the outdoors that gets you excited, we have the gear, knowledge and experience to help you enjoy it to the fullest!\u003C/p>"},"description":{"en":"\u003Cp>West Fork is a forest service road and campground in the San Juan National Forest and is groomed by the Pagosa Nordic Club for skate and classic skiing with the permission of the US Forest Service, Pagosa Ranger District. There is a variety of easy, intermediate, and difficult terrain at West Fork both up the road, through the campground and also in a meadow on the way in. Look for the meadow turn off on your left just a short ways past the first bridge. It joins back up with the road on the far side of the meadow.\u003C/p>\n\u003Cp>\u003Cstrong>\u003Cem>West Fork sustained some damage during the spring flooding in 2025 and currently the upper section past the campground is closed due to an unsafe bridge and a road washout.\u003C/em>\u003C/strong>\u003C/p>\n\u003Cp>The road down to the venue can be variable in its conditions and we recommend 4WD if you are going to ski there. We will try to report the road conditions in our grooming reports also. Parking can be limited and is along side the road on the south side. It is best to go all the way in to the berm and turn around and park on the right as you are heading out.\u003C/p>\n\n\u003Cp>The Pagosa Nordic Club of Pagosa Springs, Colorado is a 501(c)(3) non profit, 100% volunteer organization with a mission &ldquo;To enhance winter recreational opportunities in Pagosa Springs by maintaining accessible groomed winter trails for skate skiing &amp; classic cross country skiing for all ability levels and to encourage and promote the use of these winter trails through education, marketing and events.\"\u003C/p>\n\u003Cp>Have any questions or suggestions for the&nbsp;Pagosa Nordic Club?&nbsp;\u003Ca href=\"https://pagosanordic.com/contact-pagosa-nordic-club/\">Let us know\u003C/a>!\u003C/p>\n\u003Cp>\u003Cstrong>Looking forward to seeing you all out on the trails!\u003C/strong>\u003C/p>"},"region":"Colorado","country":"USA","regions":["US-CO-PagosaSprings"],"logo":"2025-12-08T15-20-57-198-08:00_US-CO-WestFork_logo_0.png","banner":"2025-12-01T13-24-02-987-07:00_US-CO-WestFork_0.jpg","lastGroomedClass":"not-groomed","active":true,"timezone":"US/Mountain","liveTrack":true,"coordinates":[37.445479,-106.901921],"distance":10878.104275014872,"distanceGroups":[{"id":"easy","distance":6.29,"percent":57.825848313722574},{"id":"advanced","distance":4.59,"percent":42.17415168627745}],"links":{"website":{"en":"https://pagosanordic.com/"},"weather":{"en":"https://www.wunderground.com/weather/us/co/pagosa-springs"}},"sponsor":true,"sponsorLogo":"2025-12-05T16-10-32-247-07:00_US-CO-CoyoteHill_logo_0.png","sponsorLink":"http://www.pagosamountainsports.com","elevation":2401,"lastTrailsUpdate":"2025-12-03T00:35:35.980Z","tempUnits":"F","timezoneUTC":"-6"},{"clubId":"US-CO-GrandLakeNordicCenter","season":"winter","activities":["nordic","snowshoe"],"countryId":"US","regionId":"CO","permalink":"Grand-Lake-Nordic-Center","bounds":[[-105.87280416759567,40.23726644315026],[-105.84795439978807,40.2577971702982]],"offlineMapsBounds":[[[[-105.87751703329292,40.24339922832204],[-105.87279729917672,40.24339922832204],[-105.87279729917672,40.243246577437354],[-105.87277777116574,40.243246577437354],[-105.87277777116574,40.238209441186996],[-105.87013108163073,40.238209441186996],[-105.87013108163073,40.234813471260516],[-105.86872212308296,40.234813471260516],[-105.86872212308296,40.2336690183707],[-105.85445273470941,40.2336690183707],[-105.85445273470941,40.2346421588793],[-105.84503159832728,40.2346421588793],[-105.84503159832728,40.234890028877984],[-105.84486043795961,40.234890028877984],[-105.84486043795961,40.24457981482675],[-105.84324074253273,40.24457981482675],[-105.84324074253273,40.25659810961969],[-105.85067333537431,40.25659810961969],[-105.85067333537431,40.25710596118118],[-105.85174892811592,40.25710596118118],[-105.85174892811592,40.26131176671689],[-105.85548293825966,40.26131176671689],[-105.85548293825966,40.26136540179946],[-105.85634456671103,40.26136540179946],[-105.85634456671103,40.261394308304524],[-105.87280582093439,40.261394308304524],[-105.87280582093439,40.25403915689671],[-105.87751703329292,40.25403915689671],[-105.87751703329292,40.24339922832204]]]],"lastGroomed":"2026-03-15T16:10:27.000Z","weatherSources":["692fb79ed7978bf78c4a1939"],"name":{"en":"Grand Lake Nordic Center"},"city":{"en":"Grand Lake"},"description":{"en":"\u003Cp>Enjoy the scenic views of Rocky Mountain National Park and the Arapaho National Forest at the Grand Lake Nordic Center. We offer the beginner to advanced skier a variety of terrain on 35 km of classic and skate skiing trails.\u003C/p>\n\u003Cp>View of t