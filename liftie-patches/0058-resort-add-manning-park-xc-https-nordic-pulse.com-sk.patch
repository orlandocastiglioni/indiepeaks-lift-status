en the main trails.&nbsp; Ski grooming at Saux Head is performed by volunteers, so please check the NTN trail report for the latest information.\u003C/p>"},"descriptionDirections":{"en":"\u003Cp>&nbsp;&nbsp;\u003C/p>"},"region":"Michigan","country":"USA","regions":["US-MI-Noquemanon-Trails"],"logo":"2025-02-13T12-36-30-065-08:00_US-MI-SouthTrails_logo_0.png","banner":"2025-01-07T16-41-09-329-07:00_US-MI-Saux_Rob_0.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-04-04T15:31:24.063Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-04-04T15:31:24.063Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-04-04T15:31:24.063Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-04-04T15:31:24.063Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-04-04T15:31:24.063Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-04-04T15:31:24.063Z","cl":"twoWeeksAgo"}},"lgcTr":{"14d":{"ts":"2026-04-04T15:31:24.063Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-04-04T15:31:24.063Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-04-04T15:31:24.063Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-04-04T15:31:24.063Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-04-04T15:31:24.063Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-04-04T15:31:24.063Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":7447.43,"percent":72.23}],"7d":[{"id":"twoWeeksAgo","distance":7447.43,"percent":72.23}],"4d":[{"id":"twoWeeksAgo","distance":7447.43,"percent":72.23}],"36h":[{"id":"twoWeeksAgo","distance":7447.43,"percent":72.23}],"24h":[{"id":"twoWeeksAgo","distance":7447.43,"percent":72.23}],"12h":[{"id":"twoWeeksAgo","distance":7447.43,"percent":72.23}]},"lggTr":{"14d":[{"id":"twoWeeksAgo","distance":7447.43,"percent":72.23}],"7d":[{"id":"twoWeeksAgo","distance":7447.43,"percent":72.23}],"4d":[{"id":"twoWeeksAgo","distance":7447.43,"percent":72.23}],"36h":[{"id":"twoWeeksAgo","distance":7447.43,"percent":72.23}],"24h":[{"id":"twoWeeksAgo","distance":7447.43,"percent":72.23}],"12h":[{"id":"twoWeeksAgo","distance":7447.43,"percent":72.23}]},"lastGroomedGroups":[{"id":"twoWeeksAgo"