e end of March.&nbsp;\u003C/p>"},"account":"692f34f4dd42915ab023c154","author":"GroomerRob","timestamp":"2026-03-13T23:22:41.000Z","deviceId":"214E9AB1-D9F1-4C61-98FB-1F0381FF2E88"}},{"clubId":"SK-Melfort-Golf","activities":["nordic"],"countryId":"CA","regionId":"SK","permalink":"Melfort-Golf","bounds":[[-104.6021551,52.8500042],[-104.5935291,52.8553297]],"lastGroomed":"2025-03-15T00:05:24.871Z","weatherSources":["680907e6e3004a71b66ca40e"],"name":{"en":"Melfort Golf Course"},"city":{"en":"Melfort"},"region":"Saskatchewan","country":"Canada","regions":["SK-Melfort"],"logo":"2023-09-06T15-35-40-132-07:00_SK-Melfort_logo.png","banner":"2023-09-06T15-34-30-869-07:00_SK-Melfort-Golf_Rob.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2025-03-15T00:05:24.871Z","cl":"twoWeeksAgo"},"7d":{"ts":"2025-03-15T00:05:24.871Z","cl":"twoWeeksAgo"},"4d":{"ts":"2025-03-15T00:05:24.871Z","cl":"twoWeeksAgo"},"36h":{"ts":"2025-03-15T00:05:24.871Z","cl":"twoWeeksAgo"},"24h":{"ts":"2025-03-15T00:05:24.871Z","cl":"twoWeeksAgo"},"12h":{"ts":"2025-03-15T00:05:24.871Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":3986.73,"percent":100}],"7d":[{"id":"twoWeeksAgo","distance":3986.73,"percent":100}],"4d":[{"id":"twoWeeksAgo","distance":3986.73,"percent":100}],"36h":[{"id":"twoWeeksAgo","distance":3986.73,"percent":100}],"24h":[{"id":"twoWeeksAgo","distance":3986.73,"percent":100}],"12h":[{"id":"twoWeeksAgo","distance":3986.73,"percent":100}]},"lastGroomedGroups":[{"id":"twoWeeksAgo","distance":3986.73,"percent":100}],"active":true,"timezone":"America/Regina","liveTrack":true,"coordinates":[52.85323595,-104.59849115],"distance":"3986.7277708444276","distanceGroups":[{"id":"easy","distance":3.99,"percent":100}],"links":{"website":{"en":"https://www.facebook.com/people/Melfort-Jackrabbits-Cross-Country-Ski-Club/100083515752052/"},"weather":{"en":"https://www.theweathernetwork.com/ca/weather/saskatchewan/melfort"}},"elevation":458,"tempUnits":"C","timezoneUTC":"-6","re