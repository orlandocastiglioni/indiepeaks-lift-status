,[-107.0469746257522,37.30267990855974],[-107.05042706140678,37.30267990855974],[-107.05042706140678,37.30269146739756],[-107.05393122927748,37.30269146739756],[-107.05393122927748,37.30271946739742],[-107.05460431561106,37.30271946739742],[-107.05460431561106,37.30293402151504],[-107.05471693725325,37.30293402151504],[-107.05471693725325,37.30434308216379],[-107.05523998665022,37.30434308216379],[-107.05523998665022,37.30441864650041],[-107.06719936680803,37.30441864650041],[-107.06719936680803,37.30407646739083],[-107.06857229542707,37.30407646739083],[-107.06857229542707,37.30312646739545],[-107.07006399866856,37.30312646739545],[-107.07006399866856,37.290183263802724]]]],"lastGroomed":"2026-02-23T01:00:00.000Z","weatherSources":["6925158dcc50385b17f13d3e"],"name":{"en":"Cloman"},"city":{"en":"Pagosa Springs"},"sponsorText":{"en":"\u003Cp>Pagosa Mountain Sports provides bike &amp; outdoor sales, service, guiding and rentals in beautiful downtown Pagosa Springs, Colorado. Whether it's biking, stand up paddling, backpacking, cross country skiing, sledding or just playing in the outdoors that gets you excited, we have the gear, knowledge and experience to help you enjoy it to the fullest!\u003C/p>"},"description":{"en":"\u003Cp>The Cloman XC ski venue is an Archuleta County park and is groomed by the Pagosa Nordic Club for skate and classic skiing. \u003Cstrong>\u003Cem>There is a variety of easy and intermediate terrain within the park that also allows dogs and there is an adjoining intermediate area (The Airport Loop) that is on private property through the east gate that is a no dog area\u003C/em>\u003C/strong>. Please respect the owner&rsquo;s restrictions on dogs as they graciously allow us to groom and use their property.\u003C/p>\n\u003Cp>Snowshoeing and walking are allowed within the park but not on the private Airport Loop property. We ask that you please respect the groom and try to avoid walking on it, as it icreates a hazard for the skiers. If you must walk on it, please stay to the far edge opposite of the set track and walk in single file if with a group.\u003C/p>\n\u003Cp>The Pagosa Nordic Club of Pagosa Springs, Colorado is a 501(c)(3) non profit, 100% volunteer organization with a mission &ldquo;To enhance winter recreational opportunities in Pagosa Springs by maintaining accessible groomed winter trails for skate skiing &amp; classic cross country skiing for all ability levels and to encourage and promote the use of these winter trails through education, marketing and events.\"\u003C/p>\n\u003Cp>Have any questions or suggestions for the&nbsp;Pagosa Nordic Club?&nbsp;\u003Ca href=\"https://pagosanordic.com/contact-pagosa-nordic-club/\">Let us know\u003C/a>!\u003C/p>\n\u003Cp>\u003Cstrong>Looking forward to seeing you all out on the trails!\u003C/strong>\u003C/p>"},"region":"Colorado","country":"USA","regions":["US-CO-PagosaSprings"],"logo":"2025-12-08T15-20-57-198-08:00_US-CO-WestFork_logo_0.png","banner":"2025-12-01T12-41-50-847-07:00_US-CO-Cloman_0.jpg","lastGroomedClass":"twoWeeksAgo","lgc":{"14d":{"ts":"2026-02-23T01:00:00.000Z","cl":"twoWeeksAgo"},"7d":{"ts":"2026-02-23T01:00:00.000Z","cl":"twoWeeksAgo"},"4d":{"ts":"2026-02-23T01:00:00.000Z","cl":"twoWeeksAgo"},"36h":{"ts":"2026-02-23T01:00:00.000Z","cl":"twoWeeksAgo"},"24h":{"ts":"2026-02-23T01:00:00.000Z","cl":"twoWeeksAgo"},"12h":{"ts":"2026-02-23T01:00:00.000Z","cl":"twoWeeksAgo"}},"lgg":{"14d":[{"id":"twoWeeksAgo","distance":7742.49,"percent":96.61}],"7d":[{"id":"twoWeeksAgo","distance":7742.49,"percent":96.61}],"4d":[{"id":"twoWeeksAgo","distance":7742.49,"percent":96.61}],"36h":[{"id":"twoWeeksAgo","distance":7742.49,"percent":96.61}],"24h":[{"id":"twoWeeksAgo","distance":7742.49,"percent":96.61}],"12h":[{"id":"twoWeeksAgo","distance":7742.49,"percent":96.61}]},"lastGroomedGroups":[{"id":"twoWeeksAgo","distance":7742.49,"percent":96.61}],"active":true,"timezone":"US/Mountain","liveTrack":true,"trackset":true,"tracksetType":"tracksetChecked","coordi