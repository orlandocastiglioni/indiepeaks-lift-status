, bikers, and dogs remain off the trails \u003Cspan dir=\"ltr\">until March 30th.\u003C/span>\u003C/strong>\u003C/p>"},"account":"692f34d0dd42915ab023bd85","author":"Chris","timestamp":"2026-03-27T14:04:55.000Z","images":["2026-03-27T08-07-46-631-06:00_BC-KimberleyNordic_Chris.jpg"],"deviceId":"B29486BE-4853-426A-ACE0-D7180C42353A","imagesMeta":[{"createdAt":"2026-03-27T14:08:12.342Z","updatedAt":"2026-03-29T17:44:08.514Z","name":"2026-03-27T08-07-46-631-06:00_BC-KimberleyNordic_Chris.jpg","description":"Kimberley Nordic Ski Club Daily Grooming Report","alt":"Kimberley Nordic Ski Club Daily Grooming Report","clubId":"BC-KimberleyNordic","caption":{"en":"","fr":"","de":""}}]}},{"clubId":"US-NH-GreatGlen","season":"winter","activities":["nordic","snowshoe"],"countryId":"US","regionId":"NH","permalink":"Great-Glen-Trails","bounds":[[-71.282484900072,44.277876872754],[-71.2100346469501,44.30372701347537]],"offlineMapsBounds":[[[[-71.28751009373451,44.28529802607232],[-71.27945799154251,44.28529802607232],[-71.27945799154251,44.285277526072456],[-71.27935763027058,44.285277526072456],[-71.27935763027058,44.282833926087136],[-71.27298882344948,44.282833926087136],[-71.27298882344948,44.282770126087506],[-71.27294218805716,44.282770126087506],[-71.27294218805716,44.27869732611199],[-71.2672316158769,44.27869732611199],[-71.2672316158769,44.27427942613853],[-71.2232780012645,44.27427942613853],[-71.2232780012645,44.27936402610797],[-71.22289505002534,44.27936402610797],[-71.22289505002534,44.28181392609326],[-71.21913126809568,44.28181392609326],[-71.21913126809568,44.28203692609192],[-71.21434083036145,44.28203692609192],[-71.21434083036145,44.28449462607716],[-71.20943303518511,44.28449462607716],[-71.20943303518511,44.28487502607486],[-71.20500898295766,44.28487502607486],[-71.20500898295766,44.28587252606887],[-71.20500857879745,44.28587252606887],[-71.20500857879745,44.29864322964782],[-71.21018489549,44.29864322964782],[-71.21018489549,44.304093829615056],[-71.2156453