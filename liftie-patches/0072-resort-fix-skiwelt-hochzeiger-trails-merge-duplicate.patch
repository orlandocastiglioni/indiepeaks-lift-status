From 88e327932e0732b76ca069dd0a309d448b1188c4 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Fri, 17 Jul 2026 13:05:39 +0000
Subject: [PATCH 72/77] resort: fix skiwelt/hochzeiger trails - merge duplicate
 piste segments

The micadoweb facility API lists multi-segment pistes once per segment
(Kaiserexpress x3, Filzboden Abfahrt x3, ...), inflating SkiWelt's trail
list to 100 rows for 83 unique pistes. Merge rows by title - open wins,
first level kept. Same parser shared by hochzeiger.
---
 lib/resorts/hochzeiger/trails.js |  25 +-
 lib/resorts/skiwelt/trails.js    |  25 +-
 test/resorts/skiwelt-trails.js   | 591 +++++--------------------------
 3 files changed, 121 insertions(+), 520 deletions(-)

diff --git a/lib/resorts/hochzeiger/trails.js b/lib/resorts/hochzeiger/trails.js
index b99a2907..b09b2714 100644
--- a/lib/resorts/hochzeiger/trails.js
+++ b/lib/resorts/hochzeiger/trails.js
@@ -7,11 +7,22 @@ const levels = {
 
 export default function parse(data = {}) {
   const { items = [] } = data;
-  return items
-    .filter(item => item.state) // off season the report carries no state
-    .map(({ title, state, facilityTypeIdentifier }) => ({
-      name: title,
-      status: state,
-      level: levels[facilityTypeIdentifier]
-    }));
+  // multi-segment pistes repeat under one title (Kaiserexpress x3) - merge
+  // by title, open wins, first level kept
+  const byTitle = new Map();
+  for (const { title, state, facilityTypeIdentifier } of items) {
+    if (!state) {
+      continue; // off season the report carries no state
+    }
+    const prev = byTitle.get(title);
+    if (!prev) {
+      byTitle.set(title, { name: title, status: state, level: levels[facilityTypeIdentifier] });
+    } else {
+      if (state === 'open') {
+        prev.status = 'open';
+      }
+      prev.level ??= levels[facilityTypeIdentifier];
+    }
+  }
+  return [...byTitle.values()];
 }
