From 8062cd3a5cccbfd1edc7f14bbdc0e2fea281bc08 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Fri, 17 Jul 2026 13:04:16 +0000
Subject: [PATCH 69/77] resort: fix togakushi - novice level unmapped,
 difficulty suffix left in names
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

とがっきーC（初心者） carried no level because only 初級 was recognized -
map 初心 to green too. Difficulty parentheticals (（初級者） etc.) now map
to the level and are dropped from display names; informative ones like
（ポール専用） are kept.
---
 lib/resorts/togakushi/trails.js  |  18 +++--
 test/resorts/togakushi-trails.js | 116 ++++++-------------------------
 2 files changed, 32 insertions(+), 102 deletions(-)

diff --git a/lib/resorts/togakushi/trails.js b/lib/resorts/togakushi/trails.js
index 582a80cc..a35ac754 100644
--- a/lib/resorts/togakushi/trails.js
+++ b/lib/resorts/togakushi/trails.js
@@ -1,13 +1,19 @@
 import sections from './sections.js';
 
-const courseLevels = { 初級: 'green', 中級: 'blue', 上級: 'black' };
+const courseLevels = { 初級: 'green', 初心: 'green', 中級: 'blue', 上級: 'black' };
 
 export default function parse(dom) {
   return sections(dom)
     .filter(r => r.section !== 'リフト情報')
-    .map(({ section, name, status }) => ({
-      name,
-      status,
-      level: section === 'パーク情報' ? 'terrainPark' : courseLevels[name.match(/（(初級|中級|上級)/)?.[1]]
-    }));
+    .map(({ section, name, status }) => {
+      // difficulty rides in the course name - "お仙水コース（初級者）";
+      // map it to the level and drop it from the display name (other
+      // parentheticals like （ポール専用） are kept)
+      const m = name.match(/（(初級|初心|中級|上級)者?）/);
+      return {
+        name: m ? name.replace(m[0], '').trim() : name,
+        status,
+        level: section === 'パーク情報' ? 'terrainPark' : courseLevels[m?.[1]]
+      };
+    });
 }
