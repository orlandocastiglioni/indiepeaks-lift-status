From 945c19a9194c1b44c195bc783240930a761b2af4 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Fri, 17 Jul 2026 13:07:47 +0000
Subject: [PATCH 76/77] resort: fix mthood - conditions page replaced, read the
 POI API instead

/the-mountain/conditions now redirects to /mountain-report and #liftGrid
is gone, so the parser has published nothing since the redesign. The page
hydrates from /api/weather/poi (lumiplan-style: types LIFT vs SECTOR,
openingStatusCompl OPEN/CLOSED/FORECAST - field names confirmed from the
page bundle and live sector stubs; vocabulary matches Saddleback's
lumiplan feed). Fixture synthesized from that schema - re-verify against
live winter data at season start.
---
 lib/resorts/mthood/index.js      | 23 +++++++++++++++++------
 lib/resorts/mthood/resort.json   | 12 ++++++++++--
 test/resorts/example/mthood.json | 11 +++++++++++
 test/resorts/mthood.js           | 16 ++++------------
 4 files changed, 42 insertions(+), 20 deletions(-)
 create mode 100644 test/resorts/example/mthood.json

diff --git a/lib/resorts/mthood/index.js b/lib/resorts/mthood/index.js
index 36fdef45..0aa54fff 100644
--- a/lib/resorts/mthood/index.js
+++ b/lib/resorts/mthood/index.js
@@ -1,7 +1,18 @@
-export default {
-  selector: '#liftGrid tbody tr',
-  parse: {
-    name: 1,
-    status: 0
+import coerce from '../../tools/coerce.js';
+
+// lumiplan-style POI feed behind the mountain-report page; items carry
+// types (LIFT vs SECTOR groupers) and OPEN/CLOSED/FORECAST in
+// openingStatusCompl. Off season the feed returns sector stubs only.
+export default function parse(data = {}) {
+  const liftStatus = {};
+  for (const item of data.data ?? []) {
+    if (!item.types?.includes('LIFT')) {
+      continue;
+    }
+    const status = item.openingStatusCompl ?? item.openingStatus;
+    if (item.name && status) {
+      liftStatus[item.name.trim()] = coerce(status);
+    }
   }
-};
+  return liftStatus;
+}
