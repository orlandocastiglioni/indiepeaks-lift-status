diff --git a/lib/resorts/wisp/index.js b/lib/resorts/wisp/index.js
new file mode 100644
index 00000000..b336618f
--- /dev/null
+++ b/lib/resorts/wisp/index.js
@@ -0,0 +1,16 @@
+import { findText } from '../../tools/domutil.js';
+
+// Pacific Group Resorts theme: cells are tagged with data-title attributes,
+// the Status cell carries the state as a class (text/images vary)
+export default {
+  selector: 'tr:has(td[data-title="Lift Name"])',
+  parse: row => {
+    const tds = row.children.filter(c => c.name === 'td');
+    const byTitle = t => tds.find(td => td.attribs?.['data-title'] === t);
+    const name = findText(byTitle('Lift Name'));
+    const status = byTitle('Status')?.attribs.class;
+    if (name && status) {
+      return { name, status };
+    }
+  }
+};
diff --git a/lib/resorts/wisp/resort.json b/lib/resorts/wisp/resort.json
new file mode 100644
index 00000000..3611fa10
--- /dev/null
+++ b/lib/resorts/wisp/resort.json
@@ -0,0 +1,15 @@
+{
+  "name": "Wisp Resort",
+  "url": {
+    "host": "https://www.wispresort.com",
+    "pathname": "/mountain-report-cams/"
+  },
+  "trails": true,
+  "tags": [
+    "Maryland"
+  ],
+  "ll": [
+    -79.3903,
+    39.5626
+  ]
+}
diff --git a/lib/resorts/wisp/trails.js b/lib/resorts/wisp/trails.js
new file mode 100644
index 00000000..394fdbc0
--- /dev/null
+++ b/lib/resorts/wisp/trails.js
@@ -0,0 +1,15 @@
+import { findText } from '../../tools/domutil.js';
+
+// run tables use the same data-title cells; no difficulty column
+export default {
+  selector: 'tr:has(td[data-title="Run Name"])',
+  parse: row => {
+    const tds = row.children.filter(c => c.name === 'td');
+    const byTitle = t => tds.find(td => td.attribs?.['data-title'] === t);
+    const name = findText(byTitle('Run Name'));
+    const status = byTitle('Status')?.attribs.class;
+    if (name && status) {
+      return { name, status };
+    }
+  }
+};
