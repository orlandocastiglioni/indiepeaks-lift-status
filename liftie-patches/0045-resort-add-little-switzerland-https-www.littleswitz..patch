--- /dev/null
+++ b/lib/resorts/little-switzerland/resort.json
@@ -0,0 +1,16 @@
+{
+  "name": "Little Switzerland",
+  "url": {
+    "host": "https://www.littleswitz.com",
+    "pathname": "/mountain-info/snow-report"
+  },
+  "trails": true,
+  "tags": [
+    "Wisconsin",
+    "Midwest"
+  ],
+  "ll": [
+    -88.2848,
+    43.3327
+  ]
+}
diff --git a/lib/resorts/little-switzerland/trails.js b/lib/resorts/little-switzerland/trails.js
new file mode 100644
index 00000000..db5d2683
--- /dev/null
+++ b/lib/resorts/little-switzerland/trails.js
@@ -0,0 +1,19 @@
+import select from '../../select.js';
+import { allText } from '../../tools/domutil.js';
+
+export default {
+  selector: '.Trail.component-row',
+  parse: row => {
+    const title = select(row.children, '.cell.title')[0];
+    const status = select(row.children, '.cell.status')[0];
+    const level = title && select(title.children, '.f-icon.level')[0];
+    if (!title || !status) {
+      return;
+    }
+    return {
+      name: allText(title),
+      status: status.attribs.title ?? allText(status),
+      level: level?.attribs.title
+    };
+  }
+};
