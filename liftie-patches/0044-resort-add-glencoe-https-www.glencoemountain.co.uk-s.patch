diff --git a/lib/resorts/glencoe/status.js b/lib/resorts/glencoe/status.js
new file mode 100644
index 00000000..6749e592
--- /dev/null
+++ b/lib/resorts/glencoe/status.js
@@ -0,0 +1,6 @@
+// status is an image: 2.jpg shows on the summer-running access chair (open),
+// 0.jpg on everything shut; 1.jpg presumed hold
+export default function status(src = '') {
+  const code = src.match(/images\/(\d)\.jpg/)?.[1];
+  return { 0: 'closed', 1: 'hold', 2: 'open' }[code];
+}
diff --git a/lib/resorts/glencoe/trails.js b/lib/resorts/glencoe/trails.js
new file mode 100644
index 00000000..bb587fe5
--- /dev/null
+++ b/lib/resorts/glencoe/trails.js
@@ -0,0 +1,24 @@
+import select from '../../select.js';
+import { findText } from '../../tools/domutil.js';
+import status from './status.js';
+
+// runs list rows: name td + td with "Difficulty:<span>green</span>" and a status image
+export default {
+  selector: 'table tr',
+  parse: row => {
+    const tds = row.children.filter(c => c.name === 'td');
+    if (tds.length !== 2) {
+      return;
+    }
+    const div = select(tds[1].children, 'div')[0];
+    if (!/Difficulty:/.test(findText(div) ?? '')) {
+      return;
+    }
+    const level = findText(select(tds[1].children, 'span')[0]);
+    const img = select(tds[1].children, 'img')[0];
+    const name = findText(tds[0])?.trim();
+    if (name && img) {
+      return { name, status: status(img.attribs.src), level };
+    }
+  }
+};
