diff --git a/lib/resorts/ski-sawmill/sections.js b/lib/resorts/ski-sawmill/sections.js
new file mode 100644
index 00000000..ec2df226
--- /dev/null
+++ b/lib/resorts/ski-sawmill/sections.js
@@ -0,0 +1,23 @@
+import select from '../../select.js';
+import { findText } from '../../tools/domutil.js';
+
+// one ea-advanced-data-table per section; the first header cell names it
+// (Lifts / Beginner Trails / Intermediate Trails / Expert Trails / Terrain Park / Tubing)
+export default function sections(dom) {
+  const result = [];
+  for (const table of select(dom, 'table.ea-advanced-data-table')) {
+    const section = findText(select(table.children, 'thead th')[0])?.trim();
+    if (!section) {
+      continue;
+    }
+    for (const row of select(table.children, 'tbody tr')) {
+      const tds = row.children.filter(c => c.name === 'td');
+      const name = findText(select(tds[0]?.children ?? [], 'span')[0] ?? tds[0]);
+      const status = findText(select(tds[1]?.children ?? [], 'span')[0] ?? tds[1]);
+      if (name && status) {
+        result.push({ section, name: name.trim(), status });
+      }
+    }
+  }
+  return result;
+}
diff --git a/lib/resorts/ski-sawmill/trails.js b/lib/resorts/ski-sawmill/trails.js
new file mode 100644
index 00000000..d541caae
--- /dev/null
+++ b/lib/resorts/ski-sawmill/trails.js
@@ -0,0 +1,14 @@
+import sections from './sections.js';
+
+const levels = {
+  'Beginner Trails': 'green',
+  'Intermediate Trails': 'blue',
+  'Expert Trails': 'black',
+  'Terrain Park': 'terrainPark'
+};
+
+export default function parse(dom) {
+  return sections(dom)
+    .filter(r => r.section !== 'Lifts')
+    .map(({ section, name, status }) => ({ name, status, level: levels[section] }));
+}
