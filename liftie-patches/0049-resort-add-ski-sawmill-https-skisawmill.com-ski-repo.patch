+<script type="text/javascript">
+jQuery(document).ready(function($) {
+	$('table:not(#operatingHours table) tr').each(function() {
+        // Select all cells (td) in the current row
+        $(this).find('td').each(function() {
+            var text = $(this).text().trim().toLowerCase(); // Get cell text content
+			
+            if (text === 'open') {
+                $(this).closest('tr').addClass('openTrail'); // Add class for "open"
+                return false; // Break out of the loop
+            } else if (text === 'closed') {
+                $(this).closest('tr').addClass('closedTrail'); // Add class for "closed"
+                return false; // Break out of the loop
+            }else if (text === 'making snow') {
+                $(this).closest('tr').addClass('makingSnow'); // Add class for "making snow"
+                return false; // Break out of the loop
+            }else if (text === 'thin cover') {
+                $(this).closest('tr').addClass('thinCover'); // Add class for "light cover"
+                return false; // Break out of the loop
+            }
+        });
+    });
+
+    // FORM STUFF
+    var now = new Date();
+    var day = ("0" + now.getDate()).slice(-2);
+    var month = ("0" + (now.getMonth() + 1)).slice(-2);
+    var today = now.getFullYear() + "-" + month + "-" + day;
+    $('#datePicker').val(today);
+    $("#datePicker").attr("min", today);
+	
+	
+  	// CONTACT FOR BOOKINGS FORM
+	var allowedUrls = [
+		"https://skisawmill.com/services/chalet/",
+		"https://skisawmill.com/services/bunkhouse/",
+		"https://skisawmill.com/services/mountain-inn/",
+		"https://skisawmill.com/services/farmhouse/"
+	];
+
+	var currentUrl = window.location.href;
+
+	if (allowedUrls.includes(currentUrl)) {
+		var lodgingTitle = $("h2.services_page_title").text();
+		$("input[name='txtLodging']").val(lodgingTitle);
+	}
+	
+	
+  	// GET IN TOUCH FORM - CHOOSE CORRECT DEPARTMENT
+   	if($(location).attr('pathname').includes("get-in-touch")){
+        var urlParams = new URLSearchParams(window.location.search);
+        if(urlParams.has("recipient")){
+            var departmentName = urlParams.get("recipient");
+		}
+
+        $("#ddlRecipientContact option").each(function(){
+            if($(this).is(":contains(" + departmentName + ")")){
+                $("#ddlRecipientContact").val($(this).text());
+                $("#ddlRecipientContact").trigger('change');
+            }
+        });
+    }	
+});</script>
