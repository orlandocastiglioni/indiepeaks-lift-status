From 044ad4823983dd676500ebb53a3ebe8a9dc9b8fa Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Fri, 17 Jul 2026 13:04:58 +0000
Subject: [PATCH 71/77] resort: fix pitztaler-gletscher - strip 'GLE ||' /
 'RIFF ||' area prefixes

The site prefixes every lift and piste name with an area code separated by
a double pipe ('GLE || Gletscherexpress'), which the app displayed
verbatim. Strip the prefix from display names.
---
 lib/resorts/pitztaler-gletscher/index.js   |  5 +-
 lib/resorts/pitztaler-gletscher/trails.js  |  2 +-
 test/resorts/pitztaler-gletscher-trails.js | 60 +++++++++++-----------
 test/resorts/pitztaler-gletscher.js        | 24 ++++-----
 4 files changed, 47 insertions(+), 44 deletions(-)

diff --git a/lib/resorts/pitztaler-gletscher/index.js b/lib/resorts/pitztaler-gletscher/index.js
index 6c3a6fb..9ad5555 100644
--- a/lib/resorts/pitztaler-gletscher/index.js
+++ b/lib/resorts/pitztaler-gletscher/index.js
@@ -13,6 +13,9 @@ export default {
       return;
     }
     const status = dot.attribs.class.replace('tableDot', '').trim();
-    return { name: allText(nameCell), status: status || 'open' };
+    // cells prefix names with the area code - "GLE || Gletscherexpress" -
+    // which reads badly as a display name
+    const name = allText(nameCell).replace(/^\s*(GLE|RIFF)\s*\|\|\s*/, '').trim();
+    return { name, status: status || 'open' };
   }
 };
diff --git a/lib/resorts/pitztaler-gletscher/trails.js b/lib/resorts/pitztaler-gletscher/trails.js
index 10ffec3..0885c70 100644
--- a/lib/resorts/pitztaler-gletscher/trails.js
+++ b/lib/resorts/pitztaler-gletscher/trails.js
@@ -21,7 +21,7 @@ export default {
       .trim()
       .toLowerCase();
     return {
-      name,
+      name: name.replace(/^\s*(GLE|RIFF)\s*\|\|\s*/, '').trim(),
       status: dot.attribs.class.replace('tableDot', '').trim() || 'open',
       level: classifications[classification]
     };
