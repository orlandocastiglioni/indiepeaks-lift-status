diff --git a/lib/resorts/nayoro-piyashiri/status.js b/lib/resorts/nayoro-piyashiri/status.js
new file mode 100644
index 00000000..dd2c6178
--- /dev/null
+++ b/lib/resorts/nayoro-piyashiri/status.js
@@ -0,0 +1,11 @@
+// status text translation - the page mixes English and Japanese labels
+export default function status(text = '') {
+  const t = text.trim();
+  if (/運行中|営業中|^OPEN/i.test(t)) {
+    return 'open';
+  }
+  if (/運休|終了|^CLOSE/i.test(t)) {
+    return 'closed';
+  }
+  return t; // STANDBY etc - coerce maps standby to hold
+}
diff --git a/lib/resorts/nayoro-piyashiri/trails.js b/lib/resorts/nayoro-piyashiri/trails.js
new file mode 100644
index 00000000..1b1a5304
--- /dev/null
+++ b/lib/resorts/nayoro-piyashiri/trails.js
@@ -0,0 +1,23 @@
+import select from '../../select.js';
+import { findText } from '../../tools/domutil.js';
+import status from './status.js';
+
+// same right-table markup with th Course; no difficulty markers
+export default function parse(dom) {
+  const rows = [];
+  const seen = new Set();
+  for (const table of select(dom, 'table.right-table')) {
+    if (!select(table.children, 'th').some(th => /Course/i.test(findText(th) ?? ''))) {
+      continue;
+    }
+    for (const row of select(table.children, 'tr')) {
+      const name = findText(select(row.children, 'td.course')[0])?.trim();
+      const state = findText(select(row.children, 'td.status')[0]);
+      if (name && state && !seen.has(name)) {
+        seen.add(name);
+        rows.push({ name, status: status(state) });
+      }
+    }
+  }
+  return rows;
+}
