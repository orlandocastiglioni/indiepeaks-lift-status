Date: Sun, 12 Jul 2026 09:52:05 -0400
Subject: [PATCH 27/77] resort: add skiwelt trail status

---
 lib/resorts/skiwelt/resort.json          |  11 +
 lib/resorts/skiwelt/trails.js            |  17 +
 test/resorts/example/skiwelt-trails.json |   1 +
 test/resorts/skiwelt-trails.js           | 508 +++++++++++++++++++++++
 4 files changed, 537 insertions(+)
 create mode 100644 lib/resorts/skiwelt/trails.js
 create mode 100644 test/resorts/example/skiwelt-trails.json
 create mode 100644 test/resorts/skiwelt-trails.js

diff --git a/lib/resorts/skiwelt/resort.json b/lib/resorts/skiwelt/resort.json
index 76638c6a..58f73810 100644
--- a/lib/resorts/skiwelt/resort.json
+++ b/lib/resorts/skiwelt/resort.json
@@ -21,5 +21,16 @@
       "season": "winter",
       "typeIDs": 1
     }
+  },
+  "trails": {
+    "host": "https://www.skiwelt.at",
+    "pathname": "/webapi/micadoweb",
+    "query": {
+      "api": "Micado.Ski.Web/Micado.Ski.Web.IO.Api.FacilityApi/List.api",
+      "region": "skiwelt",
+      "season": "winter",
+      "typeIDs": 2
+    },
+    "json": true
   }
 }
diff --git a/lib/resorts/skiwelt/trails.js b/lib/resorts/skiwelt/trails.js
new file mode 100644
index 00000000..b99a2907
--- /dev/null
+++ b/lib/resorts/skiwelt/trails.js
@@ -0,0 +1,17 @@
+const levels = {
+  'easy-piste': 'green',
+  'medium-piste': 'blue',
+  'difficult-piste2': 'black',
+  skiroute: 'doubleBlack'
+};
+
+export default function parse(data = {}) {
+  const { items = [] } = data;
+  return items
+    .filter(item => item.state) // off season the report carries no state
+    .map(({ title, state, facilityTypeIdentifier }) => ({
+      name: title,
+      status: state,
+      level: levels[facilityTypeIdentifier]
+    }));
+}
