diff --git a/lib/resorts/echo-mountain/status.js b/lib/resorts/echo-mountain/status.js
new file mode 100644
index 00000000..cf68841b
--- /dev/null
+++ b/lib/resorts/echo-mountain/status.js
@@ -0,0 +1,5 @@
+// status is an icon image: open.svg / projected.svg / closed.svg
+export default function status(src = '') {
+  const s = src.match(/images\/([a-z]+)\.svg/)?.[1];
+  return s === 'projected' ? 'scheduled' : s;
+}
