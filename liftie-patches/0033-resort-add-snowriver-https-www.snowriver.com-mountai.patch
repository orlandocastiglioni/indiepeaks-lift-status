 lib/resorts/snowriver/resort.json   |   16 +
 lib/resorts/snowriver/trails.js     |   19 +
 test/resorts/example/snowriver.html | 3765 +++++++++++++++++++++++++++
 test/resorts/snowriver-trails.js    |  364 +++
 test/resorts/snowriver.js           |   14 +
 6 files changed, 4193 insertions(+)
 create mode 100644 lib/resorts/snowriver/index.js
 create mode 100644 lib/resorts/snowriver/resort.json
 create mode 100644 lib/resorts/snowriver/trails.js
 create mode 100644 test/resorts/example/snowriver.html
 create mode 100644 test/resorts/snowriver-trails.js
 create mode 100644 test/resorts/snowriver.js

diff --git a/lib/resorts/snowriver/index.js b/lib/resorts/snowriver/index.js
new file mode 100644
index 00000000..bb4aa392
--- /dev/null
+++ b/lib/resorts/snowriver/index.js
@@ -0,0 +1,15 @@
+import select from '../../select.js';
+import { allText } from '../../tools/domutil.js';
+
+// same platform as granite-peak: flat component rows, status icon title attr
+export default {
+  selector: '.lift.component-row',
+  parse: row => {
+    const title = select(row.children, '.cell.title')[0];
+    const status = select(row.children, '.status .f-icon')[0];
+    if (!title || !status) {
+      return;
+    }
+    return { name: allText(title), status: status.attribs.title };
+  }
+};
diff --git a/lib/resorts/snowriver/resort.json b/lib/resorts/snowriver/resort.json
new file mode 100644
index 00000000..b6062eff
--- /dev/null
+++ b/lib/resorts/snowriver/resort.json
@@ -0,0 +1,16 @@
+{
+  "name": "Snowriver Mountain Resort",
+  "url": {
+    "host": "https://www.snowriver.com",
+    "pathname": "/mountain-info/mountain-report"
+  },
+  "trails": true,
+  "tags": [
+    "Michigan",
+    "Midwest"
+  ],
+  "ll": [
+    -89.899,
+    46.49
+  ]
+}
diff --git a/lib/resorts/snowriver/trails.js b/lib/resorts/snowriver/trails.js
new file mode 100644
index 00000000..f060bf90
--- /dev/null
+++ b/lib/resorts/snowriver/trails.js
@@ -0,0 +1,19 @@
+import select from '../../select.js';
+import { allText } from '../../tools/domutil.js';
+
+export default {
+  selector: '.trail.component-row',
+  parse: row => {
+    const title = select(row.children, '.cell.title')[0];
+    const status = select(row.children, '.status .f-icon')[0];
+    const level = title && select(title.children, '.f-icon.level')[0];
+    if (!title || !status) {
+      return;
+    }
+    return {
+      name: allText(title),
+      status: status.attribs.title,
+      level: level?.attribs.title
+    };
+  }
+};
