From 13f82c06e968d878585c8a18546e3719f44d5bee Mon Sep 17 00:00:00 2001
From: Orlando Castiglioni <orlando@orlandocc.me>
Date: Sun, 12 Jul 2026 07:55:21 -0400
Subject: [PATCH 02/52] resort: fix burke-mountain
 (https://www.skiburke.com/ski-ride/weather-conditions)

---
 lib/resorts/burke-mountain/index.js    | 26 ++++++++++++--------------
 lib/resorts/burke-mountain/resort.json |  4 ++--
 2 files changed, 14 insertions(+), 16 deletions(-)

diff --git a/lib/resorts/burke-mountain/index.js b/lib/resorts/burke-mountain/index.js
index 3186825b..f3f100b2 100644
--- a/lib/resorts/burke-mountain/index.js
+++ b/lib/resorts/burke-mountain/index.js
@@ -1,3 +1,9 @@
+function hasClass(node, className) {
+  if (node?.attribs?.class?.includes(className)) return true;
+  if (node?.children) return node.children.some(c => hasClass(c, className));
+  return false;
+}
+
 export default {
   selector: '.uk-h2:contains(Lift Status) + .fs-table tbody tr',
   parse: {
@@ -5,21 +11,13 @@ export default {
       child: '0/0',
       regex: /(.*?)(\s+\d|$)/s
     },
+    // in season the table has separate Open and Closed columns; off season it
+    // collapses to a single status column - look for the icon in any of them
     status: row => {
-      const children = row.children.filter(c => c.type === 'tag');
-      const openCol = children[1];
-      const closedCol = children[2]; // Might be undefined in old 2-col layout
-
-      // Helper for new site structure (uikit classes)
-      const hasClass = (node, className) => {
-        if (node?.attribs?.class?.includes(className)) return true;
-        if (node?.children) return node.children.some(c => hasClass(c, className));
-        return false;
-      };
-
-      // New Logic (uk-text-success / danger inside col 1 or 2)
-      if (hasClass(openCol, 'uk-text-success')) return 'open';
-      if (hasClass(closedCol, 'uk-text-danger')) return 'closed';
+      const cols = row.children.filter(c => c.type === 'tag').slice(1);
+      if (cols.some(col => hasClass(col, 'uk-text-success'))) return 'open';
+      if (cols.some(col => hasClass(col, 'uk-text-warning'))) return 'hold';
+      if (cols.some(col => hasClass(col, 'uk-text-danger'))) return 'closed';
     }
   }
 };
diff --git a/lib/resorts/burke-mountain/resort.json b/lib/resorts/burke-mountain/resort.json
index 90db2710..6aaa2ff1 100644
--- a/lib/resorts/burke-mountain/resort.json
+++ b/lib/resorts/burke-mountain/resort.json
@@ -1,8 +1,8 @@
 {
   "name": "Burke Mountain",
   "url": {
-    "host": "https://skiburke.com",
-    "pathname": "/the-mountain/weather-conditions"
+    "host": "https://www.skiburke.com",
+    "pathname": "/ski-ride/weather-conditions"
   },
   "tags": [
     "Vermont",
-- 
2.39.5

