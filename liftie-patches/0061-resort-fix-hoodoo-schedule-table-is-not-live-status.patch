From 21789fa800f489a0db290b8f23d5d898abee3a04 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Fri, 17 Jul 2026 12:59:00 +0000
Subject: [PATCH 61/77] resort: fix hoodoo - schedule table is not live status

#tablepress-10 lists LIFT | HOURS (the page footnote says it is the plan,
not status). The old parser called any non-CLOSED cell 'open', reporting
6/7 lifts open in July, and the newly added thead row became a phantom
lift literally named 'LIFT' (status open). Scope to tbody and map posted
hours to 'scheduled'; fixture refreshed to the current page.
---
 lib/resorts/hoodoo/index.js           |    7 +-
 test/resorts/example/hoodoo-2026.html | 2503 +++++++++++++++++++++++++
 test/resorts/hoodoo.js                |   11 +-
 3 files changed, 2514 insertions(+), 7 deletions(-)
 create mode 100644 test/resorts/example/hoodoo-2026.html

diff --git a/lib/resorts/hoodoo/index.js b/lib/resorts/hoodoo/index.js
index 2464a67..e1c41cd 100644
--- a/lib/resorts/hoodoo/index.js
+++ b/lib/resorts/hoodoo/index.js
@@ -1,10 +1,13 @@
 export default {
-  selector: '#tablepress-10 tr',
+  // #tablepress-10 is a LIFT | HOURS schedule, not live status: rows with
+  // posted hours are only *planned* to run (the page's own footnote), so
+  // they map to scheduled, never open; tbody skips the LIFT/HOURS header
+  selector: '#tablepress-10 tbody tr',
   parse: {
     name: 0,
     status: {
       child: 1,
-      fn: s => (s === 'CLOSED' ? 'closed' : 'open')
+      fn: s => (s === 'CLOSED' ? 'closed' : 'scheduled')
     }
   }
 };
diff --git a/test/resorts/example/hoodoo-2026.html b/test/resorts/example/hoodoo-2026.html
new file mode 100644
index 0000000..7e4fb80
--- /dev/null
+++ b/test/resorts/example/hoodoo-2026.html
@@ -0,0 +1,2503 @@
