diff --git a/lib/resorts/okunakayama/status.js b/lib/resorts/okunakayama/status.js
new file mode 100644
index 00000000..82c6a52b
--- /dev/null
+++ b/lib/resorts/okunakayama/status.js
@@ -0,0 +1,11 @@
+// shared status glyph translation for the Japanese status tables
+export default function status(text = '') {
+  const t = text.trim();
+  if (/^[○◯〇]$|運行|営業中/.test(t)) {
+    return 'open';
+  }
+  if (/^[×✕✖-]$|運休|営業終了/.test(t)) {
+    return 'closed';
+  }
+  return t;
+}
diff --git a/lib/resorts/okunakayama/trails.js b/lib/resorts/okunakayama/trails.js
new file mode 100644
index 00000000..4306eaf4
--- /dev/null
+++ b/lib/resorts/okunakayama/trails.js
@@ -0,0 +1,17 @@
+import select from '../../select.js';
+import { findText } from '../../tools/domutil.js';
+import status from './status.js';
+
+// course tables follow the コース名 heading; no difficulty markers on the page
+export default function parse(dom) {
+  const rows = [];
+  for (const row of select(dom, 'h3:contains(コース名) ~ div table tr')) {
+    const cells = row.children.filter(c => c.name === 'th' || c.name === 'td');
+    const name = findText(cells[0])?.trim();
+    const state = findText(cells[1]);
+    if (name && state) {
+      rows.push({ name, status: status(state) });
+    }
+  }
+  return rows;
+}
