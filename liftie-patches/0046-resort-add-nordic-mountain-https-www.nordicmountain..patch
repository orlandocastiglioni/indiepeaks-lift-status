diff --git a/lib/resorts/nordic-mountain/index.js b/lib/resorts/nordic-mountain/index.js
new file mode 100644
index 00000000..a4d8d6b8
--- /dev/null
+++ b/lib/resorts/nordic-mountain/index.js
@@ -0,0 +1,14 @@
+import select from '../../select.js';
+import { allText } from '../../tools/domutil.js';
+
+export default {
+  selector: '.Lift.component-row',
+  parse: row => {
+    const title = select(row.children, '.cell.title')[0];
+    const status = select(row.children, '.cell.status')[0];
+    if (!title || !status) {
+      return;
+    }
+    return { name: allText(title), status: status.attribs.title ?? allText(status) };
+  }
+};
diff --git a/lib/resorts/nordic-mountain/resort.json b/lib/resorts/nordic-mountain/resort.json
new file mode 100644
index 00000000..326f467e
--- /dev/null
+++ b/lib/resorts/nordic-mountain/resort.json
@@ -0,0 +1,16 @@
+{
+  "name": "Nordic Mountain",
+  "url": {
+    "host": "https://www.nordicmountain.com",
+    "pathname": "/mountain-info/snow-report-nordic"
+  },
+  "trails": true,
+  "tags": [
