From ee280931af183821dd69d8a2a5b36a11daa12654 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Fri, 17 Jul 2026 13:06:58 +0000
Subject: [PATCH 75/77] resort: fix owlshead - rebuild for the redesigned
 conditions page

The old .legende_* markup is gone (absent from the 2026-01-21 winter
snapshot too, so the parser produced nothing all last season). The page
now groups trails under lift sections: numbered .slope-name titles
('1. Summit') are the six lifts, with an Open/Closed state span; the
unnumbered Snowparks / Alpine touring sections are skipped.
---
 lib/resorts/owlshead/index.js           |   20 +-
 test/resorts/example/owlshead-2026.html | 4784 +++++++++++++++++++++++
 test/resorts/owlshead.js                |   12 +-
 3 files changed, 4803 insertions(+), 13 deletions(-)
 create mode 100644 test/resorts/example/owlshead-2026.html

diff --git a/lib/resorts/owlshead/index.js b/lib/resorts/owlshead/index.js
index f085079..a7e729e 100644
--- a/lib/resorts/owlshead/index.js
+++ b/lib/resorts/owlshead/index.js
@@ -1,11 +1,17 @@
+import select from '../../select.js';
+import { findText } from '../../tools/domutil.js';
+
+// the conditions page groups trails under lift sections; numbered
+// .slope-name titles ("1. Summit") are the lifts, while the unnumbered
+// "Snowparks" / "Alpine touring" sections are not
 export default {
-  selector: '.legende_title:contains(Lifts) + .legende_piste li',
-  parse: {
-    name: 2,
-    status: {
-      child: 3,
-      attribute: 'class',
-      regex: /legende_(\w+)$/
+  selector: '.section-piste .slope-name',
+  parse: row => {
+    const title = findText(select(row.children, '.label-title')[0]);
+    const m = title?.match(/^\d+\.\s*(.+)$/);
+    const status = findText(select(row.children, '[class^=section-]')[0]);
+    if (m && status) {
+      return { name: m[1].trim(), status };
     }
   }
 };
