+<script>
+document.addEventListener('DOMContentLoaded', function() {
+    const images = document.querySelectorAll('.image-modal-trigger');
+    
+    images.forEach(element => {
+        element.style.cursor = 'pointer';
+        element.addEventListener('click', function(e) {
+            e.preventDefault();
+            e.stopPropagation();
+            
+            // Obtener el src de la imagen
+            let imageSrc = null;
+            
+            if (this.tagName === 'IMG') {
+                imageSrc = this.getAttribute('src');
+            } else {
+                const img = this.querySelector('img');
+                if (img) {
+                    imageSrc = img.getAttribute('src');
+                }
+            }
+            
+            // Validar que tenemos un src válido
+            if (imageSrc && imageSrc !== 'undefined' && imageSrc.startsWith('http')) {
+                openImageModal(imageSrc);
+            } else {
+                console.error('No se pudo obtener la URL de la imagen:', imageSrc);
+            }
+        });
+    });
+});
+
+function openImageModal(imageSrc) {
+    // Crear modal
+    const modal = document.createElement('div');
+    modal.style.cssText = 'position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.95); z-index: 9999; overflow: auto; padding: 60px 20px 20px 20px; box-sizing: border-box;';
+    
+    // Crear botón cerrar
+    const closeBtn = document.createElement('span');
+    closeBtn.innerHTML = '&times;';
+    closeBtn.style.cssText = 'position: fixed; top: 20px; right: 30px; color: white; font-size: 40px; font-weight: bold; cursor: pointer; z-index: 10000; transition: color 0.3s;';
+    closeBtn.onmouseover = () => closeBtn.style.color = '#ccc';
+    closeBtn.onmouseout = () => closeBtn.style.color = 'white';
+    
+    // Crear imagen
+    const img = document.createElement('img');
+    img.src = imageSrc;
+    img.style.cssText = 'display: block; width: auto; height: auto; margin: 0 auto;';
+    
+    // Agregar elementos
+    modal.appendChild(closeBtn);
+    modal.appendChild(img);
+    document.body.appendChild(modal);
+    document.body.style.overflow = 'hidden';
+    
+    // Cerrar modal
+    function closeModal() {
+        modal.remove();
+        document.body.style.overflow = '';
+    }
+    
+    closeBtn.onclick = closeModal;
+    modal.onclick = (e) => {
+        if(e.target === modal) closeModal();
+    };
+    
+    // Cerrar con ESC
+    const escHandler = (e) => {
+        if(e.key === 'Escape') {
+            closeModal();
+            document.removeEventListener('keydown', escHandler);
+        }
+    };
+    document.addEventListener('keydown', escHandler);
+}</script>
