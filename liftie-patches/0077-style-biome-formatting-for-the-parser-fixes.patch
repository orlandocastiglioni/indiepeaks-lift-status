diff --git a/lib/resorts/big-moose/trails.js b/lib/resorts/big-moose/trails.js
index 776efc2..97863d4 100644
--- a/lib/resorts/big-moose/trails.js
+++ b/lib/resorts/big-moose/trails.js
@@ -32,7 +32,9 @@ export default function parse(dom) {
     // the Upper Mountain section annotates items with their real rating
     // ("Upper Penobscot - Blue Square") - strip it and let it win over the
     // section level
-    const suffix = name?.match(/\s*-\s*(green circle|blue square|black diamond|double black(?: diamond)?|terrain park)\s*$/i);
+    const suffix = name?.match(
+      /\s*-\s*(green circle|blue square|black diamond|double black(?: diamond)?|terrain park)\s*$/i
+    );
     if (suffix) {
       name = name.slice(0, suffix.index).trim();
       level = sectionLevel(suffix[1]);
diff --git a/lib/resorts/pitztaler-gletscher/index.js b/lib/resorts/pitztaler-gletscher/index.js
index 9ad5555..88d4abd 100644
--- a/lib/resorts/pitztaler-gletscher/index.js
+++ b/lib/resorts/pitztaler-gletscher/index.js
@@ -15,7 +15,9 @@ export default {
     const status = dot.attribs.class.replace('tableDot', '').trim();
     // cells prefix names with the area code - "GLE || Gletscherexpress" -
     // which reads badly as a display name
-    const name = allText(nameCell).replace(/^\s*(GLE|RIFF)\s*\|\|\s*/, '').trim();
+    const name = allText(nameCell)
+      .replace(/^\s*(GLE|RIFF)\s*\|\|\s*/, '')
+      .trim();
     return { name, status: status || 'open' };
   }
 };
