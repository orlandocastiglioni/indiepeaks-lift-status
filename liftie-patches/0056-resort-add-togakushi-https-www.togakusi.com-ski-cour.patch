diff --git a/lib/resorts/togakushi/sections.js b/lib/resorts/togakushi/sections.js
new file mode 100644
index 00000000..e9f350d8
--- /dev/null
+++ b/lib/resorts/togakushi/sections.js
@@ -0,0 +1,22 @@
+import select from '../../select.js';
+import { findText } from '../../tools/domutil.js';
+
+// status blocks are headed by h4.p-course__statusList__item-ttl
+// (リフト情報 lifts / パーク情報 parks / コース情報 courses); each row is
+// <th>name</th><td class="is-open|is-close">
+export default function sections(dom) {
+  const rows = [];
+  let section;
+  for (const node of select(dom, '.p-course__statusList__item-ttl, .p-course__status__table tr')) {
+    if (/ttl/.test(node.attribs?.class ?? '')) {
+      section = findText(node)?.trim();
+      continue;
+    }
+    const name = findText(node.children.find(c => c.name === 'th'));
+    const status = node.children.find(c => c.name === 'td')?.attribs.class?.match(/is-(open|close)/)?.[1];
+    if (name && status) {
+      rows.push({ section, name: name.trim(), status: status === 'close' ? 'closed' : 'open' });
+    }
+  }
+  return rows;
+}
diff --git a/lib/resorts/togakushi/trails.js b/lib/resorts/togakushi/trails.js
new file mode 100644
index 00000000..582a80cc
--- /dev/null
+++ b/lib/resorts/togakushi/trails.js
@@ -0,0 +1,13 @@
+import sections from './sections.js';
+
+const courseLevels = { 初級: 'green', 中級: 'blue', 上級: 'black' };
+
+export default function parse(dom) {
+  return sections(dom)
+    .filter(r => r.section !== 'リフト情報')
+    .map(({ section, name, status }) => ({
+      name,
+      status,
+      level: section === 'パーク情報' ? 'terrainPark' : courseLevels[name.match(/（(初級|中級|上級)/)?.[1]]
+    }));
+}
